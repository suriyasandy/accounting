@authenticate(UserRole.ADMIN)
def get(self):

    print("MODELS_DIR =", MODELS_DIR)
    print("Exists:", MODELS_DIR.exists())
    print("Content:", list(MODELS_DIR.glob("**/*")))

    models = []

    for model_file in MODELS_DIR.glob("**/*_model.pkl"):

        feature_file = model_file.with_name(
            model_file.name.replace("_model.pkl", "_features.json")
        )

        models.append({
            "model": str(model_file.relative_to(MODELS_DIR)),
            "features": str(feature_file.relative_to(MODELS_DIR))
        })

    return models, HTTPStatus.OK
