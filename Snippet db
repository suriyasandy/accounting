@authenticate(UserRole.ADMIN)
def get(self):
    """Handle GET request to this endpoint."""

    model_paths = []

    cg_dirs = cache.list_dir(MODELS_DIR)

    for cg in cg_dirs:

        if not cg.is_dir():
            continue

        files = cache.list_dir(cg)

        for f in files:

            if f.name.endswith("_model.pkl"):
                model_paths.append(
                    str(f.relative_to(MODELS_DIR))
                )

    return model_paths, HTTPStatus.OK
