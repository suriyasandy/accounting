@authenticate(UserRole.ADMIN)
def get(self):
    """Handle GET request to list trained models"""

    paths = cache.list_dir(MODELS_DIR)

    models = []

    for p in paths:

        name = p.name

        # only return trained model files
        if name.endswith("_model.pkl"):

            control_group = name.replace("_model.pkl", "")

            models.append({
                "control_group": control_group,
                "model_file": name,
                "features_file": f"{control_group}_features.json"
            })

    return models, HTTPStatus.OK
