def _prediction_to_json(self, model_output):

    prediction = []

    for p in model_output:

        features = []

        for fi in p.features:
            features.append(
                {
                    "key": fi.key,
                    "value": fi.value,
                    "importance": float(fi.importance)
                }
            )

        prediction.append(
            {
                "key": p.key,
                "value": p.value,
                "confidence": float(p.confidence),
                "timestamp": p.timestamp.isoformat(),
                "root_cause": getattr(p, "root_cause", None),
                "features": features
            }
        )

    return prediction



