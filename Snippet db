from http import HTTPStatus
from flask_restx import Resource
from pathlib import Path

from lentil.cache import MODELS_DIR, cache
from lentil.auth.authenticator import authenticate
from lentil.auth.user import UserRole
from . import namespace


@namespace.route("/ls/")
class ListModel(Resource):
    """Define the API endpoint: /model/ls/"""

    @authenticate(UserRole.ADMIN)
    def get(self):
        """
        List all trained models with their associated feature files
        """

        models = []

        # list control group directories
        cg_dirs = cache.list_dir(MODELS_DIR)

        for cg_dir in cg_dirs:

            if not cg_dir.is_dir():
                continue

            try:
                files = cache.list_dir(cg_dir)
            except Exception:
                continue

            for file in files:

                if file.name.endswith("_model.pkl"):

                    feature_file = file.name.replace("_model.pkl", "_features.json")
                    feature_path = cg_dir / feature_file

                    models.append({
                        "control_group": cg_dir.name,
                        "model_file": str(file.relative_to(MODELS_DIR)),
                        "features_file": str(feature_path.relative_to(MODELS_DIR)),
                    })

        return models, HTTPStatus.OK
