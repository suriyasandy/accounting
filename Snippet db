predictions: List[PredictorModelOutput] = []

for model in self.models:

    try:
        prediction = model.inference_single(b_exc)

        # Skip empty predictions
        if prediction is None:
            continue

        if prediction.value == SimpleEncoder.MISSING:
            continue

        # Attach exception id for DB
        prediction.exception_id = b_exc.exception_id

        predictions.append(prediction)

    except Exception as e:
        logger.error(
            f"Prediction failed for exception {b_exc.exception_id}: {e}"
        )
