from http import HTTPStatus
from flask_restx import Resource
from lentil.cache import MODELS_DIR
from lentil.auth.authenticator import authenticate
from lentil.auth.user import UserRole
from . import namespace
from pathlib import Path


@namespace.route("/ls/")
class ListModel(Resource):
    """List all trained models"""

    @authenticate(UserRole.ADMIN)
    def get(self):

        models = []

        # iterate control group folders
        for cg_dir in MODELS_DIR.iterdir():

            if not cg_dir.is_dir():
                continue

            for f in cg_dir.iterdir():

                if f.name.endswith("_model.pkl"):

                    feature_file = f.name.replace("_model.pkl", "_features.json")

                    models.append({
                        "control_group": cg_dir.name,
                        "model_file": f"{cg_dir.name}/{f.name}",
                        "features_file": f"{cg_dir.name}/{feature_file}"
                    })

        return models, HTTPStatus.OK
