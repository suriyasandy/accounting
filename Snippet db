@authenticate(UserRole.ADMIN)
def get(self):
    """Handle GET request to this endpoint."""

    models = []

    # first level (control groups)
    control_groups = cache.list_dir(MODELS_DIR)

    for cg in control_groups:

        # list files inside control group folder
        files = cache.list_dir(cg)

        for f in files:

            if f.name.endswith("_model.pkl"):

                feature_file = f.name.replace("_model.pkl", "_features.json")

                models.append({
                    "model": str(f),
                    "features": str(f.parent / feature_file)
                })

    return models, HTTPStatus.OK
