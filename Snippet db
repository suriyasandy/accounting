@staticmethod
def load_from_pkl(path):

    path = Path(path)

    # Remove "models" prefix if present
    if path.parts and path.parts[0] == "models":
        path = Path(*path.parts[1:])

    # Correct full path
    full_path = MODELS_DIR.joinpath(path)

    if not full_path.exists():
        raise FileNotFoundError(f"Model not found: {full_path}")

    # Load model
    model = joblib.load(full_path)

    # Build feature file path
    features_path = full_path.with_name(
        full_path.name.replace("_model.pkl", "_features.json")
    )

    if not features_path.exists():
        raise FileNotFoundError(f"Features file not found: {features_path}")

    import json
    with open(features_path) as f:
        feature_keys = json.load(f)

    model.feature_keys = feature_keys

    return model
