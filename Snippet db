def inference_single(self, b_exc: BusinessException) -> PredictorModelOutput:

    encoded = self.encode(b_exc)

    # Prediction probabilities
    prediction_probs = self._classifier.predict_proba(encoded)

    # Feature importance
    importances = self._classifier.get_feature_importance()

    best_class_i = np.argmax(prediction_probs)

    confidence = float(prediction_probs[best_class_i])

    predicted_value = self._encoder.decode(
        self._classifier.classes_[best_class_i]
    )

    # Build feature importance list
    features = []

    for i, key in enumerate(self._feature_keys):

        features.append(
            FeatureImportance(
                key=key,
                value=b_exc.get(key),
                importance=float(importances[i])
            )
        )

    # ----------------------------------------------------
    # ROOT CAUSE FROM FEATURE CONTRIBUTION
    # ----------------------------------------------------

    root_cause = None

    try:

        contrib = self._classifier.get_feature_importance(
            encoded,
            type="PredictionValuesChange"
        )

        contrib = np.array(contrib)

        idx = int(np.argmax(contrib))

        root_cause = self._feature_keys[idx]

    except Exception as e:

        logging.warning(f"Root cause calculation failed: {e}")

    return PredictorModelOutput(
        control_group=self.control_group,
        key=self._predict_key,
        value=predicted_value,
        confidence=confidence,
        timestamp=datetime.now(),
        features=features,
        root_cause=root_cause
    )
