from http import HTTPStatus
from flask_restx import Resource

from lentil.cache import MODELS_DIR, cache
from lentil.auth.authenticator import authenticate
from lentil.auth.user import UserRole

from . import namespace


@namespace.route("/ls")
class ListModel(Resource):
    """List all available trained models and their feature files"""

    @authenticate(UserRole.ADMIN)
    def get(self):
        models = []

        # iterate control-group folders
        for cg_dir in cache.list_dir(MODELS_DIR):

            if not cg_dir.is_dir():
                continue

            # list files inside control-group folder
            for file in cache.list_dir(cg_dir):

                if file.name.endswith("_model.pkl"):

                    feature_file = file.name.replace("_model.pkl", "_features.json")
                    feature_path = cg_dir / feature_file

                    models.append({
                        "model": str(file.relative_to(MODELS_DIR)),
                        "features": str(feature_path.relative_to(MODELS_DIR))
                    })

        return models, HTTPStatus.OK
