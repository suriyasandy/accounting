def load_from_pkl(path):

    model = joblib.load(path)

    control_group = path.stem.replace("_model", "")

    features_path = path.parent / f"{control_group}_features.json"

    with open(features_path) as f:
        feature_keys = json.load(f)

    model.feature_keys = feature_keys

    return model
