@authenticate(UserRole.ADMIN)
def get(self):
    """Handle GET request to this endpoint."""

    models = []

    for cg_dir in MODELS_DIR.iterdir():

        if not cg_dir.is_dir():
            continue

        for f in cg_dir.iterdir():

            if f.name.endswith("_model.pkl"):

                feature_file = f.name.replace("_model.pkl", "_features.json")

                models.append({
                    "model": f"{cg_dir.name}/{f.name}",
                    "features": f"{cg_dir.name}/{feature_file}"
                })

    return models, HTTPStatus.OK
