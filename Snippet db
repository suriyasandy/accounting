from http import HTTPStatus
from pathlib import Path

from flask import request
from flask_restx import Resource, fields

from lentil.cache import MODELS_DIR, cache
from lentil.auth.authenticator import authenticate
from lentil.auth.user import UserRole
from lentil.task.tasks.live_inference import LiveInferenceTask
from lentil.task.async_task_handler import async_task_handler

from . import namespace


trained_models_model = namespace.model(
    "TrainedModels",
    {
        "models": fields.List(
            fields.String(
                description="Relative model path from models directory"
            ),
            required=True,
            example=["OMRC/OMRC_2026-03-11_model.pkl"],
        )
    },
)


@namespace.route("/start")
class Start(Resource):
    """Start live inference using selected models"""

    @namespace.expect(trained_models_model)
    @authenticate(UserRole.ADMIN)
    def post(self):

        request_as_json = request.json

        if request_as_json is None:
            return HTTPStatus.BAD_REQUEST.description, HTTPStatus.BAD_REQUEST

        params = dict(request_as_json)

        try:
            model_paths = params["models"]

            # build full paths
            model_path_valid = [MODELS_DIR / Path(mp) for mp in model_paths]

            # validate model exists
            assert all(cache.path_exists(mpv) for mpv in model_path_valid)

        except (ValueError, KeyError, TypeError):
            return HTTPStatus.BAD_REQUEST.description, HTTPStatus.BAD_REQUEST

        except AssertionError:
            return HTTPStatus.NOT_FOUND.description, HTTPStatus.NOT_FOUND

        task = LiveInferenceTask(model_paths=model_paths)

        async_task_handler.start_task(task)

        return task.json_description(), HTTPStatus.ACCEPTED



from http import HTTPStatus
from pathlib import Path

from flask_restx import Resource

from lentil.cache import MODELS_DIR, cache
from lentil.auth.authenticator import authenticate
from lentil.auth.user import UserRole

from . import namespace


@namespace.route("/ls/")
class ListModel(Resource):
    """List all available trained models"""

    @authenticate(UserRole.ADMIN)
    def get(self):

        models = []

        # list control group folders
        control_groups = cache.list_dir(Path("models"))

        for cg in control_groups:

            # list files inside each control group
            files = cache.list_dir(cg)

            for f in files:

                if f.name.endswith("_model.pkl"):

                    feature_file = f.name.replace("_model.pkl", "_features.json")

                    models.append({
                        "model": str(f.relative_to(Path("models"))).replace("\\", "/"),
                        "features": str((f.parent / feature_file).relative_to(Path("models"))).replace("\\", "/"),
                    })

        return models, HTTPStatus.OK
