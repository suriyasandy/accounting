predictions: List[PredictorModelOutput] = []

for model in self.models:

    try:

        logger.info(f"Model features keys: {model.feature_keys}")

        filtered_features = {}

        for key in model.feature_keys:

            value = b_exc.get(key, None)

            if value in [None, "", "NULL", "null"]:
                value = SimpleEncoder.MISSING

            filtered_features[key] = value

        filtered_exception = BusinessException(filtered_features)

        prediction = model.inference_single(filtered_exception)

        logger.info(f"Raw Predictions for {b_exc.exception_id}: {prediction}")

        if prediction is None:
            continue

        if prediction.value == SimpleEncoder.MISSING:
            continue

        prediction.exception_id = b_exc.exception_id

        predictions.append(prediction)

    except Exception as e:

        logger.error(
            f"Prediction failed for exception {b_exc.exception_id}: {e}"
        )
