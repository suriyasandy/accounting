def get_predictions_by_exception_id(
        self,
        exception_id: str,
):

    cursor = self.conn.cursor()

    row = cursor.execute(
        """
        SELECT *
        FROM predictions
        WHERE exceptionId = ?
        """,
        (exception_id,),
    ).fetchone()

    cursor.close()

    if row is None:
        return {}

    prediction_json = row["prediction"]

    if prediction_json:
        prediction = json.loads(prediction_json)
    else:
        prediction = []

    return {

        "exceptionId": row["exceptionId"],
        "exceptionTimestamp": row["exceptionTimestamp"],
        "responseCode": row["responseCode"],
        "responseDescription": row["responseDescription"],
        "controlGroup": row["controlGroup"],

        "prediction.timestamp": [
            p.get("timestamp") for p in prediction
        ],

        "prediction.key": [
            p.get("key") for p in prediction
        ],

        "prediction.value": [
            p.get("value") for p in prediction
        ],

        "prediction": prediction
    }
