    @staticmethod
    def remove_unusable_columns(columns: List[str]) -> List[str]:
        """
        Filters out columns that should not be used for ML training.
        These fields are populated only AFTER analysts start working
        on an exception and would leak future information.
        """

        columns_set = set(columns)

        columns_set -= {
            "assignedQueue",
            "assignedUser",
            "closedMode",
            "lastExecutiveSummary",
            "omrctradeComment",
            "priority",
            "processAdditionalInformation",
            "processInstanceId",
            "processParticipants",
            "reasonCodeId",
            "updatedBy",
            "updatedDate",
            "version",
            "workflowAction",
            "workflowStatus",
        }

        return list(columns_set)
