import csv
from typing import Iterator

from lentil.model.business_exception import be_from_dict
from lentil.model.business_exception import BusinessException


class LocalExceptionLoader:

    def __init__(self, filepath: str):
        self.filepath = filepath

    def load(self) -> Iterator[BusinessException]:

        with open(self.filepath, "r", encoding="utf-8") as f:

            reader = csv.DictReader(f)

            for row in reader:

                # convert CSV row -> BusinessException
                b_exc = be_from_dict(row)

                yield b_exc
