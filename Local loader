import csv
from typing import Iterator

from lentil.interfaces import BusinessException
from lentil.interfaces import BusinessExceptionHeader


class LocalExceptionLoader:

    def __init__(self, filepath: str):
        self.filepath = filepath

    def load(self) -> Iterator[BusinessException]:

        with open(self.filepath, "r", encoding="utf-8") as f:

            reader = csv.DictReader(f)

            for row in reader:

                # Build header
                header = BusinessExceptionHeader(
                    exception_id=row.get("exceptionId"),
                    control_group=row.get("controlGroup", "OMRC")
                )

                # Create BusinessException properly
                b_exc = BusinessException(
                    header=header,
                    attributes=row
                )

                yield b_exc
