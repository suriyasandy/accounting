            age_trend.columns = ["Period", "Mean Age Days", "Median Age Days", "Break Count"]
            fig = go.Figure()
            fig.add_trace(go.Bar(
                x=age_trend["Period"], y=age_trend["Mean Age Days"],
                name="Mean Age Days", marker_color=COLORS[0], opacity=0.8,
