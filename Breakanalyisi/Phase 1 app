                            aspect="auto", text_auto=".0f")
            fig = chart_layout(fig,"Heatmap: Avg Age Days by Team × Period","","",height=350)
            st.plotly_chart(fig, use_container_width=True)

    ct5, ct6 = st.columns(2)
    with ct5:
        risk = dq("""
            SELECT _Period_label AS period, COUNT(*) AS total,
                   COUNT(*) FILTER (WHERE _Computed_Age_Days>90)  AS over90,
                   COUNT(*) FILTER (WHERE _Computed_Age_Days>365) AS over365
            FROM tbl WHERE _Computed_Age_Days IS NOT NULL
            GROUP BY _Period_label ORDER BY _Period_label
        """, df)
