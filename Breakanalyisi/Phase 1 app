        fig = add_rolling_avg(fig, p90["period"], p90["p90"],
                              name="P90 Rolling Avg", color=COLORS[7])
        fig = chart_layout(fig,"90th Percentile Age Days Trend","Period","Days")
        st.plotly_chart(fig, use_container_width=True)

    with ct4:
        if team_col and team_col in df.columns:
            heat = dq(f"""
                SELECT "{team_col}" AS team, _Period_label AS period,
