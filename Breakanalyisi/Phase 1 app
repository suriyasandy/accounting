# ─────────────────────────── Tab 5: Jira Factor Analysis ───────────────────────────

def tab_jira_factor_analysis(df: pd.DataFrame, col_map: dict):
    """
    Factor Analysis using Jira Reference, Jira Desc, System to be Fixed.
    Replaces Root Cause identified — these columns directly indicate which
    system/Jira ticket is driving the breaks.
    """
    st.markdown("## Jira Factor Analysis")
    st.markdown(
        '<div class="jira-banner">🔍 <b>Factor Analysis:</b> Identify which Jira tickets, '
        'descriptions, and systems are driving the highest break volumes, worst ageing, '
        'and largest amounts. Use the dimension selector below to switch between factors.</div>',
        unsafe_allow_html=True)

    # ── Resolve Jira columns via fuzzy col map ──
    jira_ref_col = col_map.get("Jira Reference")
    jira_desc_col = col_map.get("Jira Desc")
    system_col   = col_map.get("System to be Fixed")
    abs_col      = col_map.get("ABS GBP") or col_map.get("BREAK AMOUNT GBP")
    team_col     = col_map.get("Team")
    rec_col      = col_map.get("Rec Name (as per Rec Cube)")
    period_col   = col_map.get("Period")

    # Build available factor options — only show if column exists in df
    factor_options = {}
    if jira_ref_col  and jira_ref_col  in df.columns: factor_options["Jira Reference"]     = jira_ref_col
    if jira_desc_col and jira_desc_col in df.columns: factor_options["Jira Description"]   = jira_desc_col
    if system_col    and system_col    in df.columns: factor_options["System to be Fixed"] = system_col

    # Also expose the standard driver dimensions alongside Jira columns
    extra_dims = {k: v for k, v in {
        "Team":          team_col,
        "Rec Name":      rec_col,
        "Asset Class":   col_map.get("Asset Class"),
        "Entity":        col_map.get("Entity"),
        "True/Systemic": col_map.get("True/Systemic Breaks"),
    }.items() if v and v in df.columns}

    all_dims = {**factor_options, **extra_dims}

    if not all_dims:
        st.info("No Jira or dimension columns found. Check column names include "
                "'Jira Reference', 'Jira Desc', 'System to be Fixed'.")
        return

    # ── Jira Coverage KPIs ──
    jira_kpis = {}
    for label, col in factor_options.items():
        filled = dq(f"""
            SELECT COUNT(*) AS filled, COUNT(*) FILTER (WHERE "{col}" IS NOT NULL
              AND TRIM(CAST("{col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')) AS populated
            FROM tbl
        """, df).iloc[0]
        jira_kpis[label] = {
            "populated": int(filled["populated"]),
            "total":     int(filled["filled"]),
            "pct":       round(int(filled["populated"]) / max(int(filled["filled"]),1) * 100, 1),
        }

    if jira_kpis:
        st.markdown("### Jira Column Coverage")
        cols = st.columns(len(jira_kpis))
        for i, (label, kdata) in enumerate(jira_kpis.items()):
            with cols[i]:
                kpi_card(f"{label} Coverage",
                         f"{kdata['pct']}%",
                         f"{format_number(kdata['populated'])} / {format_number(kdata['total'])} rows",
                         warn=(kdata["pct"] < 50))

    st.markdown("---")
    selected_label = st.selectbox(
        "Select Factor Dimension",
        list(all_dims.keys()), key="jira_dim_sel",
    )
    dim_col = all_dims[selected_label]

    period_order = sorted(df["_Period_label"].dropna().unique().tolist()) \
                   if "_Period_label" in df.columns else []
    latest = period_order[-1] if period_order else "0"
    prev   = period_order[-2] if len(period_order) >= 2 else "0"

    # ── Driver Summary Table — DuckDB aggregation ──
    st.markdown(f"### {selected_label} — Factor Summary Table")

    age_clause    = 'AVG(_Computed_Age_Days) AS avg_age_days, MAX(_Computed_Age_Days) AS max_age_days,' \
                    if "_Computed_Age_Days" in df.columns else ""
    amount_clause = f'SUM(ABS("{abs_col}")) AS total_abs_gbp,' if abs_col and abs_col in df.columns else ""
    over90_clause = 'COUNT(*) FILTER (WHERE _Computed_Age_Days > 90)  AS count_over_90d,' \
                    if "_Computed_Age_Days" in df.columns else ""
    over365_clause= 'COUNT(*) FILTER (WHERE _Computed_Age_Days > 365) AS count_over_365d' \
                    if "_Computed_Age_Days" in df.columns else "0 AS count_over_365d"

    summary_df = dq(f"""
        SELECT "{dim_col}" AS factor,
               COUNT(*) AS break_count,
               {age_clause}
               {amount_clause}
               {over90_clause}
               {over365_clause}
        FROM tbl
        WHERE "{dim_col}" IS NOT NULL
          AND TRIM(CAST("{dim_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
        GROUP BY "{dim_col}"
        ORDER BY break_count DESC
    """, df)

    summary_df = summary_df.rename(columns={
        "factor":         selected_label,
        "break_count":    "Break Count",
        "avg_age_days":   "Avg Age Days",
        "max_age_days":   "Max Age Days",
        "total_abs_gbp":  "Total ABS GBP",
        "count_over_90d": "Count > 90 Days",
        "count_over_365d":"Count > 365 Days",
    })
    if "Total ABS GBP" in summary_df.columns:
        summary_df["Total ABS GBP"] = summary_df["Total ABS GBP"].apply(format_short)
    if "Avg Age Days" in summary_df.columns:
        summary_df["Avg Age Days"] = summary_df["Avg Age Days"].round(1)

    render_aggrid(summary_df, height=380, key="jira_summary_grid")

    st.markdown("---")
    row1a, row1b = st.columns(2)

    # ── Top 10 by Break Count ──
    with row1a:
        top_cnt = dq(f"""
            SELECT "{dim_col}" AS factor, COUNT(*) AS cnt
            FROM tbl
            WHERE "{dim_col}" IS NOT NULL
              AND TRIM(CAST("{dim_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
            GROUP BY "{dim_col}" ORDER BY cnt DESC LIMIT 10
        """, df).sort_values("cnt", ascending=True)
        fig = px.bar(top_cnt, x="cnt", y="factor", orientation="h",
                     color_discrete_sequence=[PRIMARY])
        fig = chart_layout(fig, f"Top 10 {selected_label} by Break Count",
                           "Break Count", "", height=max(320, len(top_cnt)*32))
        st.plotly_chart(fig, use_container_width=True)

    # ── Top 10 by Avg Age Days ──
    with row1b:
        if "_Computed_Age_Days" in df.columns:
            top_age = dq(f"""
                SELECT "{dim_col}" AS factor, AVG(_Computed_Age_Days) AS avg_age
                FROM tbl
                WHERE "{dim_col}" IS NOT NULL
                  AND TRIM(CAST("{dim_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
                  AND _Computed_Age_Days IS NOT NULL
                GROUP BY "{dim_col}" ORDER BY avg_age DESC LIMIT 10
            """, df).sort_values("avg_age", ascending=True)
            fig = px.bar(top_age, x="avg_age", y="factor", orientation="h",
                         color_discrete_sequence=[COLORS[4]])
            fig = chart_layout(fig, f"Top 10 {selected_label} by Avg Age Days",
                               "Avg Age Days", "", height=max(320, len(top_age)*32))
            st.plotly_chart(fig, use_container_width=True)

    # ── Top 10 by ABS GBP ──
    if abs_col and abs_col in df.columns:
        row2a, row2b = st.columns(2)
        with row2a:
            top_amt = dq(f"""
                SELECT "{dim_col}" AS factor, SUM(ABS("{abs_col}")) AS total
                FROM tbl
                WHERE "{dim_col}" IS NOT NULL
                  AND TRIM(CAST("{dim_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
                GROUP BY "{dim_col}" ORDER BY total DESC LIMIT 10
            """, df).sort_values("total", ascending=True)
            top_amt["label"] = top_amt["total"].apply(format_short)
            fig = px.bar(top_amt, x="total", y="factor", orientation="h",
                         color_discrete_sequence=[COLORS[2]])
            fig.update_traces(text=top_amt["label"], textposition="outside")
            fig = chart_layout(fig, f"Top 10 {selected_label} by ABS GBP",
                               "GBP (£)", "", height=max(320, len(top_amt)*32))
            st.plotly_chart(fig, use_container_width=True)

        # ── High-risk (>90 days) share by factor ──
        with row2b:
            if "_Computed_Age_Days" in df.columns:
                risk_df = dq(f"""
                    SELECT "{dim_col}" AS factor,
                           COUNT(*) AS total,
                           COUNT(*) FILTER (WHERE _Computed_Age_Days > 90) AS over90
                    FROM tbl
                    WHERE "{dim_col}" IS NOT NULL
                      AND TRIM(CAST("{dim_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
                      AND _Computed_Age_Days IS NOT NULL
                    GROUP BY "{dim_col}" ORDER BY over90 DESC LIMIT 10
                """, df)
                risk_df[">90 Day %"] = (risk_df["over90"] / risk_df["total"] * 100).round(1)
                risk_df = risk_df.sort_values(">90 Day %", ascending=True)
                fig = px.bar(risk_df, x=">90 Day %", y="factor", orientation="h",
                             color_discrete_sequence=[WARN])
                fig = chart_layout(fig, f"Top 10 {selected_label} — % Breaks > 90 Days",
                                   "% of Breaks > 90 Days", "",
                                   height=max(320, len(risk_df)*32))
                st.plotly_chart(fig, use_container_width=True)

    # ── Period Trend for Top 5 values of selected dimension ──
    if "_Period_label" in df.columns and period_order:
        st.markdown(f"### {selected_label} — Break Count Trend Over Periods (Top 5)")
        top5 = dq(f"""
            SELECT "{dim_col}" AS factor FROM tbl
            WHERE "{dim_col}" IS NOT NULL
              AND TRIM(CAST("{dim_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
            GROUP BY "{dim_col}" ORDER BY COUNT(*) DESC LIMIT 5
        """, df)["factor"].tolist()
        top5_str = ", ".join(f"'{str(v).replace(chr(39), chr(39)*2)}'" for v in top5)
        trend_df = dq(f"""
            SELECT "{dim_col}" AS factor, _Period_label AS period, COUNT(*) AS cnt
            FROM tbl WHERE "{dim_col}" IN ({top5_str})
            GROUP BY "{dim_col}", _Period_label ORDER BY _Period_label
        """, df)
        fig = px.line(trend_df, x="period", y="cnt", color="factor",
                      color_discrete_sequence=COLORS, markers=True)
        fig = chart_layout(fig, f"Top 5 {selected_label} — Break Count Trend","Period","Count")
        st.plotly_chart(fig, use_container_width=True)

    # ── MoM Change by Factor — which is driving increase/decrease? ──
    if len(period_order) >= 2:
        st.markdown(f"### MoM Change by {selected_label}  ({prev} → {latest})")
        mom_df = dq(f"""
            SELECT "{dim_col}" AS factor,
                   COUNT(*) FILTER (WHERE _Period_label='{latest}') AS lat,
                   COUNT(*) FILTER (WHERE _Period_label='{prev}')   AS prv
            FROM tbl
            WHERE "{dim_col}" IS NOT NULL
              AND TRIM(CAST("{dim_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
            GROUP BY "{dim_col}"
        """, df)
        mom_df["MoM Δ"]   = mom_df["lat"] - mom_df["prv"]
        mom_df["MoM Δ %"] = ((mom_df["lat"] - mom_df["prv"]) /
                              mom_df["prv"].replace(0, np.nan) * 100).round(1)
        mom_df = mom_df.sort_values("MoM Δ")
        colors_mom = [COLORS[0] if v >= 0 else COLORS[4] for v in mom_df["MoM Δ"]]
        fig = go.Figure(go.Bar(
            x=mom_df["MoM Δ"], y=mom_df["factor"], orientation="h",
            marker_color=colors_mom,
            text=mom_df["MoM Δ"].apply(lambda x: f"+{x}" if x >= 0 else str(x)),
            textposition="outside",
        ))
        fig.add_vline(x=0, line_dash="dash", line_color=MUTED, line_width=1)
        fig = chart_layout(fig,
            f"MoM Break Count Change by {selected_label}",
            "Change in Break Count","",
            height=max(380, len(mom_df)*28))
        st.plotly_chart(fig, use_container_width=True)
        st.caption("🟩 Teal = Increase in breaks  🟥 Red = Decrease in breaks (improvement)")

    # ── Cross-factor: Jira Reference × System to be Fixed heatmap ──
    if (jira_ref_col and jira_ref_col in df.columns and
            system_col  and system_col  in df.columns and
            selected_label in ("Jira Reference","System to be Fixed")):
        st.markdown("### Jira Reference × System to be Fixed — Break Count Heatmap")
        cross = dq(f"""
            SELECT "{jira_ref_col}" AS jira_ref,
                   "{system_col}"   AS system_fix,
                   COUNT(*) AS cnt
            FROM tbl
            WHERE "{jira_ref_col}" IS NOT NULL AND "{system_col}" IS NOT NULL
              AND TRIM(CAST("{jira_ref_col}" AS VARCHAR)) NOT IN ('','nan','None','N/A')
              AND TRIM(CAST("{system_col}"   AS VARCHAR)) NOT IN ('','nan','None','N/A')
            GROUP BY "{jira_ref_col}", "{system_col}"
            ORDER BY cnt DESC
            LIMIT 200
        """, df)
        if len(cross) > 0:
            pivot = cross.pivot_table(index="jira_ref", columns="system_fix",
                                      values="cnt", fill_value=0)
            # Limit heatmap to top 20 jira refs for readability
            top20 = cross.groupby("jira_ref")["cnt"].sum().nlargest(20).index
            pivot = pivot.loc[pivot.index.isin(top20)]
            fig = px.imshow(pivot, color_continuous_scale=["#E8F5E9","#FFC553","#A84B2F"],
                            aspect="auto", text_auto=".0f")
            fig = chart_layout(fig,"Jira Reference × System to be Fixed (Break Count)",
                               "","", height=max(350, len(pivot)*28))
            st.plotly_chart(fig, use_container_width=True)

    # ── Download factor summary ──
    st.download_button(
        f"📥 Download {selected_label} Factor Summary (CSV)",
        summary_df.to_csv(index=False).encode("utf-8"),
        file_name=f"factor_analysis_{selected_label.replace(' ','_').lower()}.csv",
        mime="text/csv",
    )


# ─────────────────────────── Main ───────────────────────────

def main():
    st.sidebar.title("📊 Accounting Control AI")
    st.sidebar.markdown("*Phase 1 — DuckDB + Jira Factor Analysis*")
    st.sidebar.markdown("---")

    uploaded = st.sidebar.file_uploader(
        "Upload Data (CSV / Excel / Parquet)",
        type=["csv","xlsx","xls","parquet"],
        key="uploader",
    )

    if uploaded is None:
        st.markdown("## 👋 Welcome to Accounting Control AI Platform")
        st.info("Upload your **MI Report** (CSV, Excel, or Parquet) to begin.")
        st.markdown("""
        | Format | First Load | Reruns |
        |---|---|---|
        | `.parquet` | ⚡ ~0.2s | ⚡ Instant (cached) |
        | `.csv`     | 🟢 ~1–2s  | ⚡ Instant (cached) |
        | `.xlsx`    | 🟡 ~4–6s  | ⚡ Instant (cached) |

        **Tabs available:**
        - 🧹 Data Quality — completeness, violations, outliers
        - 📅 Ageing Validation — age days & bucket discrepancy check
        - 📈 Break Counts — period trend analysis
        - 💷 Amount Analysis — ABS GBP trend analysis
        - 🔍 Jira Factor Analysis — Jira Ref / Jira Desc / System to be Fixed driver analysis
        """)
        return

    file_bytes = uploaded.read()
    fname      = uploaded.name

    df, col_map, filter_options, violations_df, dropped_cols = clean_dataframe(file_bytes, fname)

    vcount = int(violations_df["Violation Count"].sum()) if len(violations_df) else 0
    st.sidebar.markdown(f"""
    **File:** `{fname}`
    **Rows:** {len(df):,} &nbsp;|&nbsp; **Cols:** {len(df.columns)}
    """)
    if dropped_cols:
        st.sidebar.markdown(
            f'<span style="color:{MUTED};font-size:0.8rem">🗑️ {len(dropped_cols)} blank col(s) removed</span>',
            unsafe_allow_html=True)
    if vcount > 0:
        st.sidebar.markdown(
            f'<span style="color:{WARN};font-weight:600">⚠️ {vcount} type violations</span>',
            unsafe_allow_html=True)

    df_filtered = apply_global_filters(df, col_map, filter_options)
    st.sidebar.markdown(f"**Filtered Rows:** {len(df_filtered):,}")

    tab1, tab2, tab3, tab4, tab5 = st.tabs([
        "🧹 Data Quality",
        "📅 Ageing Validation",
        "📈 Break Counts",
        "💷 Amount Analysis",
        "🔍 Jira Factor Analysis",
    ])
    with tab1: tab_data_quality(df_filtered, col_map, violations_df, file_bytes, fname, dropped_cols)
    with tab2: tab_ageing_validation(df_filtered, col_map)
    with tab3: tab_break_counts(df_filtered, col_map)
    with tab4: tab_amount_analysis(df_filtered, col_map)
    with tab5: tab_jira_factor_analysis(df_filtered, col_map)


if __name__ == "__main__":
    main()
