    else:
        st.success("No discrepancies found!")

    st.markdown("---")

    # Charts
    col_left, col_right = st.columns(2)

    with col_left:
        st.markdown("### Age Days Distribution: Computed vs Pre-populated")
        hist_data = valid_rows[[age_col, "_Computed_Age_Days"]].dropna()
        if len(hist_data) > 0:
            fig = go.Figure()
            fig.add_trace(go.Histogram(x=hist_data[age_col], name="Pre-populated", opacity=0.6,
                                       marker_color=COLORS[0], nbinsx=50))
            fig.add_trace(go.Histogram(x=hist_data["_Computed_Age_Days"], name="Computed", opacity=0.6,
                                       marker_color=COLORS[4], nbinsx=50))
            fig.update_layout(barmode="overlay")
            fig = chart_layout(fig, "Age Days Distribution: Computed vs Pre-populated", "Age Days", "Count")
            st.plotly_chart(fig, use_container_width=True)

    with col_right:
        st.markdown("### Bucket Distribution Comparison")
        bucket_comp = pd.DataFrame({
            "Pre-populated": valid_rows[bucket_col].value_counts(),
            "Computed": valid_rows["_Computed_Bucket"].value_counts(),
        }).reindex(BUCKET_ORDER).fillna(0).reset_index()
        bucket_comp.columns = ["Bucket", "Pre-populated", "Computed"]
        fig = go.Figure()
        fig.add_trace(go.Bar(x=bucket_comp["Bucket"], y=bucket_comp["Pre-populated"],
                             name="Pre-populated", marker_color=COLORS[0]))
        fig.add_trace(go.Bar(x=bucket_comp["Bucket"], y=bucket_comp["Computed"],
                             name="Computed", marker_color=COLORS[4]))
        fig.update_layout(barmode="group")
        fig = chart_layout(fig, "Bucket Distribution: Computed vs Pre-populated", "Bucket", "Count")
        st.plotly_chart(fig, use_container_width=True)

    # Discrepancy rate by Team — VECTORISED (no groupby.apply lambda)
    if team_col and team_col in valid_rows.columns:
        st.markdown("### Discrepancy Rate by Team")
        team_total = valid_rows.groupby(team_col).size().rename("Total")
        team_age_mis = valid_rows[~valid_rows["_Age_Match"]].groupby(team_col).size().rename("Age Mismatch")
        team_bucket_mis = valid_rows[~valid_rows["_Bucket_Match"]].groupby(team_col).size().rename("Bucket Mismatch")
        team_disc = pd.concat([team_total, team_age_mis, team_bucket_mis], axis=1).fillna(0).reset_index()
        team_disc["Age Disc %"] = (team_disc["Age Mismatch"] / team_disc["Total"] * 100).round(1)
        team_disc["Bucket Disc %"] = (team_disc["Bucket Mismatch"] / team_disc["Total"] * 100).round(1)
        fig = go.Figure()
        fig.add_trace(go.Bar(x=team_disc[team_col], y=team_disc["Age Disc %"],
                             name="Age Days Disc %", marker_color=COLORS[0]))
        fig.add_trace(go.Bar(x=team_disc[team_col], y=team_disc["Bucket Disc %"],
                             name="Bucket Disc %", marker_color=COLORS[4]))
        fig.update_layout(barmode="group")
        fig = chart_layout(fig, "Discrepancy Rate by Team (%)", "Team", "Discrepancy %")
        st.plotly_chart(fig, use_container_width=True)

    if rec_col and rec_col in valid_rows.columns:
        st.markdown("### Discrepancy Rate by Rec Name")
        rec_total = valid_rows.groupby(rec_col).size().rename("Total")
        rec_bucket_mis = valid_rows[~valid_rows["_Bucket_Match"]].groupby(rec_col).size().rename("Bucket Mismatch")
        rec_disc = pd.concat([rec_total, rec_bucket_mis], axis=1).fillna(0).reset_index()
        rec_disc["Disc %"] = (rec_disc["Bucket Mismatch"] / rec_disc["Total"] * 100).round(1)
        rec_disc = rec_disc.sort_values("Disc %", ascending=True)
        fig = px.bar(rec_disc, x="Disc %", y=rec_col, orientation="h", color_discrete_sequence=[COLORS[0]])
        fig = chart_layout(fig, "Bucket Discrepancy Rate by Rec Name (%)", "Discrepancy %", "", height=max(300, len(rec_disc) * 25))
        st.plotly_chart(fig, use_container_width=True)

    # ──── Trend Analysis Section ────
    st.markdown("---")
    st.markdown("## Trend Analysis: Break Ageing")

    if "_Period_label" in vdf.columns and period_col and period_col in vdf.columns:
        trend_df = vdf[vdf["_Computed_Age_Days"].notna()]
        period_labels = trend_df["_Period_label"]
