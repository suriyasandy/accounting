    # Discrepancy rate by Team/Rec Name
    if team_col and team_col in valid_rows.columns:
        st.markdown("### Discrepancy Rate by Team")
        team_disc = valid_rows.groupby(team_col).apply(
            lambda g: pd.Series({
                "Total": len(g),
                "Age Mismatch": int((~g["_Age_Match"]).sum()),
                "Bucket Mismatch": int((~g["_Bucket_Match"]).sum()),
            })
        ).reset_index()
        team_disc["Age Disc %"] = (team_disc["Age Mismatch"] / team_disc["Total"] * 100).round(1)
        team_disc["Bucket Disc %"] = (team_disc["Bucket Mismatch"] / team_disc["Total"] * 100).round(1)
        fig = go.Figure()
        fig.add_trace(go.Bar(x=team_disc[team_col], y=team_disc["Age Disc %"],
                             name="Age Days Disc %", marker_color=COLORS[0]))
        fig.add_trace(go.Bar(x=team_disc[team_col], y=team_disc["Bucket Disc %"],
                             name="Bucket Disc %", marker_color=COLORS[4]))
        fig.update_layout(barmode="group")
        fig = chart_layout(fig, "Discrepancy Rate by Team (%)", "Team", "Discrepancy %")
        st.plotly_chart(fig, use_container_width=True)

    if rec_col and rec_col in valid_rows.columns:
        st.markdown("### Discrepancy Rate by Rec Name")
        rec_disc = valid_rows.groupby(rec_col).apply(
            lambda g: pd.Series({
                "Total": len(g),
                "Bucket Mismatch": int((~g["_Bucket_Match"]).sum()),
            })
        ).reset_index()
        rec_disc["Disc %"] = (rec_disc["Bucket Mismatch"] / rec_disc["Total"] * 100).round(1)
        rec_disc = rec_disc.sort_values("Disc %", ascending=True)
        fig = px.bar(rec_disc, x="Disc %", y=rec_col, orientation="h", color_discrete_sequence=[COLORS[0]])
        fig = chart_layout(fig, "Bucket Discrepancy Rate by Rec Name (%)", "Discrepancy %", "", height=max(300, len(rec_disc) * 25))
        st.plotly_chart(fig, use_container_width=True)

    # ──── Trend Analysis Section ────
    st.markdown("---")
    st.markdown("## Trend Analysis: Break Ageing")

    if "_Period_label" in vdf.columns and period_col and period_col in vdf.columns:
        # Prepare period-level ageing aggregation
        trend_df = vdf[vdf["_Computed_Age_Days"].notna()].copy()
        trend_df["_Period_label"] = trend_df["_Period_date"].dt.strftime("%Y-%m").fillna(trend_df[period_col].astype(str))
        period_order = sorted(trend_df["_Period_label"].unique())

        col_t1, col_t2 = st.columns(2)

        # Chart T1: Average Age Days Trend by Period
        with col_t1:
            age_trend = trend_df.groupby("_Period_label")["_Computed_Age_Days"].agg(
                ["mean", "median", "count"]
