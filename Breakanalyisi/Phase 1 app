            fig = chart_layout(fig, "Average Age Days Trend by Period", "Period", "Days")
            st.plotly_chart(fig, use_container_width=True)

        # Chart T2: Bucket Distribution Over Time (stacked bar)
        with col_t2:
            bucket_period = trend_df.groupby(["_Period_label", "_Computed_Bucket"], observed=False).size().reset_index(name="Count")
            bucket_period["_Computed_Bucket"] = pd.Categorical(
                bucket_period["_Computed_Bucket"], categories=BUCKET_ORDER, ordered=True
            )
            bucket_period = bucket_period.sort_values("_Computed_Bucket")
            fig = px.bar(
                bucket_period, x="_Period_label", y="Count",
                color="_Computed_Bucket", color_discrete_sequence=COLORS,
