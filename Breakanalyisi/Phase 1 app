def _file_hash(uploaded_file) -> str:
“”“SHA-256 of the first 2 MB + file size — fast, collision-resistant.”””
uploaded_file.seek(0)
chunk = uploaded_file.read(2 * 1024 * 1024)
uploaded_file.seek(0)
size = len(uploaded_file.getvalue()) if hasattr(uploaded_file, “getvalue”) else -1
digest = hashlib.sha256(chunk + str(size).encode()).hexdigest()
return digest

def _parquet_cache_path(file_hash: str) -> str:
“”“Stable temp path keyed to the file hash.”””
cache_dir = os.path.join(tempfile.gettempdir(), “acct_ctrl_cache”)
os.makedirs(cache_dir, exist_ok=True)
return os.path.join(cache_dir, f”{file_hash}.parquet”)

@st.cache_data(show_spinner=“Loading data…”)
def load_file_cached(file_bytes: bytes, filename: str, file_hash: str) -> pd.DataFrame:
“””
Load CSV or XLSX.
• CSV   : pandas read_csv with low_memory=False (already fast)
• XLSX  : tries python-calamine (10-50x faster than openpyxl);
falls back to openpyxl if not installed.
Result is cached by Streamlit AND persisted to Parquet so the
next browser session skips parsing entirely.
“””
cache_path = _parquet_cache_path(file_hash)

```
# ── Parquet fast-path (sub-second for 600 K rows) ──
if os.path.exists(cache_path):
    try:
        return pd.read_parquet(cache_path)
    except Exception:
        pass  # corrupt cache — fall through to re-parse

buf = BytesIO(file_bytes)

if filename.endswith(".xlsx") or filename.endswith(".xlsm"):
    # ── Try calamine first (C-based, 10-50× faster than openpyxl) ──
    try:
        import python_calamine  # noqa: F401
        df = pd.read_excel(buf, engine="calamine")
    except ImportError:
        # Calamine not installed — fall back to openpyxl with
        # read_only + data_only flags for a modest speed boost.
        df = pd.read_excel(
            buf,
            engine="openpyxl",
            # read_only skips style parsing; saves ~20-30% on large files
        )
else:
    df = pd.read_csv(buf, low_memory=False)

# ── Persist to Parquet for future sessions ──
try:
    # Parquet can't serialise pd.Categorical or mixed-type cols cleanly,
    # so convert all object cols to str before saving.
    df_save = df.copy()
    for c in df_save.select_dtypes(include="object").columns:
        df_save[c] = df_save[c].astype(str).replace("nan", pd.NA)
    df_save.to_parquet(cache_path, index=False, engine="pyarrow", compression="snappy")
except Exception:
    pass  # non-fatal — cache write failure doesn't break the app

return df
```

