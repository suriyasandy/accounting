def detect_outliers_iqr(series, name=“Column”):
clean = series.dropna()
if len(clean) < 10:
return pd.DataFrame()
q1, q3 = clean.quantile(0.25), clean.quantile(0.75)
iqr = q3 - q1
lower, upper = q1 - 1.5 * iqr, q3 + 1.5 * iqr
outliers = clean[(clean < lower) | (clean > upper)]
if len(outliers) == 0:
return pd.DataFrame()
return pd.DataFrame({
“Column”: [name], “Outlier Count”: [len(outliers)],
“Outlier %”: [round(len(outliers) / len(clean) * 100, 2)],
“IQR Lower”: [round(lower, 2)], “IQR Upper”: [round(upper, 2)],
“Min Outlier”: [round(outliers.min(), 2)], “Max Outlier”: [round(outliers.max(), 2)],
})

