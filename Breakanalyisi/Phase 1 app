def tab_break_counts(df, col_map):
    """Render Trend Analysis - Break Counts tab."""
    st.markdown("## Trend Analysis: Break Counts")

    period_col = col_map.get("Period")
    team_col = col_map.get("Team")
    rec_col = col_map.get("Rec Name (as per Rec Cube)")
    ac_col = col_map.get("Asset Class")
    ts_col = col_map.get("True/Systemic Breaks")
    bucket_col = col_map.get("Bucket")

    if not period_col or period_col not in df.columns:
        st.warning("Period column not found.")
        return

    # Period-level aggregation
    periods_sorted = sorted(df[period_col].dropna().unique())
    period_counts = df.groupby(period_col).size().reset_index(name="Break Count")
    period_counts = period_counts.sort_values(period_col)
    period_counts["Period Label"] = period_counts[period_col].apply(
        lambda x: period_to_datetime(x).strftime("%Y-%m") if pd.notna(period_to_datetime(x)) else str(x))

    total_breaks = len(df)
    latest_period = periods_sorted[-1] if periods_sorted else None
    prev_period = periods_sorted[-2] if len(periods_sorted) >= 2 else None

    latest_count = int(period_counts[period_counts[period_col] == latest_period]["Break Count"].sum()) if latest_period else 0
    prev_count = int(period_counts[period_counts[period_col] == prev_period]["Break Count"].sum()) if prev_period else 0
    mom_pct = safe_mom_pct(latest_count, prev_count)
    avg_per_period = round(total_breaks / len(periods_sorted), 0) if periods_sorted else 0
    unique_recs = df[rec_col].nunique() if rec_col and rec_col in df.columns else "N/A"

    # KPIs
    c1, c2, c3, c4 = st.columns(4)
    with c1:
        kpi_card("Total Breaks", format_number(total_breaks))
    with c2:
        delta_str = f"{'+' if mom_pct and mom_pct > 0 else ''}{mom_pct}% MoM" if mom_pct is not None else "N/A"
        kpi_card("MoM Change", f"{format_number(latest_count)}", delta_str, invert=True)
    with c3:
        kpi_card("Avg Breaks/Period", format_number(avg_per_period))
    with c4:
        kpi_card("Unique Recs with Breaks", str(unique_recs))

    st.markdown("---")

    # Chart 1: Total break count by Period (bar + line combo)
    col_a, col_b = st.columns(2)
    with col_a:
        fig = go.Figure()
        fig.add_trace(go.Bar(x=period_counts["Period Label"], y=period_counts["Break Count"],
                             name="Break Count", marker_color=COLORS[0], opacity=0.8))
        fig.add_trace(go.Scatter(x=period_counts["Period Label"], y=period_counts["Break Count"],
                                 name="Trend", line=dict(color=COLORS[4], width=2), mode="lines+markers"))
        fig = chart_layout(fig, "Break Count Trend by Period", "Period", "Count")
        st.plotly_chart(fig, use_container_width=True)

    # Chart 2: Break count by Team
    with col_b:
        if team_col and team_col in df.columns:
            team_period = df.groupby([team_col, "_Period_label"]).size().reset_index(name="Count")
            fig = px.bar(team_period, x="_Period_label", y="Count", color=team_col,
                         color_discrete_sequence=COLORS, barmode="group")
            fig = chart_layout(fig, "Break Count by Team Over Periods", "Period", "Count")
            st.plotly_chart(fig, use_container_width=True)

    col_c, col_d = st.columns(2)

    # Chart 3: Break count by Rec Name (top 10)
    with col_c:
        if rec_col and rec_col in df.columns:
            top_recs = df[rec_col].value_counts().head(10).index.tolist()
            rec_data = df[df[rec_col].isin(top_recs)]
            rec_period = rec_data.groupby([rec_col, "_Period_label"]).size().reset_index(name="Count")
            fig = px.line(rec_period, x="_Period_label", y="Count", color=rec_col,
                          color_discrete_sequence=COLORS, markers=True)
            fig = chart_layout(fig, "Break Count by Top 10 Rec Names Over Periods", "Period", "Count")
            st.plotly_chart(fig, use_container_width=True)

    # Chart 4: Asset Class
    with col_d:
        if ac_col and ac_col in df.columns:
            if latest_period:
                latest_ac = df[df[period_col] == latest_period].groupby(ac_col).size().reset_index(name="Count")
                fig = px.pie(latest_ac, values="Count", names=ac_col,
                             color_discrete_sequence=COLORS, hole=0.4)
                fig = chart_layout(fig, f"Break Count by Asset Class ({period_to_datetime(latest_period).strftime('%Y-%m')})", height=380)
                st.plotly_chart(fig, use_container_width=True)

    col_e, col_f = st.columns(2)

    # Chart 5: True vs Systemic
    with col_e:
        if ts_col and ts_col in df.columns:
            ts_period = df.groupby([ts_col, "_Period_label"]).size().reset_index(name="Count")
            fig = px.bar(ts_period, x="_Period_label", y="Count", color=ts_col,
                         color_discrete_sequence=[COLORS[0], COLORS[4]], barmode="group")
            fig = chart_layout(fig, "True vs Systemic Breaks Over Time", "Period", "Count")
            st.plotly_chart(fig, use_container_width=True)

    # Chart 6: Heatmap Team x Period
    with col_f:
        if team_col and team_col in df.columns:
            heat = df.groupby([team_col, "_Period_label"]).size().reset_index(name="Count")
            heat_pivot = heat.pivot_table(index=team_col, columns="_Period_label", values="Count", fill_value=0)
            fig = px.imshow(heat_pivot, color_continuous_scale=["#FFFFFF", PRIMARY],
                            aspect="auto", text_auto=True)
            fig = chart_layout(fig, "Heatmap: Team x Period (Break Counts)", "", "", height=350)
            st.plotly_chart(fig, use_container_width=True)

    col_g, col_h = st.columns(2)

    # Chart 7: Age Bucket distribution over time
    with col_g:
        if bucket_col and bucket_col in df.columns:
            bucket_period = df.groupby([bucket_col, "_Period_label"]).size().reset_index(name="Count")
            bucket_period[bucket_col] = pd.Categorical(bucket_period[bucket_col], categories=BUCKET_ORDER, ordered=True)
            bucket_period = bucket_period.sort_values(bucket_col)
            fig = px.bar(bucket_period, x="_Period_label", y="Count", color=bucket_col,
                         color_discrete_sequence=COLORS, barmode="stack")
            fig = chart_layout(fig, "Age Bucket Distribution Over Time", "Period", "Count")
            st.plotly_chart(fig, use_container_width=True)

    # Chart 8: Top 10 Rec Names horizontal bar
    with col_h:
        if rec_col and rec_col in df.columns:
            top10 = df[rec_col].value_counts().head(10).reset_index()
            top10.columns = ["Rec Name", "Count"]
            top10 = top10.sort_values("Count", ascending=True)
            fig = px.bar(top10, x="Count", y="Rec Name", orientation="h",
                         color_discrete_sequence=[COLORS[0]])
            fig = chart_layout(fig, "Top 10 Rec Names by Break Count", "Count", "")
            st.plotly_chart(fig, use_container_width=True)


