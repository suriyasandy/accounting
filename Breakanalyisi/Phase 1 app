@st.cache_data(show_spinner="Cleaning data...")
def clean_dataframe(df, col_map_tuple):
    """Apply type coercion and cleaning based on column mapping."""
    col_map = dict(col_map_tuple)
    df = df.copy()
    type_violations = []

    # Parse amount columns
    for col_key in ["BREAK AMOUNT CCY", "BREAK AMOUNT GBP", "ABS GBP"]:
        if col_key in col_map and col_map[col_key] in df.columns:
            actual_col = col_map[col_key]
            original = df[actual_col].copy()
            df[actual_col] = df[actual_col].apply(parse_amount)
            violations = original.notna() & df[actual_col].isna()
            if violations.sum() > 0:
                type_violations.append({
                    "Column": actual_col,
                    "Expected Type": "float64",
                    "Violation Count": int(violations.sum()),
                    "Sample Values": ", ".join(original[violations].head(3).astype(str).tolist())
                })

    # Parse Age Days
    if "Age Days" in col_map and col_map["Age Days"] in df.columns:
        actual_col = col_map["Age Days"]
        original = df[actual_col].copy()
        df[actual_col] = df[actual_col].apply(parse_age_days)
        violations = original.notna() & original.astype(str).str.strip().ne('') & df[actual_col].isna()
        if violations.sum() > 0:
            type_violations.append({
                "Column": actual_col,
                "Expected Type": "numeric",
                "Violation Count": int(violations.sum()),
                "Sample Values": ", ".join(original[violations].head(3).astype(str).tolist())
            })

    # Parse Date
    if "Date" in col_map and col_map["Date"] in df.columns:
        actual_col = col_map["Date"]
        df[actual_col] = pd.to_datetime(df[actual_col], errors="coerce")

    # Parse Period to datetime helper column
    if "Period" in col_map and col_map["Period"] in df.columns:
        actual_col = col_map["Period"]
        df["_Period_date"] = df[actual_col].apply(period_to_datetime)
        df["_Period_label"] = df["_Period_date"].dt.strftime("%Y-%m").fillna(df[actual_col].astype(str))

    # Pre-compute unique values for each filterable column to speed up filter rendering
    filter_options = {}
    period_col = col_map.get("Period")
    if period_col and period_col in df.columns:
        filter_options["Period"] = sorted(df[period_col].dropna().unique().tolist())
    for fkey in ["Team", "Rec Name (as per Rec Cube)", "Entity", "Asset Class", "Type of break", "True/Systemic Breaks"]:
        if fkey in col_map and col_map[fkey] in df.columns:
            filter_options[fkey] = sorted(df[col_map[fkey]].dropna().unique().tolist())

    return df, pd.DataFrame(type_violations) if type_violations else pd.DataFrame(columns=["Column", "Expected Type", "Violation Count", "Sample Values"]), filter_options


def detect_outliers_iqr(series, name="Column"):
    """Detect outliers using IQR method."""
    clean = series.dropna()
    if len(clean) < 10:
        return pd.DataFrame()
    q1 = clean.quantile(0.25)
    q3 = clean.quantile(0.75)
    iqr = q3 - q1
    lower = q1 - 1.5 * iqr
    upper = q3 + 1.5 * iqr
    outliers = clean[(clean < lower) | (clean > upper)]
    if len(outliers) == 0:
        return pd.DataFrame()
    return pd.DataFrame({
        "Column": [name],
        "Outlier Count": [len(outliers)],
        "Outlier %": [round(len(outliers) / len(clean) * 100, 2)],
        "IQR Lower": [round(lower, 2)],
        "IQR Upper": [round(upper, 2)],
        "Min Outlier": [round(outliers.min(), 2)],
        "Max Outlier": [round(outliers.max(), 2)],
    })


def apply_global_filters(df, col_map, filter_options):
    """Apply sidebar global filters and return filtered df using pre-computed options."""
    st.sidebar.markdown("---")
    st.sidebar.markdown(f"### 🔍 Global Filters")

    # Build all filter selections first (using pre-computed options), then apply at once
    selections = {}

    # Period range
    if "Period" in filter_options:
        periods_sorted = filter_options["Period"]
        if len(periods_sorted) >= 2:
            period_labels = {p: period_to_datetime(p).strftime("%Y-%m") if pd.notna(period_to_datetime(p)) else str(p) for p in periods_sorted}
            selections["Period"] = st.sidebar.multiselect(
                "Period",
                options=periods_sorted,
                default=periods_sorted,
                format_func=lambda x: period_labels.get(x, str(x)),
                key="filter_period",
            )

    # Team
    if "Team" in filter_options:
        selections["Team"] = st.sidebar.multiselect("Team", filter_options["Team"], default=filter_options["Team"], key="filter_team")

    # Rec Name
    if "Rec Name (as per Rec Cube)" in filter_options:
        selections["Rec Name (as per Rec Cube)"] = st.sidebar.multiselect("Rec Name", filter_options["Rec Name (as per Rec Cube)"], default=filter_options["Rec Name (as per Rec Cube)"], key="filter_rec")

    # Entity
    if "Entity" in filter_options:
        selections["Entity"] = st.sidebar.multiselect("Entity", filter_options["Entity"], default=filter_options["Entity"], key="filter_entity")

    # Asset Class
    if "Asset Class" in filter_options:
        selections["Asset Class"] = st.sidebar.multiselect("Asset Class", filter_options["Asset Class"], default=filter_options["Asset Class"], key="filter_ac")

    # Type of break
    if "Type of break" in filter_options:
        selections["Type of break"] = st.sidebar.multiselect("Type of Break", filter_options["Type of break"], default=filter_options["Type of break"], key="filter_tob")

    # True/Systemic
    if "True/Systemic Breaks" in filter_options:
        selections["True/Systemic Breaks"] = st.sidebar.multiselect("True/Systemic", filter_options["True/Systemic Breaks"], default=filter_options["True/Systemic Breaks"], key="filter_ts")

    # Apply all filters in one pass using boolean indexing
    mask = pd.Series(True, index=df.index)
    for col_key, selected_vals in selections.items():
        if selected_vals and col_key in col_map and col_map[col_key] in df.columns:
            mask &= df[col_map[col_key]].isin(selected_vals)

    return df.loc[mask]


def chart_layout(fig, title="", xaxis_title="", yaxis_title="", height=400):
    """Apply consistent chart styling."""
    fig.update_layout(
        title=dict(text=title, font=dict(size=14, color=DARK)),
        xaxis_title=xaxis_title,
        yaxis_title=yaxis_title,
        height=height,
        margin=dict(l=40, r=20, t=50, b=40),
        font=dict(family="Inter, sans-serif", size=11, color=DARK),
        plot_bgcolor="white",
        paper_bgcolor="white",
        legend=dict(font=dict(size=10)),
    )
    fig.update_xaxes(showgrid=True, gridwidth=1, gridcolor="#ECECEC")
    fig.update_yaxes(showgrid=True, gridwidth=1, gridcolor="#ECECEC")
    return fig


