    "Root Cause identified","B/S Cert",
]


def fuzzy_col_match(cols, target):
    tl = target.lower().strip()
    for c in cols:
        if c.lower().strip() == tl: return c
    for c in cols:
        if tl in c.lower() or c.lower() in tl: return c
    return None


def build_col_map(cols):
    return {exp: m for exp in EXPECTED_COLUMNS if (m := fuzzy_col_match(cols, exp))}


# ─────────────────────────── DuckDB Connection ───────────────────────────

@st.cache_resource
def get_duck() -> duckdb.DuckDBPyConnection:
    """Persistent in-memory DuckDB connection (shared across reruns)."""
    return duckdb.connect()


def duck_query(sql: str, arrow_table=None, table_name: str = "tbl") -> pd.DataFrame:
    """Register an Arrow table and run SQL. Returns Pandas for Plotly."""
    con = get_duck()
    if arrow_table is not None:
        con.register(table_name, arrow_table)
    return con.execute(sql).df()


# ─────────────────────────── Data Loading (Polars) ───────────────────────────

@st.cache_data(show_spinner="Loading file...")
def load_file(file_bytes: bytes, filename: str) -> pl.DataFrame:
    """Load CSV or Excel into Polars DataFrame."""
    buf = BytesIO(file_bytes)
    if filename.lower().endswith(".csv"):
        return pl.read_csv(buf, infer_schema_length=10000, ignore_errors=True)
    return pl.read_excel(buf, engine="openpyxl")


# ─────────────────────────── Cleaning Pipeline (Polars LazyFrame) ───────────────────────────

@st.cache_data(show_spinner="Cleaning & processing data...")
def clean_data(file_bytes: bytes, filename: str):
    """
    Full Polars LazyFrame cleaning pipeline.
    Returns: (pl.DataFrame, col_map, filter_options, type_violations_df)
    Cache key = file bytes hash → only re-runs on new upload.
    """
    raw = load_file(file_bytes, filename)
    col_map = build_col_map(raw.columns)
    lf = raw.lazy()
    type_violations = []

    # ── Amount columns: strip currency symbols/codes, cast to Float64 ──
    for key in ["BREAK AMOUNT CCY", "BREAK AMOUNT GBP", "ABS GBP"]:
        if key not in col_map: continue
        col = col_map[key]
        original_nulls = raw[col].null_count()
        lf = lf.with_columns(
            pl.col(col).cast(pl.Utf8)
              .str.strip_chars()
              .str.replace_all(r"[£$€¥,]", "")
              .str.replace(r"(?i)^(GBP|USD|EUR|JPY|CHF|AUD|CAD)\s*", "")
              .str.strip_chars()
              .cast(pl.Float64, strict=False)
              .alias(col)
        )
        # Collect just that column to count new nulls (cheap)
        new_nulls = lf.select(pl.col(col)).collect()[col].null_count()
        gained = new_nulls - original_nulls
        if gained > 0:
            sample = raw[col].cast(pl.Utf8).drop_nulls().head(3).to_list()
            type_violations.append({"Column": col, "Expected Type": "Float64",
                                    "Violation Count": gained, "Sample Values": ", ".join(sample)})

    # ── Age Days: extract leading integer ──
    if "Age Days" in col_map:
        col = col_map["Age Days"]
        lf = lf.with_columns(
            pl.col(col).cast(pl.Utf8)
              .str.strip_chars()
              .str.extract(r"^[~]?(-?\d+)", 1)
              .cast(pl.Float64, strict=False)
              .alias(col)
        )

    # ── Date: parse to Date ──
    if "Date" in col_map:
        col = col_map["Date"]
        lf = lf.with_columns(
            pl.col(col).cast(pl.Utf8).str.to_date(format=None, strict=False).alias(col)
        )

    # ── Period: derive last-day-of-month datetime ──
    if "Period" in col_map:
        col = col_map["Period"]
        # Period is e.g. 202501 → year=2025, month=1 → last day = 2025-01-31
        lf = lf.with_columns(
            pl.col(col).cast(pl.Int64, strict=False).alias(col)
        ).with_columns([
            (pl.col(col) // 100).cast(pl.Int32).alias("_period_year"),
            (pl.col(col) % 100).cast(pl.Int32).alias("_period_month"),
        ]).with_columns(
            # Build date string for 1st of NEXT month, then subtract 1 day
            pl.when(pl.col("_period_month") == 12)
              .then(
                  pl.concat_str([
                      (pl.col("_period_year") + 1).cast(pl.Utf8),
                      pl.lit("-01-01")
                  ])
              )
              .otherwise(
                  pl.concat_str([
                      pl.col("_period_year").cast(pl.Utf8),
                      pl.lit("-"),
                      (pl.col("_period_month") + 1).cast(pl.Utf8).str.zfill(2),
                      pl.lit("-01")
                  ])
              )
              .str.to_date(strict=False)
              .dt.offset_by("-1d")
              .alias("_Period_date")
        ).with_columns(
            pl.col("_Period_date").dt.strftime("%Y-%m").alias("_Period_label")
        )

    df = lf.collect()

    # ── Ageing validation columns ──
    if "Date" in col_map and "_Period_date" in df.columns:
        date_col = col_map["Date"]
        df = df.with_columns(
            (pl.col("_Period_date") - pl.col(date_col))
            .dt.total_days()
            .alias("_Computed_Age_Days")
        )
        # Computed bucket
        df = df.with_columns(
            pl.when(pl.col("_Computed_Age_Days").is_null()).then(pl.lit("Unknown"))
            .when(pl.col("_Computed_Age_Days") <= 15).then(pl.lit("0-15"))
            .when(pl.col("_Computed_Age_Days") <= 30).then(pl.lit("16-30"))
            .when(pl.col("_Computed_Age_Days") <= 60).then(pl.lit("31-60"))
            .when(pl.col("_Computed_Age_Days") <= 90).then(pl.lit("61-90"))
            .when(pl.col("_Computed_Age_Days") <= 180).then(pl.lit("91-180"))
            .when(pl.col("_Computed_Age_Days") <= 365).then(pl.lit("181-365"))
            .otherwise(pl.lit("365+"))
            .alias("_Computed_Bucket")
        )

    # ── Age / Bucket match flags ──
    if "Age Days" in col_map and "_Computed_Age_Days" in df.columns:
        age_col = col_map["Age Days"]
        df = df.with_columns(
            ((pl.col(age_col) - pl.col("_Computed_Age_Days")).abs() <= 1)
            .alias("_Age_Match")
        )
    if "Bucket" in col_map and "_Computed_Bucket" in df.columns:
        bucket_col = col_map["Bucket"]
        df = df.with_columns(
            (pl.col(bucket_col).cast(pl.Utf8).str.strip_chars() ==
             pl.col("_Computed_Bucket").cast(pl.Utf8).str.strip_chars())
            .alias("_Bucket_Match")
        )

    # ── Pre-compute filter options ──
    filter_options = {}
    for key in ["Period","Team","Rec Name (as per Rec Cube)","Entity",
                "Asset Class","Type of break","True/Systemic Breaks"]:
        if key in col_map and col_map[key] in df.columns:
            vals = df[col_map[key]].drop_nulls().unique().sort().to_list()
            filter_options[key] = vals

    type_violations_df = pd.DataFrame(type_violations) if type_violations else \
        pd.DataFrame(columns=["Column","Expected Type","Violation Count","Sample Values"])

    return df, col_map, filter_options, type_violations_df


# ─────────────────────────── Global Filters ───────────────────────────

def apply_filters(df: pl.DataFrame, col_map: dict, filter_options: dict) -> pl.DataFrame:
    """Apply sidebar multiselect filters using Polars boolean mask (single pass)."""
    st.sidebar.markdown("---")
    st.sidebar.markdown("### 🔍 Global Filters")

    filter_pairs = [
        ("Period",                       "Period",          "f_period"),
        ("Team",                         "Team",            "f_team"),
        ("Rec Name (as per Rec Cube)",   "Rec Name",        "f_rec"),
        ("Entity",                       "Entity",          "f_entity"),
        ("Asset Class",                  "Asset Class",     "f_ac"),
        ("Type of break",                "Type of Break",   "f_tob"),
        ("True/Systemic Breaks",         "True/Systemic",   "f_ts"),
    ]

    mask = pl.lit(True)
    for key, label, widget_key in filter_pairs:
        if key not in filter_options: continue
        opts = filter_options[key]
        selected = st.sidebar.multiselect(label, opts, default=opts, key=widget_key)
        if selected and col_map.get(key) in df.columns:
            mask = mask & pl.col(col_map[key]).is_in(selected)

    return df.filter(mask)


# ─────────────────────────── IQR Outlier Detection ───────────────────────────

def detect_outliers(df: pl.DataFrame, col: str) -> pd.DataFrame:
    s = df[col].drop_nulls()
    if len(s) < 10: return pd.DataFrame()
    q1, q3 = s.quantile(0.25), s.quantile(0.75)
    iqr = q3 - q1
    lo, hi = q1 - 1.5 * iqr, q3 + 1.5 * iqr
    out = s.filter((s < lo) | (s > hi))
    if len(out) == 0: return pd.DataFrame()
    return pd.DataFrame({
        "Column": [col], "Outlier Count": [len(out)],
        "Outlier %": [round(len(out)/len(s)*100, 2)],
        "IQR Lower": [round(lo, 2)], "IQR Upper": [round(hi, 2)],
        "Min Outlier": [round(out.min(), 2)], "Max Outlier": [round(out.max(), 2)],
    })


# ─────────────────────────── Tab 1: Data Quality ───────────────────────────

def tab_data_quality(df: pl.DataFrame, col_map: dict, type_violations_df: pd.DataFrame):
    st.markdown("## Data Quality & Ingestion Scorecard")

    n_rows, n_cols = df.shape
    total_cells = n_rows * n_cols
    null_count  = sum(df[c].null_count() for c in df.columns)
    completeness = round((1 - null_count / total_cells) * 100, 1) if total_cells else 0
    violations   = int(type_violations_df["Violation Count"].sum()) if len(type_violations_df) else 0

    c1, c2, c3, c4 = st.columns(4)
    with c1: kpi_card("Total Records",   format_number(n_rows))
    with c2: kpi_card("Columns",         str(n_cols))
    with c3: kpi_card("Completeness",    f"{completeness}%")
    with c4: kpi_card("Type Violations", format_number(violations), invert=True)

    st.markdown("---")
    col_left, col_right = st.columns(2)

    with col_left:
        st.markdown("### Column Completeness")
        # DuckDB query for per-column null stats
        arrow = df.to_arrow()
        null_exprs = ", ".join(
            f"ROUND(100.0 * COUNT({c}) / COUNT(*), 1) AS \"{c}\""
            for c in df.columns
        )
        comp_wide = duck_query(f"SELECT {null_exprs} FROM tbl", arrow)
        comp_df = comp_wide.T.reset_index()
        comp_df.columns = ["Column", "Completeness %"]
        comp_df = comp_df.sort_values("Completeness %", ascending=True)
        fig = px.bar(comp_df, x="Completeness %", y="Column",
                     orientation="h", color_discrete_sequence=[PRIMARY])
        fig = chart_layout(fig, "Per-Column Completeness (%)", "Completeness %",
                           height=max(350, n_cols * 18))
        fig.update_layout(yaxis=dict(tickfont=dict(size=9)))
        st.plotly_chart(fig, use_container_width=True)

    with col_right:
        st.markdown("### Type Violation Details")
        if len(type_violations_df) > 0:
            render_aggrid(type_violations_df, height=200, key="tv_grid")
        else:
            st.success("No type violations detected.")

        st.markdown("### Outlier Detection (IQR)")
        out_frames = []
        for key in ["BREAK AMOUNT CCY","BREAK AMOUNT GBP","ABS GBP","Age Days"]:
            if key in col_map and col_map[key] in df.columns:
                col = col_map[key]
                if df[col].dtype in (pl.Float64, pl.Int64, pl.Float32, pl.Int32):
                    o = detect_outliers(df, col)
                    if len(o): out_frames.append(o)
        if out_frames:
            render_aggrid(pd.concat(out_frames, ignore_index=True), height=200, key="out_grid")
        else:
            st.info("No outliers detected.")

    st.markdown("### Numeric Summary Statistics")
    num_cols = [c for c in df.columns if df[c].dtype in
                (pl.Float64, pl.Float32, pl.Int64, pl.Int32, pl.Int16)]
    if num_cols:
        summary = df.select(num_cols).describe().to_pandas()
        render_aggrid(summary, height=300, key="summary_grid")
    else:
        st.info("No numeric columns found.")

    st.markdown("---")
    st.download_button(
        "📥 Download Cleaned Dataset (CSV)",
        df.write_csv().encode("utf-8"),
        file_name="cleaned_data.csv", mime="text/csv",
    )


# ─────────────────────────── Tab 2: Ageing Validation ───────────────────────────

def tab_ageing_validation(df: pl.DataFrame, col_map: dict):
    st.markdown("## Ageing Validation")

    age_col    = col_map.get("Age Days")
    bucket_col = col_map.get("Bucket")
    team_col   = col_map.get("Team")
    rec_col    = col_map.get("Rec Name (as per Rec Cube)")

    required = ["_Computed_Age_Days", "_Computed_Bucket", "_Age_Match", "_Bucket_Match"]
    if not all(c in df.columns for c in required):
        st.warning("Period and Date columns required for ageing validation.")
        return

    arrow = df.to_arrow()

    # ── KPIs via DuckDB ──
    kpi_sql = """
        SELECT
            COUNT(*) FILTER (WHERE _Computed_Age_Days IS NOT NULL AND "{age}" IS NOT NULL) AS total_valid,
            COUNT(*) FILTER (WHERE _Age_Match = false AND _Computed_Age_Days IS NOT NULL AND "{age}" IS NOT NULL) AS age_mis,
            COUNT(*) FILTER (WHERE _Bucket_Match = false AND _Computed_Age_Days IS NOT NULL) AS bucket_mis
        FROM tbl
    """.format(age=age_col)
    kpi = duck_query(kpi_sql, arrow).iloc[0]
    total_valid    = int(kpi["total_valid"])
    age_mismatch   = int(kpi["age_mis"])
    bucket_mismatch= int(kpi["bucket_mis"])
    age_pct    = round(age_mismatch / total_valid * 100, 1) if total_valid else 0
    bucket_pct = round(bucket_mismatch / total_valid * 100, 1) if total_valid else 0

    c1, c2, c3, c4 = st.columns(4)
    with c1: kpi_card("Records Validated",      format_number(total_valid))
    with c2: kpi_card("Age Days Discrepancies", f"{format_number(age_mismatch)} ({age_pct}%)", invert=True)
    with c3: kpi_card("Bucket Discrepancies",   f"{format_number(bucket_mismatch)} ({bucket_pct}%)", invert=True)
    with c4: kpi_card("Accuracy Rate",          f"{round(100 - max(age_pct, bucket_pct), 1)}%")

    st.markdown("---")

    # ── Discrepancy table ──
    st.markdown("### Discrepancy Records (max 500)")
    disc_cols = []
    for k in ["Period","Team","Rec Name (as per Rec Cube)","Entity","Date"]:
        if k in col_map and col_map[k] in df.columns:
            disc_cols.append(f'"{col_map[k]}"')
    disc_cols += [f'"{age_col}"', '"_Computed_Age_Days"',
                  f'"{bucket_col}"', '"_Computed_Bucket"', '"_Age_Match"', '"_Bucket_Match"']

    disc_sql = f"""
        SELECT {', '.join(disc_cols)}
        FROM tbl
        WHERE (_Age_Match = false OR _Bucket_Match = false)
          AND _Computed_Age_Days IS NOT NULL
        LIMIT 500
    """
    disc_df = duck_query(disc_sql, arrow)
    if len(disc_df) > 0:
        if HAS_AGGRID:
            gb = GridOptionsBuilder.from_dataframe(disc_df)
            gb.configure_pagination(paginationAutoPageSize=False, paginationPageSize=20)
            gb.configure_default_column(filterable=True, sortable=True, resizable=True)
            cell_style = JsCode("""function(p){
                if(p.value===false||p.value==='False') return {'backgroundColor':'#FDECEA','color':'#A84B2F','fontWeight':'bold'};
                if(p.value===true||p.value==='True')  return {'backgroundColor':'#E8F5E9','color':'#01696F'};
                return {};}""")
            for c in disc_df.columns:
                if "Match" in c: gb.configure_column(c, cellStyle=cell_style)
            AgGrid(disc_df, gridOptions=gb.build(), height=400,
                   theme="streamlit", allow_unsafe_jscode=True, key="disc_grid")
        else:
            st.dataframe(disc_df, height=400, use_container_width=True)
    else:
        st.success("No discrepancies found!")

    st.markdown("---")

    # ── Histogram: computed vs pre-populated ──
    col_left, col_right = st.columns(2)
    with col_left:
        hist_sql = f"""
            SELECT "{age_col}" AS prepop, _Computed_Age_Days AS computed
            FROM tbl WHERE _Computed_Age_Days IS NOT NULL AND "{age_col}" IS NOT NULL
        """
        hist_df = duck_query(hist_sql, arrow)
        fig = go.Figure()
        fig.add_trace(go.Histogram(x=hist_df["prepop"],   name="Pre-populated",
                                   opacity=0.6, marker_color=COLORS[0], nbinsx=50))
        fig.add_trace(go.Histogram(x=hist_df["computed"], name="Computed",
                                   opacity=0.6, marker_color=COLORS[4], nbinsx=50))
        fig.update_layout(barmode="overlay")
        fig = chart_layout(fig, "Age Days Distribution: Computed vs Pre-populated", "Age Days", "Count")
        st.plotly_chart(fig, use_container_width=True)

    with col_right:
        bucket_sql = f"""
            SELECT
                _Computed_Bucket AS bucket,
                COUNT(*) AS computed_count,
                COUNT(*) FILTER (WHERE "{bucket_col}" = _Computed_Bucket) AS match_count
            FROM tbl
            WHERE _Computed_Age_Days IS NOT NULL
            GROUP BY _Computed_Bucket
        """
        bkt_df = duck_query(bucket_sql, arrow)
        prepop_sql = f'SELECT "{bucket_col}" AS bucket, COUNT(*) AS prepop_count FROM tbl GROUP BY "{bucket_col}"'
        prepop_df  = duck_query(prepop_sql, arrow)
        merged = bkt_df.merge(prepop_df, on="bucket", how="outer").fillna(0)
        merged["bucket"] = pd.Categorical(merged["bucket"], categories=BUCKET_ORDER, ordered=True)
        merged = merged.sort_values("bucket")
        fig = go.Figure()
        fig.add_trace(go.Bar(x=merged["bucket"], y=merged["prepop_count"],  name="Pre-populated", marker_color=COLORS[0]))
        fig.add_trace(go.Bar(x=merged["bucket"], y=merged["computed_count"],name="Computed",       marker_color=COLORS[4]))
        fig.update_layout(barmode="group")
