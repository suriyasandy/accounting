        risk[">365 %"] = (risk["over365"] / risk["total"] * 100).round(1)
        fig = go.Figure()
        fig.add_trace(go.Scatter(x=risk["period"], y=risk[">90 %"], name="> 90 Days",
                                 mode="lines+markers", line=dict(color=COLORS[4], width=2),
                                 fill="tozeroy", fillcolor="rgba(168,75,47,0.15)"))
        fig.add_trace(go.Scatter(x=risk["period"], y=risk[">365 %"], name="> 365 Days",
                                 mode="lines+markers", line=dict(color=COLORS[7], width=2),
