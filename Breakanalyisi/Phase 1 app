                             name="Computed", marker_color=COLORS[4]))
        fig.update_layout(barmode="group")
        fig = chart_layout(fig,"Bucket Distribution: Computed vs Pre-populated","Bucket","Count")
        st.plotly_chart(fig, use_container_width=True)

    if team_col and team_col in df.columns:
        st.markdown("### Discrepancy Rate by Team")
        td = dq(f"""
            SELECT "{team_col}" AS team, COUNT(*) AS total,
                   COUNT(*) FILTER (WHERE _Age_Match=false)    AS age_mis,
                   COUNT(*) FILTER (WHERE _Bucket_Match=false) AS bkt_mis
            FROM tbl WHERE _Computed_Age_Days IS NOT NULL
            GROUP BY "{team_col}" ORDER BY total DESC
        """, df)
        td["Age Disc %"]    = (td["age_mis"] / td["total"] * 100).round(1)
        td["Bucket Disc %"] = (td["bkt_mis"] / td["total"] * 100).round(1)
        fig = go.Figure()
        fig.add_trace(go.Bar(x=td["team"], y=td["Age Disc %"],
                             name="Age Disc %", marker_color=COLORS[0]))
        fig.add_trace(go.Bar(x=td["team"], y=td["Bucket Disc %"],
