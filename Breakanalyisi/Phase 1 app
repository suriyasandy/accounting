def main():
    st.sidebar.title("📊 Accounting Control AI")
    st.sidebar.markdown("*Phase 1 — Polars + DuckDB Edition*")
    st.sidebar.markdown("---")

    uploaded = st.sidebar.file_uploader(
        "Upload Data (CSV or Excel)", type=["csv","xlsx","xls"], key="uploader")

    if uploaded is None:
        st.markdown("## 👋 Welcome to Accounting Control AI Platform")
        st.info("Upload a CSV or Excel file using the sidebar to begin.")
        st.markdown("""
        **Supported columns:** `Period`, `Team`, `Rec Name`, `Entity`, `Asset Class`,
        `Type of break`, `BREAK AMOUNT GBP`, `ABS GBP`, `Date`, `Age Days`, `Bucket`,
        `True/Systemic Breaks`, `Root Cause identified`, and more.

        **Performance stack:**
        - 🐻‍❄️ **Polars** — data loading & type coercion (LazyFrame pipeline)
        - 🦆 **DuckDB** — all aggregations via SQL on Arrow (zero-copy)
        - 🐼 **Pandas** — thin shim for Plotly chart inputs only
        """)
        return

    # Read file bytes once — cache key for clean_data
    file_bytes = uploaded.read()

