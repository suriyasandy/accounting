def kpi_card(label: str, value, delta: str = None, invert: bool = False):
    """Render a compact KPI card."""
    delta_html = ""
    if delta:
        css_class = "kpi-delta-neg" if (invert and not delta.startswith("-")) or (not invert and delta.startswith("-")) else "kpi-delta-pos"
        if not invert:
            css_class = "kpi-delta-neg" if delta.startswith("-") else "kpi-delta-pos"
        else:
            css_class = "kpi-delta-pos" if delta.startswith("-") else "kpi-delta-neg"
        delta_html = f'<p class="{css_class}">{delta}</p>'
    st.markdown(f"""
    <div class="kpi-card">
        <p class="kpi-label">{label}</p>
        <p class="kpi-value">{value}</p>
        {delta_html}
    </div>
    """, unsafe_allow_html=True)


def safe_mom_pct(current, previous):
    """Compute MoM percentage safely."""
    if previous is None or previous == 0:
        return None
    return round(((current - previous) / abs(previous)) * 100, 1)


def format_number(n, prefix="", decimal=0):
    """Format number with commas."""
    if pd.isna(n):
        return "N/A"
    if decimal > 0:
        return f"{prefix}{n:,.{decimal}f}"
    return f"{prefix}{int(n):,}"


def period_to_datetime(period_val):
    """Convert int period like 202501 to datetime (last day of month)."""
    try:
        p = int(period_val)
        year = p // 100
        month = p % 100
        if month < 1 or month > 12:
            return pd.NaT
        if month == 12:
            return pd.Timestamp(year + 1, 1, 1) - pd.Timedelta(days=1)
        return pd.Timestamp(year, month + 1, 1) - pd.Timedelta(days=1)
    except (ValueError, TypeError):
        return pd.NaT


def parse_amount(val):
    """Strip currency symbols and parse to float."""
    if pd.isna(val):
        return np.nan
    s = str(val).strip()
    # Remove currency symbols and commas
    s = re.sub(r'[£$€¥]', '', s)
    s = s.replace(',', '').strip()
    # Remove currency codes at start
    s = re.sub(r'^(GBP|USD|EUR|JPY|CHF|AUD|CAD)\s*', '', s, flags=re.IGNORECASE).strip()
    try:
        return float(s)
    except (ValueError, TypeError):
        return np.nan


def parse_age_days(val):
    """Parse age days, stripping non-numeric suffixes."""
    if pd.isna(val):
        return np.nan
    s = str(val).strip()
    if s in ('', 'N/A', 'n/a', '-'):
        return np.nan
    # Extract leading number
    m = re.match(r'^[~]?(-?\d+)', s)
    if m:
        return float(m.group(1))
    return np.nan


def age_to_bucket(age):
    """Derive bucket from age days."""
    if pd.isna(age):
        return "Unknown"
    age = int(age)
    if age <= 15:
        return "0-15"
    elif age <= 30:
        return "16-30"
    elif age <= 60:
        return "31-60"
    elif age <= 90:
        return "61-90"
    elif age <= 180:
        return "91-180"
    elif age <= 365:
        return "181-365"
    else:
        return "365+"


BUCKET_ORDER = ["0-15", "16-30", "31-60", "61-90", "91-180", "181-365", "365+", "Unknown"]


def fuzzy_col_match(uploaded_cols, target):
    """Find best matching column name (case-insensitive, stripped)."""
    target_lower = target.lower().strip()
    for c in uploaded_cols:
        if c.lower().strip() == target_lower:
            return c
    # Partial match
    for c in uploaded_cols:
        if target_lower in c.lower().strip() or c.lower().strip() in target_lower:
            return c
    return None


