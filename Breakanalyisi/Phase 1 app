    col_t3, col_t4 = st.columns(2)

    with col_t3:
        p90_sql = """
            SELECT _Period_label AS period,
                QUANTILE_CONT(_Computed_Age_Days, 0.9) AS p90
            FROM tbl WHERE _Computed_Age_Days IS NOT NULL
            GROUP BY _Period_label ORDER BY _Period_label
        """
