            fig.update_layout(legend_title_text="Bucket")
            fig = chart_layout(fig, "Ageing Bucket Distribution Over Time", "Period", "Break Count")
            st.plotly_chart(fig, use_container_width=True)

        col_t3, col_t4 = st.columns(2)

        # Chart T3: 90th Percentile Age Days Trend
        with col_t3:
            pct_trend = trend_df.groupby("_Period_label")["_Computed_Age_Days"].quantile(0.9).reindex(period_order).reset_index()
            pct_trend.columns = ["Period", "P90 Age Days"]
            fig = go.Figure()
            fig.add_trace(go.Scatter(
                x=pct_trend["Period"], y=pct_trend["P90 Age Days"],
                mode="lines+markers+text", text=pct_trend["P90 Age Days"].round(0).astype(int).astype(str),
                textposition="top center", line=dict(color=COLORS[4], width=2.5),
                marker=dict(size=8, color=COLORS[4]),
                name="P90 Age Days",
            ))
            fig = chart_layout(fig, "90th Percentile Age Days Trend", "Period", "Days")
            st.plotly_chart(fig, use_container_width=True)

        # Chart T4: Ageing Heatmap by Team x Period
        with col_t4:
            if team_col and team_col in trend_df.columns:
                heat_age = trend_df.groupby([team_col, "_Period_label"])["_Computed_Age_Days"].mean().reset_index(name="Avg Age Days")
                heat_pivot = heat_age.pivot_table(index=team_col, columns="_Period_label", values="Avg Age Days", fill_value=0)
                heat_pivot = heat_pivot.reindex(columns=sorted(heat_pivot.columns))
                fig = px.imshow(
                    heat_pivot.round(0), color_continuous_scale=["#E8F5E9", "#FFC553", "#A84B2F"],
                    aspect="auto", text_auto=".0f",
                )
                fig = chart_layout(fig, "Heatmap: Avg Age Days by Team x Period", "", "", height=350)
                fig.update_layout(coloraxis_colorbar_title="Days")
                st.plotly_chart(fig, use_container_width=True)
            else:
                st.info("Team column not available for heatmap.")

        # Chart T5: High-risk ageing proportion over time
        col_t5, col_t6 = st.columns(2)
        with col_t5:
            high_age_by_period = []
            for p in period_order:
                p_data = trend_df[trend_df["_Period_label"] == p]
                total = len(p_data)
                over_365 = int((p_data["_Computed_Age_Days"] > 365).sum())
                over_90 = int((p_data["_Computed_Age_Days"] > 90).sum())
                high_age_by_period.append({
                    "Period": p,
                    "> 365 Days %": round(over_365 / total * 100, 1) if total > 0 else 0,
                    "> 90 Days %": round(over_90 / total * 100, 1) if total > 0 else 0,
                })
            high_df = pd.DataFrame(high_age_by_period)
            fig = go.Figure()
            fig.add_trace(go.Scatter(
                x=high_df["Period"], y=high_df["> 90 Days %"],
                name="> 90 Days", mode="lines+markers",
                line=dict(color=COLORS[4], width=2), fill="tozeroy",
                fillcolor="rgba(168, 75, 47, 0.15)",
            ))
            fig.add_trace(go.Scatter(
                x=high_df["Period"], y=high_df["> 365 Days %"],
                name="> 365 Days", mode="lines+markers",
                line=dict(color=COLORS[7], width=2), fill="tozeroy",
                fillcolor="rgba(148, 68, 84, 0.15)",
            ))
            fig = chart_layout(fig, "High-Risk Ageing Proportion Over Time", "Period", "% of Breaks")
            st.plotly_chart(fig, use_container_width=True)

        # Chart T6: MoM Change in Break Count by Bucket
        with col_t6:
            bucket_period_count = trend_df.groupby(["_Period_label", "_Computed_Bucket"], observed=False).size().unstack(fill_value=0)
            bucket_period_count = bucket_period_count.reindex(columns=BUCKET_ORDER, fill_value=0).reindex(period_order)
            mom_change = bucket_period_count.pct_change().mul(100).round(1)
            if len(mom_change.dropna()) > 0:
                fig = go.Figure()
                for i, bucket in enumerate(BUCKET_ORDER[:6]):
                    if bucket in mom_change.columns:
                        fig.add_trace(go.Scatter(
                            x=mom_change.index, y=mom_change[bucket],
                            name=bucket, mode="lines+markers",
                            line=dict(color=COLORS[i % len(COLORS)], width=1.5),
                        ))
                fig = chart_layout(fig, "MoM % Change in Break Count by Bucket", "Period", "MoM Change %")
                fig.add_hline(y=0, line_dash="dash", line_color=MUTED, line_width=1)
                st.plotly_chart(fig, use_container_width=True)
    else:
        st.info("Period column not available for trend analysis.")

    # Download
    if len(disc_df) > 0:
        st.download_button(
            "📥 Download Discrepancy Report (CSV)",
            disc_df.to_csv(index=False).encode("utf-8"),
            file_name="ageing_discrepancy_report.csv",
            mime="text/csv",
        )


