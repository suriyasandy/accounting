# ── Convert high-cardinality strings to Categorical ──
for cat_key in CATEGORICAL_COLS:
    if cat_key in col_map and col_map[cat_key] in df.columns:
        col = col_map[cat_key]
        if df[col].dtype == object:
            df[col] = df[col].astype("category")

# ── Amount columns ──
for col_key in ["BREAK AMOUNT CCY", "BREAK AMOUNT GBP", "ABS GBP"]:
    if col_key in col_map and col_map[col_key] in df.columns:
        actual_col = col_map[col_key]
        original = df[actual_col].copy()
        df[actual_col] = parse_amount_vec(df[actual_col])
        violations = original.notna() & df[actual_col].isna()
        if violations.sum() > 0:
            type_violations.append({
                "Column": actual_col, "Expected Type": "float64",
                "Violation Count": int(violations.sum()),
                "Sample Values": ", ".join(original[violations].head(3).astype(str).tolist()),
            })

# ── Age Days ──
if "Age Days" in col_map and col_map["Age Days"] in df.columns:
    actual_col = col_map["Age Days"]
    original = df[actual_col].copy()
    df[actual_col] = parse_age_days_vec(df[actual_col])
    violations = (original.notna() & original.astype(str).str.strip().ne('') & df[actual_col].isna())
    if violations.sum() > 0:
        type_violations.append({
            "Column": actual_col, "Expected Type": "numeric",
            "Violation Count": int(violations.sum()),
            "Sample Values": ", ".join(original[violations].head(3).astype(str).tolist()),
        })

# ── Date ──
if "Date" in col_map and col_map["Date"] in df.columns:
    df[col_map["Date"]] = pd.to_datetime(df[col_map["Date"]], errors="coerce")

# ── Period helper columns — fully vectorised, no .apply() ──
if "Period" in col_map and col_map["Period"] in df.columns:
    actual_col = col_map["Period"]
    df["_Period_date"] = period_to_datetime_vec(df[actual_col])
    # OPTIMISATION 3: vectorised label generation
    df["_Period_label"] = period_labels_vec(df[actual_col])

# ── Pre-compute filter options (stored once) ──
filter_options = {}
period_col = col_map.get("Period")
if period_col and period_col in df.columns:
    filter_options["Period"] = sorted(df[period_col].dropna().unique().tolist())
for fkey in ["Team", "Rec Name (as per Rec Cube)", "Entity", "Asset Class",
             "Type of break", "True/Systemic Breaks"]:
    if fkey in col_map and col_map[fkey] in df.columns:
        # .cat.categories is O(1) for Categorical columns
        col = col_map[fkey]
        if hasattr(df[col], "cat"):
            filter_options[fkey] = sorted(df[col].cat.categories.tolist())
        else:
            filter_options[fkey] = sorted(df[col].dropna().unique().tolist())

type_violations_df = pd.DataFrame(type_violations) if type_violations else pd.DataFrame(
    columns=["Column", "Expected Type", "Violation Count", "Sample Values"])

return df, type_violations_df, filter_options
```

