# ─────────────────────────── Tab 6: Threshold Alerts ───────────────────────────

def tab_threshold_alerts(df, col_map):
    """Render Threshold Alerts tab with Median + MAD based alerting on count, amount, or both."""
    st.markdown("## Threshold Alerts")

    period_col = col_map.get("Period")
    team_col = col_map.get("Team")
    rec_col = col_map.get("Rec Name (as per Rec Cube)")
    entity_col = col_map.get("Entity")
    ac_col = col_map.get("Asset Class")
    gbp_col = col_map.get("BREAK AMOUNT GBP")
    abs_col = col_map.get("ABS GBP")

    amt_col = abs_col if (abs_col and abs_col in df.columns) else gbp_col
    has_amounts = amt_col and amt_col in df.columns
    if not period_col or period_col not in df.columns:
        st.warning("Period column not found.")
        return

    # ── Segment definition ──
    st.markdown("### Segment Configuration")
    seg_cols_map = {
        "Team": team_col,
        "Rec Name": rec_col,
        "Entity": entity_col,
        "Asset Class": ac_col,
    }
    available_segments = {k: v for k, v in seg_cols_map.items() if v and v in df.columns}

    if not available_segments:
        st.warning("No dimension columns available for segmentation.")
        return

    col_s1, col_s2 = st.columns([1, 1])
    with col_s1:
        seg_choice = st.selectbox(
            "Primary segment dimension",
            list(available_segments.keys()),
            key="thresh_seg",
        )
    with col_s2:
        metric_options = ["Break Count", "Break Amount", "Both"] if has_amounts else ["Break Count"]
        threshold_metric = st.radio("Threshold metric", metric_options, horizontal=True, key="thresh_metric")
    seg_col = available_segments[seg_choice]

    # MAD multiplier
    col_cfg1, col_cfg2 = st.columns(2)
    with col_cfg1:
        mad_k = st.slider("MAD multiplier (k)", 1.0, 5.0, 3.0, 0.5, key="thresh_k")
    with col_cfg2:
        watchlist_k = st.slider("Watchlist multiplier", 1.0, 4.0, 2.0, 0.5, key="thresh_wk")

    # ── Compute per-segment stats ──
    periods_sorted = sorted(df[period_col].dropna().unique())

    # Break count per segment per period
    seg_period_count = df.groupby([seg_col, period_col]).size().reset_index(name="Break Count")
    # Break amount per segment per period
    if has_amounts:
        seg_period_amt = df.groupby([seg_col, period_col])[amt_col].sum().abs().reset_index(name="Break Amount")
        seg_period = seg_period_count.merge(seg_period_amt, on=[seg_col, period_col], how="left")
    else:
        seg_period = seg_period_count.copy()
        seg_period["Break Amount"] = 0.0

    # Compute median and MAD per segment (across periods)
    alert_rows = []
    segments = seg_period[seg_col].unique()
    for seg_val in segments:
        seg_data = seg_period[seg_period[seg_col] == seg_val].sort_values(period_col)
        n_periods = len(seg_data)

        if n_periods < 2:
            latest = seg_data.iloc[-1] if n_periods == 1 else None
            alert_rows.append({
                "Segment": seg_val,
                "Latest Count": int(latest["Break Count"]) if latest is not None else 0,
                "Median Count": np.nan, "MAD Count": np.nan, "Upper Count Threshold": np.nan,
                "Count Classification": "Insufficient Data", "Count Deviation %": np.nan,
                "Latest Amount": float(latest["Break Amount"]) if latest is not None else 0,
                "Median Amount": np.nan, "MAD Amount": np.nan, "Upper Amount Threshold": np.nan,
                "Amount Classification": "Insufficient Data", "Amount Deviation %": np.nan,
                "Classification": "Insufficient Data", "Deviation %": np.nan,
                "Periods": n_periods,
            })
            continue

        counts = seg_data["Break Count"].values
        amounts = seg_data["Break Amount"].values

        # --- Count thresholds ---
        median_c = float(np.median(counts))
        mad_c = float(np.median(np.abs(counts - median_c)))
        if mad_c == 0:
            mad_c = max(median_c * 0.1, 1.0)
        upper_mat_c = median_c + mad_k * mad_c
        upper_watch_c = median_c + watchlist_k * mad_c
        latest_count = int(counts[-1])
        if latest_count > upper_mat_c:
            count_cls = "Material"
        elif latest_count > upper_watch_c:
            count_cls = "Watchlist"
        else:
            count_cls = "Normal"
        count_dev = round((latest_count - median_c) / mad_c * 100, 1) if mad_c > 0 else 0.0

        # --- Amount thresholds ---
        median_a = float(np.median(amounts))
        mad_a = float(np.median(np.abs(amounts - median_a)))
        if mad_a == 0:
            mad_a = max(median_a * 0.1, 1.0)
        upper_mat_a = median_a + mad_k * mad_a
        upper_watch_a = median_a + watchlist_k * mad_a
        latest_amount = float(amounts[-1])
        if latest_amount > upper_mat_a:
            amt_cls = "Material"
        elif latest_amount > upper_watch_a:
            amt_cls = "Watchlist"
        else:
            amt_cls = "Normal"
        amt_dev = round((latest_amount - median_a) / mad_a * 100, 1) if mad_a > 0 else 0.0

        # --- Combined classification (worst of count vs amount) ---
        cls_rank = {"Material": 2, "Watchlist": 1, "Normal": 0}
        if threshold_metric == "Break Count":
            classification = count_cls
            deviation = count_dev
        elif threshold_metric == "Break Amount":
            classification = amt_cls
            deviation = amt_dev
        else:  # Both
            classification = count_cls if cls_rank.get(count_cls, 0) >= cls_rank.get(amt_cls, 0) else amt_cls
            deviation = max(count_dev, amt_dev)

        alert_rows.append({
            "Segment": seg_val,
            "Latest Count": latest_count,
            "Median Count": round(median_c, 1), "MAD Count": round(mad_c, 2),
            "Upper Count Threshold": round(upper_mat_c, 1),
            "Count Classification": count_cls, "Count Deviation %": count_dev,
            "Latest Amount": round(latest_amount, 2),
            "Median Amount": round(median_a, 1), "MAD Amount": round(mad_a, 2),
            "Upper Amount Threshold": round(upper_mat_a, 1),
            "Amount Classification": amt_cls, "Amount Deviation %": amt_dev,
            "Classification": classification, "Deviation %": deviation,
            "Periods": n_periods,
        })

    alert_df = pd.DataFrame(alert_rows)

    # ── KPIs ──
    material_count = int((alert_df["Classification"] == "Material").sum())
    watchlist_count = int((alert_df["Classification"] == "Watchlist").sum())
    normal_count = int((alert_df["Classification"] == "Normal").sum())
    insufficient_count = int((alert_df["Classification"] == "Insufficient Data").sum())

    c1, c2, c3, c4 = st.columns(4)
    with c1:
        kpi_card("Total Segments", str(len(alert_df)))
    with c2:
        kpi_card("Material Alerts", str(material_count), invert=True)
    with c3:
        kpi_card("Watchlist", str(watchlist_count))
    with c4:
        kpi_card("Normal", str(normal_count))

    st.markdown("---")

    # ── Alert Table with color-coded classification ──
    st.markdown("### Alert Summary Table")
    # Select columns for display based on metric
    if threshold_metric == "Break Count":
        display_cols = ["Segment", "Latest Count", "Median Count", "MAD Count",
                        "Upper Count Threshold", "Latest Amount", "Classification",
                        "Count Deviation %", "Periods"]
    elif threshold_metric == "Break Amount":
        display_cols = ["Segment", "Latest Count", "Latest Amount", "Median Amount",
                        "MAD Amount", "Upper Amount Threshold", "Classification",
                        "Amount Deviation %", "Periods"]
    else:
        display_cols = ["Segment", "Latest Count", "Median Count", "Upper Count Threshold",
                        "Count Classification", "Latest Amount", "Median Amount",
                        "Upper Amount Threshold", "Amount Classification",
                        "Classification", "Deviation %", "Periods"]
    display_alert = alert_df[[c for c in display_cols if c in alert_df.columns]].copy()
    display_alert = display_alert.sort_values("Deviation %" if "Deviation %" in display_alert.columns else display_cols[-2],
                                              ascending=False, na_position="last").reset_index(drop=True)

    amt_js_formatter = JsCode("""
    function(params) {
        var v = Math.abs(params.value);
        var sign = params.value < 0 ? '-' : '';
        if (v >= 1e9) return sign + '\\u00a3' + (v/1e9).toFixed(1) + 'B';
        if (v >= 1e6) return sign + '\\u00a3' + (v/1e6).toFixed(1) + 'M';
        if (v >= 1e3) return sign + '\\u00a3' + (v/1e3).toFixed(1) + 'K';
        return sign + '\\u00a3' + Math.round(v).toLocaleString();
    }
    """)

    if HAS_AGGRID and len(display_alert) > 0:
        gb = GridOptionsBuilder.from_dataframe(display_alert)
        gb.configure_pagination(paginationAutoPageSize=False, paginationPageSize=20)
        gb.configure_default_column(filterable=True, sortable=True, resizable=True)
        cls_style = JsCode("""
        function(params) {
            if (params.value === 'Material') {
                return {'backgroundColor': '#FDECEA', 'color': '#A84B2F', 'fontWeight': 'bold'};
            }
            if (params.value === 'Watchlist') {
                return {'backgroundColor': '#FFF8E1', 'color': '#E65100', 'fontWeight': 'bold'};
            }
            if (params.value === 'Normal') {
                return {'backgroundColor': '#E8F5E9', 'color': '#01696F'};
            }
            return {'backgroundColor': '#F5F5F5', 'color': '#7A7974', 'fontStyle': 'italic'};
        }
        """)
        gb.configure_column("Classification", cellStyle=cls_style)
        if "Count Classification" in display_alert.columns:
            gb.configure_column("Count Classification", cellStyle=cls_style)
        if "Amount Classification" in display_alert.columns:
            gb.configure_column("Amount Classification", cellStyle=cls_style)
        for ac in ["Latest Amount", "Median Amount", "MAD Amount", "Upper Amount Threshold"]:
            if ac in display_alert.columns:
                gb.configure_column(ac, type=["numericColumn"], valueFormatter=amt_js_formatter)
        AgGrid(display_alert, gridOptions=gb.build(), height=400, theme="streamlit",
               allow_unsafe_jscode=True, key="alert_grid")
    else:
        st.dataframe(display_alert, height=400, use_container_width=True)

    st.markdown("---")

    # ── Charts ──
    col_a, col_b = st.columns(2)

    # Chart 1: Classification bar chart
    with col_a:
        cls_counts = alert_df["Classification"].value_counts().reset_index()
        cls_counts.columns = ["Classification", "Count"]
        cls_order = ["Material", "Watchlist", "Normal", "Insufficient Data"]
        cls_colors = {"Material": "#A84B2F", "Watchlist": "#FFC553", "Normal": "#01696F", "Insufficient Data": "#7A7974"}
        cls_counts["Classification"] = pd.Categorical(cls_counts["Classification"], categories=cls_order, ordered=True)
        cls_counts = cls_counts.sort_values("Classification")
        fig = go.Figure(go.Bar(
            x=cls_counts["Classification"], y=cls_counts["Count"],
            marker_color=[cls_colors.get(c, MUTED) for c in cls_counts["Classification"]],
            text=cls_counts["Count"], textposition="auto",
        ))
        fig = chart_layout(fig, "Segments by Classification", "Classification", "Count")
        st.plotly_chart(fig, use_container_width=True)

    # Chart 2: Scatter — Latest value vs Median
    with col_b:
        scatter_df = alert_df[alert_df["Classification"] != "Insufficient Data"].copy()
        if len(scatter_df) > 0:
            if threshold_metric == "Break Amount":
                sx, sy, slbl = "Median Amount", "Latest Amount", "amount"
                scatter_df["Bubble Size"] = scatter_df["Latest Count"].clip(lower=1)
                scatter_df["Hover Amount"] = scatter_df["Latest Amount"].apply(format_short)
            else:
                sx, sy, slbl = "Median Count", "Latest Count", "count"
                scatter_df["Bubble Size"] = scatter_df["Latest Amount"].clip(lower=1)
                scatter_df["Hover Amount"] = scatter_df["Latest Amount"].apply(format_short)
            fig = px.scatter(
                scatter_df, x=sx, y=sy,
                color="Classification",
                color_discrete_map={"Material": "#A84B2F", "Watchlist": "#FFC553", "Normal": "#01696F"},
                hover_name="Segment", size="Bubble Size",
                size_max=30,
                hover_data={"Hover Amount": True, "Bubble Size": False},
            )
            max_val = max(scatter_df[sx].max(), scatter_df[sy].max()) * 1.1
            fig.add_trace(go.Scatter(
                x=[0, max_val], y=[0, max_val],
                mode="lines", line=dict(dash="dash", color=MUTED, width=1),
                showlegend=False, name="1:1 line",
            ))
            fig = chart_layout(fig, f"Latest {slbl.title()} vs Median (bubble = {'count' if slbl == 'amount' else 'amount'})",
                               sx, sy)
            st.plotly_chart(fig, use_container_width=True)
        else:
            st.info("No segments with sufficient data for scatter chart.")

    col_c, col_d = st.columns(2)

    # Chart 3: Top 10 most deviated segments
    with col_c:
        top_dev = alert_df[alert_df["Deviation %"].notna()].nlargest(10, "Deviation %")
        if len(top_dev) > 0:
            top_dev_sorted = top_dev.sort_values("Deviation %", ascending=True)
            fig = go.Figure(go.Bar(
                x=top_dev_sorted["Deviation %"], y=top_dev_sorted["Segment"],
                orientation="h",
                marker_color=[
                    "#A84B2F" if c == "Material" else "#FFC553" if c == "Watchlist" else "#01696F"
                    for c in top_dev_sorted["Classification"]
                ],
                text=top_dev_sorted["Deviation %"].apply(lambda x: f"{x:.1f}%"),
                textposition="auto",
            ))
            fig = chart_layout(fig, "Top 10 Most Deviated Segments", "Deviation from Median (%)", "",
                               height=max(300, len(top_dev) * 35))
            st.plotly_chart(fig, use_container_width=True)

    # Chart 4: Time series with threshold bands for selected segment
    with col_d:
        st.markdown("### Segment Time Series with Threshold Bands")
        selectable_segs = alert_df[alert_df["Classification"] != "Insufficient Data"]["Segment"].tolist()
        if selectable_segs:
            default_seg = alert_df[alert_df["Classification"] == "Material"]["Segment"].tolist()
