    "If Duplicate Trade, provide the CC, etc details", "TRADE CCY",
    "BREAK AMOUNT CCY", "BREAK AMOUNT GBP", "Date", "Age Days", "Bucket",
    "True/Systemic Breaks", "Journals Posted", "Comments", "ABS GBP",
    "Root Cause identified", "B/S Cert",
]


def build_column_mapping(uploaded_cols):
    """Build a mapping from expected to actual column names."""
    mapping = {}
    for expected in EXPECTED_COLUMNS:
        match = fuzzy_col_match(uploaded_cols, expected)
        if match:
            mapping[expected] = match
    return mapping


def render_aggrid(df, height=400, selection=False, key=None):
    """Render AgGrid table or fallback to st.dataframe."""
    if HAS_AGGRID and len(df) > 0:
        gb = GridOptionsBuilder.from_dataframe(df)
        gb.configure_pagination(paginationAutoPageSize=False, paginationPageSize=20)
        gb.configure_default_column(filterable=True, sortable=True, resizable=True, wrapText=False)
        if selection:
            gb.configure_selection("single", use_checkbox=False)
        grid_opts = gb.build()
        return AgGrid(
            df, gridOptions=grid_opts, height=height,
            theme="streamlit", key=key,
            allow_unsafe_jscode=True,
        )
    else:
        st.dataframe(df, height=height, use_container_width=True)
        return None


