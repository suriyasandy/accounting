            fig = px.line(rec_amt, x="_Period_label", y="Amount", color=rec_col,
                          color_discrete_sequence=COLORS, markers=True)
            fig = chart_layout(fig, "Break Amount by Top 10 Rec Names Over Periods", "Period", "Amount (GBP)")
            st.plotly_chart(fig, use_container_width=True)

    # Chart 4: By Asset Class
    with col_d:
