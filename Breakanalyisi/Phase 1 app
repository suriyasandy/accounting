        fig.update_layout(barmode="group")
        fig = chart_layout(fig,"Discrepancy Rate by Team (%)","Team","Disc %")
        st.plotly_chart(fig, use_container_width=True)

    if rec_col and rec_col in df.columns:
        st.markdown("### Discrepancy Rate by Rec Name")
        rd = dq(f"""
            SELECT "{rec_col}" AS rec, COUNT(*) AS total,
                   COUNT(*) FILTER (WHERE _Bucket_Match=false) AS mis
            FROM tbl WHERE _Computed_Age_Days IS NOT NULL GROUP BY "{rec_col}"
        """, df)
        rd["Disc %"] = (rd["mis"] / rd["total"] * 100).round(1)
        rd = rd.sort_values("Disc %", ascending=True)
        fig = px.bar(rd, x="Disc %", y="rec", orientation="h",
