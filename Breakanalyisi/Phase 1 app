def file_hash(b: bytes) -> str:
    return hashlib.md5(b).hexdigest()


# ─────────────────────────── DuckDB Connection ───────────────────────────

@st.cache_resource
def get_duck() -> duckdb.DuckDBPyConnection:
    """Single persistent in-memory DuckDB connection."""
    return duckdb.connect()


def dq(sql: str, df: pd.DataFrame = None) -> pd.DataFrame:
    """
    Execute SQL via DuckDB on a Pandas DataFrame.
    DuckDB accesses the local variable 'df' directly via replacement scan —
    zero-copy, no registration needed.
    """
    con = get_duck()
    if df is not None:
        con.register("tbl", df)
    return con.execute(sql).df()


# ─────────────────────────── Parquet Conversion ───────────────────────────

def _csv_to_parquet_duckdb(file_bytes: bytes) -> bytes:
    con = duckdb.connect()
    with tempfile.NamedTemporaryFile(suffix=".csv", delete=False) as fi:
        fi.write(file_bytes); csv_path = fi.name
    with tempfile.NamedTemporaryFile(suffix=".parquet", delete=False) as fo:
        pq_path = fo.name
    try:
        con.execute(f"""
            COPY (SELECT * FROM read_csv_auto('{csv_path}', ignore_errors=true, all_varchar=true))
            TO '{pq_path}' (FORMAT PARQUET, COMPRESSION ZSTD)
        """)
        return open(pq_path, "rb").read()
    finally:
        os.unlink(csv_path)
        if os.path.exists(pq_path): os.unlink(pq_path)
        con.close()


def _xlsx_to_parquet(file_bytes: bytes) -> bytes:
    with tempfile.NamedTemporaryFile(suffix=".xlsx", delete=False) as fi:
        fi.write(file_bytes); xlsx_path = fi.name
    with tempfile.NamedTemporaryFile(suffix=".parquet", delete=False) as fo:
        pq_path = fo.name
    try:
        # Primary: DuckDB spatial
        con = duckdb.connect()
        con.execute("INSTALL spatial; LOAD spatial;")
        con.execute(f"COPY (SELECT * FROM st_read('{xlsx_path}')) TO '{pq_path}' (FORMAT PARQUET, COMPRESSION ZSTD)")
        return open(pq_path, "rb").read()
    except Exception:
        try:
            import polars as pl
            df = pl.read_excel(BytesIO(file_bytes), engine="calamine")
            buf = BytesIO(); df.write_parquet(buf, compression="zstd"); return buf.getvalue()
        except Exception:
            import polars as pl
            df = pl.read_excel(BytesIO(file_bytes), engine="openpyxl")
            buf = BytesIO(); df.write_parquet(buf, compression="zstd"); return buf.getvalue()
    finally:
        os.unlink(xlsx_path)
        if os.path.exists(pq_path): os.unlink(pq_path)
        try: con.close()
        except: pass


def get_parquet_bytes(file_bytes: bytes, filename: str) -> tuple[bytes, bool]:
    fhash = file_hash(file_bytes)
    key   = f"parquet_{fhash}"
    if key in st.session_state:
        return st.session_state[key], False
    name_lower = filename.lower()
    if name_lower.endswith(".parquet"):
        pq = file_bytes
    elif name_lower.endswith(".csv"):
        with st.spinner("⚡ Converting CSV → Parquet via DuckDB..."):
            pq = _csv_to_parquet_duckdb(file_bytes)
    else:
        with st.spinner("⚡ Converting Excel → Parquet..."):
            pq = _xlsx_to_parquet(file_bytes)
    st.session_state[key] = pq
    for k in list(st.session_state.keys()):
        if k.startswith("parquet_") and k != key:
            del st.session_state[k]
    return pq, not name_lower.endswith(".parquet")


# ─────────────────────────── Vectorised Helpers ───────────────────────────

def period_to_datetime_vec(series):
    s = pd.to_numeric(series, errors="coerce")
    year = (s // 100).astype("Int64"); month = (s % 100).astype("Int64")
    valid = month.between(1, 12) & year.notna()
    next_month = (month + 1).where(valid); next_year = year.where(valid)
    dec = month == 12
    next_month = next_month.where(~dec, 1); next_year = next_year.where(~dec, year + 1)
    result = pd.Series(pd.NaT, index=series.index, dtype="datetime64[ns]")
    vi = valid[valid].index
    if len(vi) > 0:
        ds = next_year.loc[vi].astype(str) + "-" + next_month.loc[vi].astype(str).str.zfill(2) + "-01"
        result.loc[vi] = pd.to_datetime(ds, errors="coerce") - pd.Timedelta(days=1)
    return result


def parse_amount_vec(series):
    s = series.astype(str).str.strip()
    s = s.str.replace(r'[£$€¥,]', '', regex=True)
    s = s.str.replace(r'^(GBP|USD|EUR|JPY|CHF|AUD|CAD)\s*', '', regex=True, case=False).str.strip()
    r = pd.to_numeric(s, errors="coerce"); r[series.isna()] = np.nan
    return r


def parse_age_days_vec(series):
    s = series.astype(str).str.strip()
    r = pd.to_numeric(s.str.extract(r'^[~]?(-?\d+)', expand=False), errors="coerce")
    r[series.isna() | s.isin(['','N/A','n/a','-','nan','None'])] = np.nan
    return r


def age_to_bucket_vec(age_series):
    a = age_series.values
    cond = [pd.isna(age_series), a<=15, a<=30, a<=60, a<=90, a<=180, a<=365]
    choices = ["Unknown","0-15","16-30","31-60","61-90","91-180","181-365"]
    return pd.Categorical(np.select(cond, choices, default="365+"),
                          categories=BUCKET_ORDER, ordered=True)


# ─────────────────────────── Column Mapping ───────────────────────────

EXPECTED_COLUMNS = [
    "Period","Asset Class","Team","Rec Name (as per Rec Cube)","Entity",
    "Type of break","Account Group","Products Reconciled","TRADE REF",
    "If Duplicate Trade, provide the CC, etc details","TRADE CCY",
    "BREAK AMOUNT CCY","BREAK AMOUNT GBP","Date","Age Days","Bucket",
    "True/Systemic Breaks","Journals Posted","Comments","ABS GBP",
    "Root Cause identified","B/S Cert",
]

def fuzzy_col_match(cols, target):
    tl = target.lower().strip()
    for c in cols:
        if c.lower().strip() == tl: return c
    for c in cols:
        if tl in c.lower() or c.lower() in tl: return c
    return None

def build_col_map(cols):
    return {e: m for e in EXPECTED_COLUMNS if (m := fuzzy_col_match(cols, e))}


# ─────────────────────────── Load Parquet ───────────────────────────

@st.cache_data(show_spinner="Loading file...")
def load_parquet(parquet_bytes: bytes) -> pd.DataFrame:
    return pd.read_parquet(BytesIO(parquet_bytes))


# ─────────────────────────── Clean & Process ───────────────────────────

@st.cache_data(show_spinner="Cleaning & processing data...")
def clean_dataframe(parquet_bytes: bytes):
    df      = load_parquet(parquet_bytes)
    col_map = build_col_map(df.columns.tolist())
    violations = []

    # ── Amount columns ──
    for key in ["BREAK AMOUNT CCY","BREAK AMOUNT GBP","ABS GBP"]:
        if key in col_map and col_map[key] in df.columns:
            col = col_map[key]; orig = df[col].copy()
            df[col] = parse_amount_vec(df[col])
            bad = orig.notna() & df[col].isna()
            if bad.sum():
                violations.append({"Column":col,"Expected Type":"float64",
                    "Violation Count":int(bad.sum()),
                    "Sample Values":", ".join(orig[bad].head(3).astype(str))})

    # ── Age Days ──
    if "Age Days" in col_map and col_map["Age Days"] in df.columns:
        col = col_map["Age Days"]; orig = df[col].copy()
        df[col] = parse_age_days_vec(df[col])
        bad = orig.notna() & orig.astype(str).str.strip().ne('') & df[col].isna()
        if bad.sum():
            violations.append({"Column":col,"Expected Type":"numeric",
                "Violation Count":int(bad.sum()),
                "Sample Values":", ".join(orig[bad].head(3).astype(str))})

    # ── Date ──
    if "Date" in col_map and col_map["Date"] in df.columns:
        df[col_map["Date"]] = pd.to_datetime(df[col_map["Date"]], errors="coerce")

    # ── Period ──
    if "Period" in col_map and col_map["Period"] in df.columns:
        col = col_map["Period"]
        df["_Period_date"]  = period_to_datetime_vec(df[col])
        df["_Period_label"] = df["_Period_date"].dt.strftime("%Y-%m").fillna(df[col].astype(str))

    # ── Ageing computed columns ──
    if "Date" in col_map and "_Period_date" in df.columns:
        date_col = col_map["Date"]
        df["_Computed_Age_Days"] = (df["_Period_date"] - df[date_col]).dt.days
        df["_Computed_Bucket"]   = age_to_bucket_vec(df["_Computed_Age_Days"])
        if "Age Days" in col_map:
            df["_Age_Match"] = np.isclose(
                df[col_map["Age Days"]].fillna(-999),
                df["_Computed_Age_Days"].fillna(-998), atol=1)
        if "Bucket" in col_map:
            df["_Bucket_Match"] = (df[col_map["Bucket"]].astype(str).str.strip() ==
                                   df["_Computed_Bucket"].astype(str).str.strip())

    # ── Filter options ──
    filter_options = {}
    for key in ["Period","Team","Rec Name (as per Rec Cube)","Entity",
                "Asset Class","Type of break","True/Systemic Breaks"]:
        if key in col_map and col_map[key] in df.columns:
            filter_options[key] = sorted(df[col_map[key]].dropna().unique().tolist())

    vdf = pd.DataFrame(violations) if violations else \
          pd.DataFrame(columns=["Column","Expected Type","Violation Count","Sample Values"])

    return df, col_map, filter_options, vdf


# ─────────────────────────── Global Filters via DuckDB ───────────────────────────

def apply_global_filters(df: pd.DataFrame, col_map: dict, filter_options: dict) -> pd.DataFrame:
    """
    Sidebar filter UI → build a single DuckDB WHERE clause → execute once.
    DuckDB C++ filter evaluation is 5-10x faster than pandas boolean mask
    on 600K rows when multiple filter columns are active simultaneously.
    """
    st.sidebar.markdown("---")
    st.sidebar.markdown("### 🔍 Global Filters")

    selections = {}
    for key, label, wkey in [
        ("Period",                      "Period",        "f_period"),
        ("Team",                        "Team",          "f_team"),
        ("Rec Name (as per Rec Cube)",  "Rec Name",      "f_rec"),
        ("Entity",                      "Entity",        "f_entity"),
        ("Asset Class",                 "Asset Class",   "f_ac"),
        ("Type of break",               "Type of Break", "f_tob"),
        ("True/Systemic Breaks",        "True/Systemic", "f_ts"),
    ]:
        if key not in filter_options: continue
        opts = filter_options[key]
        sel  = st.sidebar.multiselect(label, opts, default=opts, key=wkey)
        if sel and len(sel) < len(opts):   # only add if not "all selected"
            selections[key] = sel

    if not selections:
        return df   # nothing filtered — return full df instantly

    # ── Build WHERE clause — DuckDB handles all filter logic in C++ ──
    where_parts = []
    for key, vals in selections.items():
        col = col_map[key]
        # Escape single quotes in values
        escaped = [str(v).replace("'", "''") for v in vals]
        in_list = ", ".join(f"'{v}'" for v in escaped)
        where_parts.append(f'"{col}" IN ({in_list})')

    where_sql = " AND ".join(where_parts)
    sql = f"SELECT * FROM tbl WHERE {where_sql}"

    return dq(sql, df)


# ─────────────────────────── Outlier Detection ───────────────────────────

def detect_outliers_iqr(series, name="Column"):
    clean = series.dropna()
    if len(clean) < 10: return pd.DataFrame()
    q1, q3 = clean.quantile(0.25), clean.quantile(0.75)
    iqr = q3 - q1; lo, hi = q1 - 1.5*iqr, q3 + 1.5*iqr
    out = clean[(clean < lo) | (clean > hi)]
    if len(out) == 0: return pd.DataFrame()
    return pd.DataFrame({"Column":[name],"Outlier Count":[len(out)],
        "Outlier %":[round(len(out)/len(clean)*100,2)],
        "IQR Lower":[round(lo,2)],"IQR Upper":[round(hi,2)],
        "Min Outlier":[round(out.min(),2)],"Max Outlier":[round(out.max(),2)]})


