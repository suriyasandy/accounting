            sel_seg = st.selectbox("Select segment", selectable_segs, index=default_idx, key="thresh_ts_seg")
            seg_ts = seg_period[seg_period[seg_col] == sel_seg].sort_values(period_col)
            seg_row = alert_df[alert_df["Segment"] == sel_seg].iloc[0]

            # Choose metric for time series
            if threshold_metric == "Break Amount":
                ts_y, ts_med, ts_mad = "Break Amount", seg_row["Median Amount"], seg_row["MAD Amount"]
                ts_label = "Break Amount"
            else:
                ts_y, ts_med, ts_mad = "Break Count", seg_row["Median Count"], seg_row["MAD Count"]
                ts_label = "Break Count"

            if pd.notna(ts_med):
                period_labels = seg_ts[period_col].apply(
                    lambda x: period_to_datetime_scalar(x).strftime("%Y-%m") if pd.notna(period_to_datetime_scalar(x)) else str(x))

                fig = go.Figure()
                upper_mat = ts_med + mad_k * ts_mad
                upper_watch = ts_med + watchlist_k * ts_mad

                fig.add_hrect(y0=upper_mat, y1=max(seg_ts[ts_y].max() * 1.2, upper_mat * 1.3),
                              fillcolor="rgba(168, 75, 47, 0.1)", line_width=0, annotation_text="Material",
                              annotation_position="top left")
                fig.add_hrect(y0=upper_watch, y1=upper_mat,
                              fillcolor="rgba(255, 197, 83, 0.15)", line_width=0, annotation_text="Watchlist",
                              annotation_position="top left")
                fig.add_hline(y=ts_med, line_dash="dash", line_color=MUTED, line_width=1,
                              annotation_text="Median")
                fig.add_hline(y=upper_mat, line_dash="dot", line_color="#A84B2F", line_width=1)
                fig.add_hline(y=upper_watch, line_dash="dot", line_color="#FFC553", line_width=1)

                fig.add_trace(go.Scatter(
                    x=period_labels, y=seg_ts[ts_y],
                    mode="lines+markers", name=ts_label,
                    line=dict(color=COLORS[0], width=2.5),
                    marker=dict(size=8),
                ))
                fig = chart_layout(fig, f"Time Series: {sel_seg}", "Period", ts_label)
                st.plotly_chart(fig, use_container_width=True)
        else:
            st.info("No segments with sufficient data for time series.")

    # ── False Positive Identification (IMPROVEMENT 3) ──
    st.markdown("---")
    normal_df = alert_df[alert_df["Classification"] == "Normal"].copy()
    total_normal_breaks = 0
    total_all_breaks = 0
    if len(alert_df) > 0:
        total_all_breaks = int(alert_df["Latest Count"].sum())
        total_normal_breaks = int(normal_df["Latest Count"].sum())

    # FP Confidence: how close is the segment to the watchlist threshold
    if len(normal_df) > 0:
        if threshold_metric == "Break Amount":
            fp_latest_col, fp_watch_col = "Latest Amount", "Upper Amount Threshold"
        else:
            fp_latest_col, fp_watch_col = "Latest Count", "Upper Count Threshold"
        watch_thresholds = []
        for _, row in normal_df.iterrows():
            if threshold_metric == "Break Count":
                wt = row["Median Count"] + watchlist_k * row["MAD Count"] if pd.notna(row["Median Count"]) else np.nan
            elif threshold_metric == "Break Amount":
                wt = row["Median Amount"] + watchlist_k * row["MAD Amount"] if pd.notna(row["Median Amount"]) else np.nan
            else:
                wt_c = row["Median Count"] + watchlist_k * row["MAD Count"] if pd.notna(row["Median Count"]) else np.nan
                wt_a = row["Median Amount"] + watchlist_k * row["MAD Amount"] if pd.notna(row["Median Amount"]) else np.nan
                wt = min(wt_c, wt_a) if pd.notna(wt_c) and pd.notna(wt_a) else (wt_c if pd.notna(wt_c) else wt_a)
            watch_thresholds.append(wt)
        normal_df["Watchlist Threshold"] = watch_thresholds
        if threshold_metric == "Break Amount":
            latest_vals = normal_df["Latest Amount"]
        elif threshold_metric == "Break Count":
            latest_vals = normal_df["Latest Count"]
        else:
            latest_vals = normal_df[["Latest Count", "Latest Amount"]].max(axis=1)
        normal_df["FP Confidence %"] = np.where(
            normal_df["Watchlist Threshold"] > 0,
            ((normal_df["Watchlist Threshold"] - latest_vals) / normal_df["Watchlist Threshold"] * 100).clip(upper=100).round(1),
            np.nan,
        )

    fp_count = len(normal_df)
    fp_pct = round(total_normal_breaks / total_all_breaks * 100, 1) if total_all_breaks > 0 else 0

    c1, c2 = st.columns(2)
    with c1:
        kpi_card("Potential False Positives",
                 f"{fp_count} segments ({fp_pct}% of total breaks)")
    with c2:
        avg_fp_conf = normal_df["FP Confidence %"].mean() if len(normal_df) > 0 and "FP Confidence %" in normal_df.columns else 0
        kpi_card("Avg FP Confidence", f"{avg_fp_conf:.1f}%")

    with st.expander("View False Positive Candidates (Normal Segments)", expanded=False):
        if len(normal_df) > 0:
            fp_display_cols = ["Segment", "Latest Count", "Latest Amount", "FP Confidence %", "Periods"]
            fp_display = normal_df[[c for c in fp_display_cols if c in normal_df.columns]].copy()
            fp_display = fp_display.sort_values("FP Confidence %", ascending=True, na_position="last").reset_index(drop=True)
            if "Latest Amount" in fp_display.columns:
                fp_display["Latest Amount"] = fp_display["Latest Amount"].apply(format_short)
            render_aggrid(fp_display, height=350, key="fp_grid")
        else:
            st.info("No Normal segments found — all segments are flagged as Material or Watchlist.")

    # Download
    st.markdown("---")
    st.download_button(
        "Download Alert Report (CSV)",
        alert_df.to_csv(index=False).encode("utf-8"),
        file_name="threshold_alerts.csv",
        mime="text/csv",
    )


# ─────────────────────────── Tab 7: Factor Influence Analysis ───────────────────────────

def tab_factor_analysis(df, col_map):
    """Render Factor Influence Analysis tab — decompose period-over-period changes by dimension."""
    st.markdown("## Factor Influence Analysis")

    period_col = col_map.get("Period")
    team_col = col_map.get("Team")
    rec_col = col_map.get("Rec Name (as per Rec Cube)")
    entity_col = col_map.get("Entity")
    ac_col = col_map.get("Asset Class")
    tob_col = col_map.get("Type of break")
    ts_col = col_map.get("True/Systemic Breaks")
    gbp_col = col_map.get("BREAK AMOUNT GBP")
    abs_col = col_map.get("ABS GBP")

    amt_col = abs_col if (abs_col and abs_col in df.columns) else gbp_col
    if not period_col or period_col not in df.columns:
        st.warning("Period column not found.")
        return

    # Auto-select latest vs previous period
    periods_sorted = sorted(df[period_col].dropna().unique())
    if len(periods_sorted) < 2:
        st.warning("Need at least 2 periods for factor analysis.")
        return

    col_p1, col_p2 = st.columns(2)
    with col_p1:
        prev_period = st.selectbox("Previous Period", periods_sorted[:-1],
                                   index=len(periods_sorted) - 2,
                                   format_func=lambda x: period_to_datetime_scalar(x).strftime("%Y-%m") if pd.notna(period_to_datetime_scalar(x)) else str(x),
                                   key="fa_prev")
    with col_p2:
        curr_period = st.selectbox("Current Period", periods_sorted[1:],
                                   index=len(periods_sorted[1:]) - 1,
                                   format_func=lambda x: period_to_datetime_scalar(x).strftime("%Y-%m") if pd.notna(period_to_datetime_scalar(x)) else str(x),
                                   key="fa_curr")

    df_prev = df[df[period_col] == prev_period]
    df_curr = df[df[period_col] == curr_period]

    total_prev_count = len(df_prev)
    total_curr_count = len(df_curr)
    count_change = total_curr_count - total_prev_count
    count_pct = round(count_change / total_prev_count * 100, 1) if total_prev_count > 0 else 0

    total_prev_amt = df_prev[amt_col].sum() if amt_col and amt_col in df_prev.columns else 0
    total_curr_amt = df_curr[amt_col].sum() if amt_col and amt_col in df_curr.columns else 0
    amt_change = total_curr_amt - total_prev_amt
    amt_pct = round(amt_change / abs(total_prev_amt) * 100, 1) if total_prev_amt != 0 else 0

    prev_label = period_to_datetime_scalar(prev_period).strftime("%Y-%m") if pd.notna(period_to_datetime_scalar(prev_period)) else str(prev_period)
    curr_label = period_to_datetime_scalar(curr_period).strftime("%Y-%m") if pd.notna(period_to_datetime_scalar(curr_period)) else str(curr_period)

    # Dimension selector
    dimensions_map = {
        "Team": team_col,
        "Rec Name": rec_col,
        "Entity": entity_col,
        "Asset Class": ac_col,
        "Type of Break": tob_col,
        "True/Systemic": ts_col,
    }
    available_dims = {k: v for k, v in dimensions_map.items() if v and v in df.columns}

    if not available_dims:
        st.warning("No dimension columns available for factor analysis.")
        return

    sel_dim = st.selectbox("Decompose by dimension", list(available_dims.keys()), key="fa_dim")
    dim_col = available_dims[sel_dim]

    # Compute per-dimension breakdown
    prev_grp = df_prev.groupby(dim_col).agg(
        Prev_Count=(dim_col, "size"),
    ).reset_index()
    curr_grp = df_curr.groupby(dim_col).agg(
        Curr_Count=(dim_col, "size"),
    ).reset_index()

    if amt_col and amt_col in df.columns:
        prev_amt_grp = df_prev.groupby(dim_col)[amt_col].sum().abs().reset_index(name="Prev_Amount")
        curr_amt_grp = df_curr.groupby(dim_col)[amt_col].sum().abs().reset_index(name="Curr_Amount")
        prev_grp = prev_grp.merge(prev_amt_grp, on=dim_col, how="left")
        curr_grp = curr_grp.merge(curr_amt_grp, on=dim_col, how="left")
    else:
        prev_grp["Prev_Amount"] = 0.0
        curr_grp["Curr_Amount"] = 0.0

    factor_df = prev_grp.merge(curr_grp, on=dim_col, how="outer").fillna(0)
    factor_df["Count Change"] = factor_df["Curr_Count"] - factor_df["Prev_Count"]
    factor_df["Count Change %"] = np.where(
        factor_df["Prev_Count"] > 0,
        (factor_df["Count Change"] / factor_df["Prev_Count"] * 100).round(1),
        np.where(factor_df["Curr_Count"] > 0, 100.0, 0.0),
    )
    factor_df["Amount Change"] = factor_df["Curr_Amount"] - factor_df["Prev_Amount"]
    factor_df["Amount Change %"] = np.where(
        factor_df["Prev_Amount"] > 0,
        (factor_df["Amount Change"] / factor_df["Prev_Amount"] * 100).round(1),
        np.where(factor_df["Curr_Amount"] > 0, 100.0, 0.0),
    )
    factor_df = factor_df.sort_values("Count Change", ascending=False)

    # ── Plain-English Summary (teal info box at top) ──
    summary_parts = []
    direction = "increased" if count_change >= 0 else "decreased"
    summary_parts.append(
        f"Break count **{direction} by {abs(count_change):,}** ({count_pct:+.1f}%) "
        f"from **{prev_label}** to **{curr_label}**."
    )
    if len(factor_df) > 0:
        top_inc = factor_df.loc[factor_df["Count Change"].idxmax()]
        top_dec = factor_df.loc[factor_df["Count Change"].idxmin()]
        if top_inc["Count Change"] > 0:
            summary_parts.append(
                f"Largest increase: **{top_inc[dim_col]}** (+{int(top_inc['Count Change']):,} breaks)."
            )
        if top_dec["Count Change"] < 0:
            summary_parts.append(
                f"Largest decrease: **{top_dec[dim_col]}** ({int(top_dec['Count Change']):,} breaks)."
            )
        if amt_col and amt_col in df.columns:
            amt_dir = "increased" if amt_change >= 0 else "decreased"
            summary_parts.append(
                f"Total amount **{amt_dir} by {format_short(abs(amt_change))}** ({amt_pct:+.1f}%)."
            )
        # Concentration check
        top3 = factor_df.nlargest(3, "Count Change")
        top3_total = top3["Count Change"].sum()
        if count_change != 0:
            conc = round(top3_total / count_change * 100, 1)
            if abs(conc) > 50:
                top3_names = ", ".join(top3[dim_col].tolist())
                summary_parts.append(
                    f"Top 3 segments ({top3_names}) account for **{abs(conc):.0f}%** of the net change."
                )

    summary_text = " ".join(summary_parts)
    # Convert markdown bold to HTML bold for HTML rendering
    summary_html = re.sub(r'\*\*(.+?)\*\*', r'<strong>\1</strong>', summary_text)
    st.markdown(
        f'<div style="background-color:#E6F4F1; border-left:4px solid {PRIMARY}; padding:12px 16px; '
        f'border-radius:4px; margin-bottom:16px; color:#1B474D; font-size:0.95rem;">'
        f'{summary_html}</div>',
        unsafe_allow_html=True,
    )

    # KPIs
    c1, c2, c3, c4 = st.columns(4)
    with c1:
        kpi_card(f"Count ({prev_label})", format_number(total_prev_count))
    with c2:
        kpi_card(f"Count ({curr_label})", format_number(total_curr_count),
                 f"{'+' if count_change >= 0 else ''}{count_change:,} ({count_pct:+.1f}%)", invert=True)
    with c3:
        kpi_card(f"Amount ({prev_label})", format_short(total_prev_amt))
    with c4:
        kpi_card(f"Amount ({curr_label})", format_short(total_curr_amt),
                 f"{'+' if amt_change >= 0 else ''}{format_short(amt_change)} ({amt_pct:+.1f}%)", invert=True)

    st.markdown("---")

    # ── Charts ──
    col_a, col_b = st.columns(2)

    # Chart 1: Waterfall — Count change by dimension (simplified hover)
    with col_a:
        wf = factor_df.sort_values("Count Change", ascending=False)
        measures = ["relative"] * len(wf) + ["total"]
        x_labels = wf[dim_col].tolist() + ["Net Change"]
        y_values = wf["Count Change"].tolist() + [0]

        fig = go.Figure(go.Waterfall(
            x=x_labels, y=y_values, measure=measures,
            increasing=dict(marker_color="#A84B2F"),
            decreasing=dict(marker_color="#01696F"),
            totals=dict(marker_color=DARK),
            connector=dict(line=dict(color=MUTED, width=1)),
            text=[f"{v:+,.0f}" for v in wf["Count Change"]] + [f"{count_change:+,.0f}"],
            textposition="outside",
            hovertemplate="%{x}<br>Change: %{y:+,.0f}<extra></extra>",
        ))
        fig = chart_layout(fig, f"Break Count Change by {sel_dim}", sel_dim, "Count Change",
                           height=450)
        fig.update_xaxes(tickangle=45)
        st.plotly_chart(fig, use_container_width=True)

    # Chart 2: Side-by-side bar — previous vs current
    with col_b:
        bar_df = factor_df.sort_values("Curr_Count", ascending=True).tail(15)
        fig = go.Figure()
        fig.add_trace(go.Bar(
            y=bar_df[dim_col], x=bar_df["Prev_Count"], name=prev_label,
            orientation="h", marker_color=COLORS[0], opacity=0.7,
        ))
        fig.add_trace(go.Bar(
            y=bar_df[dim_col], x=bar_df["Curr_Count"], name=curr_label,
            orientation="h", marker_color=COLORS[4], opacity=0.7,
        ))
        fig.update_layout(barmode="group")
        fig = chart_layout(fig, f"{prev_label} vs {curr_label} by {sel_dim}", "Count", "",
                           height=max(350, len(bar_df) * 30))
        st.plotly_chart(fig, use_container_width=True)

    col_c, col_d = st.columns(2)

    # Chart 3: Top Movers (replaces heatmap) — top 5 increases and decreases
    with col_c:
        st.markdown("### Top Movers")
        top_inc = factor_df[factor_df["Count Change"] > 0].nlargest(5, "Count Change")
        top_dec = factor_df[factor_df["Count Change"] < 0].nsmallest(5, "Count Change")
        mc1, mc2 = st.columns(2)
        with mc1:
            st.markdown(f'<p style="color:#A84B2F; font-weight:bold; margin-bottom:4px;">Top Increases</p>',
                        unsafe_allow_html=True)
            if len(top_inc) > 0:
                for _, r in top_inc.iterrows():
                    st.markdown(
                        f'<div style="padding:4px 8px; margin:2px 0; background:#FDECEA; border-radius:4px;">'
                        f'<b>{r[dim_col]}</b>: +{int(r["Count Change"]):,} ({r["Count Change %"]:+.1f}%)</div>',
                        unsafe_allow_html=True,
                    )
            else:
                st.caption("No increases")
        with mc2:
            st.markdown(f'<p style="color:#01696F; font-weight:bold; margin-bottom:4px;">Top Decreases</p>',
                        unsafe_allow_html=True)
            if len(top_dec) > 0:
                for _, r in top_dec.iterrows():
                    st.markdown(
                        f'<div style="padding:4px 8px; margin:2px 0; background:#E6F4F1; border-radius:4px;">'
                        f'<b>{r[dim_col]}</b>: {int(r["Count Change"]):,} ({r["Count Change %"]:+.1f}%)</div>',
                        unsafe_allow_html=True,
                    )
            else:
                st.caption("No decreases")

    # Chart 4: Pareto — cumulative contribution to count change (cleaner)
    with col_d:
        pareto_df = factor_df[[dim_col, "Count Change"]].copy()
        pareto_df["Abs Change"] = pareto_df["Count Change"].abs()
        pareto_df = pareto_df.sort_values("Abs Change", ascending=False)
        total_abs = pareto_df["Abs Change"].sum()
        pareto_df["Cumulative %"] = (pareto_df["Abs Change"].cumsum() / total_abs * 100).round(1) if total_abs > 0 else 0

        fig = go.Figure()
        fig.add_trace(go.Bar(
            x=pareto_df[dim_col], y=pareto_df["Abs Change"],
            name="Abs Change", marker_color=COLORS[0], opacity=0.8,
            hovertemplate="%{x}<br>Abs Change: %{y:,.0f}<extra></extra>",
        ))
        fig.add_trace(go.Scatter(
            x=pareto_df[dim_col], y=pareto_df["Cumulative %"],
            name="Cumulative %", yaxis="y2",
            line=dict(color=COLORS[4], width=2.5), mode="lines+markers",
            hovertemplate="%{x}<br>Cumulative: %{y:.1f}%<extra></extra>",
        ))
        fig.update_layout(
            yaxis2=dict(title="Cumulative %", overlaying="y", side="right", range=[0, 110]),
            showlegend=False,
        )
        fig = chart_layout(fig, f"Pareto: Contribution by {sel_dim}",
                           sel_dim, "Abs Count Change", height=420)
        fig.update_xaxes(tickangle=45)
        st.plotly_chart(fig, use_container_width=True)

    # ── Summary table in expander ──
    with st.expander("Dimension Breakdown Summary", expanded=False):
        summary_df = factor_df.rename(columns={
            dim_col: sel_dim,
            "Prev_Count": f"Count ({prev_label})",
            "Curr_Count": f"Count ({curr_label})",
            "Count Change": "Count Change",
            "Count Change %": "Count Change %",
            "Prev_Amount": f"Amount ({prev_label})",
            "Curr_Amount": f"Amount ({curr_label})",
            "Amount Change": "Amount Change",
            "Amount Change %": "Amount Change %",
        })
        render_aggrid(summary_df.reset_index(drop=True), height=400, key="factor_grid")

    # Download
    st.markdown("---")
    st.download_button(
        "Download Factor Analysis (CSV)",
        factor_df.to_csv(index=False).encode("utf-8"),
        file_name="factor_analysis.csv",
        mime="text/csv",
    )


