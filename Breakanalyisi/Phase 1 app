def tab_data_quality(df, col_map, type_violations_df):
    """Render Data Quality & Ingestion tab."""
    st.markdown("## Data Quality & Ingestion Scorecard")

    total_records = len(df)
    total_cols = len(df.columns)
    completeness = round(df.notna().sum().sum() / (total_records * total_cols) * 100, 1) if total_records * total_cols > 0 else 0
    violation_count = int(type_violations_df["Violation Count"].sum()) if len(type_violations_df) > 0 else 0

    c1, c2, c3, c4 = st.columns(4)
    with c1:
        kpi_card("Total Records", format_number(total_records))
    with c2:
        kpi_card("Columns", str(total_cols))
    with c3:
        kpi_card("Completeness", f"{completeness}%")
    with c4:
        kpi_card("Type Violations", format_number(violation_count), invert=True)

    st.markdown("---")
    col_left, col_right = st.columns(2)

    # Per-column completeness
    with col_left:
        st.markdown("### Column Completeness")
        completeness_data = pd.DataFrame({
            "Column": df.columns,
            "Completeness %": [round(df[c].notna().sum() / len(df) * 100, 1) if len(df) > 0 else 0 for c in df.columns]
        }).sort_values("Completeness %", ascending=True)

        fig = px.bar(
            completeness_data, x="Completeness %", y="Column",
            orientation="h", color_discrete_sequence=[PRIMARY],
        )
        fig = chart_layout(fig, title="Per-Column Completeness (%)", xaxis_title="Completeness %", height=max(350, len(df.columns) * 18))
        fig.update_layout(yaxis=dict(tickfont=dict(size=9)))
        st.plotly_chart(fig, use_container_width=True)

    # Type violations
    with col_right:
        st.markdown("### Type Violation Details")
        if len(type_violations_df) > 0:
            render_aggrid(type_violations_df, height=200, key="tv_grid")
        else:
            st.success("No type violations detected.")

        # Outlier detection
        st.markdown("### Outlier Detection (IQR Method)")
        amount_cols = []
        for key in ["BREAK AMOUNT CCY", "BREAK AMOUNT GBP", "ABS GBP"]:
            if key in col_map and col_map[key] in df.columns:
                amount_cols.append(col_map[key])
        if "Age Days" in col_map and col_map["Age Days"] in df.columns:
            amount_cols.append(col_map["Age Days"])

        outlier_frames = []
        for c in amount_cols:
            if df[c].dtype in [np.float64, np.int64, float, int]:
                ol = detect_outliers_iqr(df[c], c)
                if len(ol) > 0:
                    outlier_frames.append(ol)
        if outlier_frames:
            outlier_df = pd.concat(outlier_frames, ignore_index=True)
            render_aggrid(outlier_df, height=200, key="outlier_grid")
        else:
            st.info("No outliers detected in amount columns.")

    # Summary stats
    st.markdown("### Numeric Column Summary Statistics")
    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    if numeric_cols:
        summary = df[numeric_cols].describe().T.round(2)
        summary.index.name = "Column"
        summary = summary.reset_index()
        render_aggrid(summary, height=300, key="summary_grid")
    else:
        st.info("No numeric columns found.")

    # Lazy download — only generate CSV when button is clicked
    st.markdown("---")
    st.download_button(
        "📥 Download Cleaned Dataset (CSV)",
        df.to_csv(index=False).encode("utf-8"),
        file_name="cleaned_data.csv",
        mime="text/csv",
    )


# ─────────────────────────── Tab 2: Ageing Validation ───────────────────────────

def tab_ageing_validation(df, col_map, col_map_tuple):
    """Render Ageing Validation tab using cached computations."""
    st.markdown("## Ageing Validation")

    period_col = col_map.get("Period")
    date_col = col_map.get("Date")
    age_col = col_map.get("Age Days")
    bucket_col = col_map.get("Bucket")
    team_col = col_map.get("Team")
    rec_col = col_map.get("Rec Name (as per Rec Cube)")

    if not all([period_col, date_col, age_col, bucket_col]):
        st.warning("Required columns (Period, Date, Age Days, Bucket) not found. Cannot run ageing validation.")
        return

    # Use CACHED computation
    vdf = compute_ageing_validation(df, col_map_tuple)
    if vdf is None:
        st.warning("Cannot compute Age Days: Period or Date not properly parsed.")
        return

    valid_rows = vdf[vdf["_Computed_Age_Days"].notna() & vdf[age_col].notna()]
    total_valid = len(valid_rows)

    age_mismatch = int((~valid_rows["_Age_Match"]).sum())
    bucket_mismatch = int((~valid_rows["_Bucket_Match"]).sum())
    age_pct = round(age_mismatch / total_valid * 100, 1) if total_valid > 0 else 0
    bucket_pct = round(bucket_mismatch / total_valid * 100, 1) if total_valid > 0 else 0

    # KPIs
    c1, c2, c3, c4 = st.columns(4)
    with c1:
        kpi_card("Records Validated", format_number(total_valid))
    with c2:
        kpi_card("Age Days Discrepancies", f"{format_number(age_mismatch)} ({age_pct}%)", invert=True)
    with c3:
        kpi_card("Bucket Discrepancies", f"{format_number(bucket_mismatch)} ({bucket_pct}%)", invert=True)
    with c4:
        kpi_card("Accuracy Rate", f"{round(100 - max(age_pct, bucket_pct), 1)}%")

    st.markdown("---")

    # Discrepancy table — limited to 500 rows for display
    st.markdown("### Discrepancy Records")
    disc_df = valid_rows[~valid_rows["_Age_Match"] | ~valid_rows["_Bucket_Match"]]
    if len(disc_df) > 0:
        show_cols = []
        for key in ["Period", "Team", "Rec Name (as per Rec Cube)", "Entity", "Date"]:
            if key in col_map and col_map[key] in disc_df.columns:
                show_cols.append(col_map[key])
        show_cols.extend([age_col, "_Computed_Age_Days", bucket_col, "_Computed_Bucket", "_Age_Match", "_Bucket_Match"])
        display_disc = disc_df[show_cols].head(500).copy()
        display_disc.columns = [c.replace("_Computed_", "Computed ").replace("_", " ").strip() for c in display_disc.columns]

        if HAS_AGGRID:
            gb = GridOptionsBuilder.from_dataframe(display_disc)
            gb.configure_pagination(paginationAutoPageSize=False, paginationPageSize=20)
            gb.configure_default_column(filterable=True, sortable=True, resizable=True)
            cell_style_jscode = JsCode("""
            function(params) {
                if (params.value === false || params.value === 'False') {
                    return {'backgroundColor': '#FDECEA', 'color': '#A84B2F', 'fontWeight': 'bold'};
                }
                if (params.value === true || params.value === 'True') {
                    return {'backgroundColor': '#E8F5E9', 'color': '#01696F'};
                }
                return {};
            }
            """)
            for col_name in display_disc.columns:
                if "Match" in col_name:
                    gb.configure_column(col_name, cellStyle=cell_style_jscode)
            AgGrid(display_disc, gridOptions=gb.build(), height=400, theme="streamlit",
                   allow_unsafe_jscode=True, key="disc_grid")
        else:
