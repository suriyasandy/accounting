        fig = chart_layout(fig,"High-Risk Ageing Proportion Over Time","Period","% of Breaks")
        st.plotly_chart(fig, use_container_width=True)

    with ct6:
        mom_raw = dq("""
            SELECT _Period_label AS period, _Computed_Bucket AS bucket, COUNT(*) AS cnt
            FROM tbl WHERE _Computed_Age_Days IS NOT NULL
            GROUP BY _Period_label, _Computed_Bucket ORDER BY _Period_label
        """, df)
        mom_pivot  = mom_raw.pivot_table(index="period", columns="bucket",
                                          values="cnt", fill_value=0)
        mom_pivot  = mom_pivot.reindex(columns=BUCKET_ORDER, fill_value=0).reindex(period_order)
        mom_change = mom_pivot.pct_change().mul(100).round(1)
        if len(mom_change.dropna()) > 0:
            fig = go.Figure()
            for i, b in enumerate(BUCKET_ORDER[:6]):
                if b in mom_change.columns:
                    fig.add_trace(go.Scatter(
                        x=mom_change.index, y=mom_change[b], name=b,
                        mode="lines+markers",
                        line=dict(color=COLORS[i % len(COLORS)], width=1.5)
                    ))
            fig.add_hline(y=0, line_dash="dash", line_color=MUTED, line_width=1)
            fig = chart_layout(fig,"MoM % Change in Break Count by Bucket","Period","MoM %")
            st.plotly_chart(fig, use_container_width=True)

    if len(disc_df) > 0:
        st.download_button("📥 Download Discrepancy Report (CSV)",
            disc_df.to_csv(index=False).encode("utf-8"),
            file_name="ageing_discrepancy_report.csv", mime="text/csv")


