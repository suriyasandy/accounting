def fuzzy_col_match(cols, target):
    tl = target.lower().strip()
    for c in cols:
        if c.lower().strip() == tl: return c
    for c in cols:
        if tl in c.lower() or c.lower() in tl: return c
    return None


def build_col_map(cols):
    return {e: m for e in EXPECTED_COLUMNS if (m := fuzzy_col_match(cols, e))}


def drop_blank_trailing_cols(df: pd.DataFrame, n: int = 4) -> pd.DataFrame:
    """
    Drop the last `n` columns if they are >95% empty (blank/NaN).
    These are the trailing unnamed blank columns in the MI report.
    """
    cols_to_drop = []
    for col in df.columns[-(n):]:
        null_pct = df[col].isna().sum() / len(df) if len(df) > 0 else 1.0
        str_blank = 0.0
        try:
            str_blank = (df[col].astype(str).str.strip().isin(['','nan','None','NaN'])
                         .sum() / len(df))
        except Exception:
            pass
        if max(null_pct, str_blank) >= 0.95:
            cols_to_drop.append(col)
    if cols_to_drop:
        df = df.drop(columns=cols_to_drop)
    return df, cols_to_drop


# ─────────────────────────── File Loading ───────────────────────────

@st.cache_data(show_spinner="Reading file... (cached after first load — instant on reruns)")
def load_raw_file(file_bytes: bytes, filename: str) -> pd.DataFrame:
    buf  = BytesIO(file_bytes)
    name = filename.lower()
    if name.endswith(".parquet"):
        return pd.read_parquet(buf)
    if name.endswith(".csv"):
        return pd.read_csv(buf, low_memory=False)
    try:
        import polars as pl
        return pl.read_excel(buf, engine="calamine").to_pandas()
    except Exception:
        buf.seek(0)
        return pd.read_excel(buf, engine="openpyxl")


# ─────────────────────────── Clean & Process ───────────────────────────

@st.cache_data(show_spinner="Cleaning & processing data...")
def clean_dataframe(file_bytes: bytes, filename: str):
    df = load_raw_file(file_bytes, filename)

    # ── Drop last 4 blank trailing columns ──
    df, dropped_cols = drop_blank_trailing_cols(df, n=4)

    col_map    = build_col_map(df.columns.tolist())
    violations = []

    for key in ["BREAK AMOUNT CCY","BREAK AMOUNT GBP","ABS GBP"]:
        if key in col_map and col_map[key] in df.columns:
            col = col_map[key]; orig = df[col].copy()
            df[col] = parse_amount_vec(df[col])
            bad = orig.notna() & df[col].isna()
            if bad.sum():
                violations.append({"Column":col,"Expected Type":"float64",
                    "Violation Count":int(bad.sum()),
                    "Sample Values":", ".join(orig[bad].head(3).astype(str))})

    if "Age Days" in col_map and col_map["Age Days"] in df.columns:
        col = col_map["Age Days"]; orig = df[col].copy()
        df[col] = parse_age_days_vec(df[col])
        bad = orig.notna() & orig.astype(str).str.strip().ne('') & df[col].isna()
        if bad.sum():
            violations.append({"Column":col,"Expected Type":"numeric",
                "Violation Count":int(bad.sum()),
                "Sample Values":", ".join(orig[bad].head(3).astype(str))})

    if "Date" in col_map and col_map["Date"] in df.columns:
        df[col_map["Date"]] = pd.to_datetime(df[col_map["Date"]], errors="coerce")

    if "Period" in col_map and col_map["Period"] in df.columns:
        col = col_map["Period"]
        df["_Period_date"]  = period_to_datetime_vec(df[col])
        df["_Period_label"] = df["_Period_date"].dt.strftime("%Y-%m").fillna(df[col].astype(str))

    if "Date" in col_map and "_Period_date" in df.columns:
        date_col = col_map["Date"]
        df["_Computed_Age_Days"] = (df["_Period_date"] - df[date_col]).dt.days
        df["_Computed_Bucket"]   = age_to_bucket_vec(df["_Computed_Age_Days"])
        if "Age Days" in col_map:
            df["_Age_Match"] = np.isclose(
                df[col_map["Age Days"]].fillna(-999),
                df["_Computed_Age_Days"].fillna(-998), atol=1)
        if "Bucket" in col_map:
            df["_Bucket_Match"] = (
                df[col_map["Bucket"]].astype(str).str.strip() ==
                df["_Computed_Bucket"].astype(str).str.strip())

    df["_False_Positive"] = False

    filter_options = {}
    for key in ["Period","Team","Rec Name (as per Rec Cube)","Entity",
                "Asset Class","Type of break","True/Systemic Breaks"]:
        if key in col_map and col_map[key] in df.columns:
            filter_options[key] = sorted(df[col_map[key]].dropna().unique().tolist())

    vdf = pd.DataFrame(violations) if violations else \
          pd.DataFrame(columns=["Column","Expected Type","Violation Count","Sample Values"])

    return df, col_map, filter_options, vdf, dropped_cols


# ─────────────────────────── Global Filters via DuckDB ───────────────────────────

def apply_global_filters(df: pd.DataFrame, col_map: dict,
                         filter_options: dict) -> pd.DataFrame:
    st.sidebar.markdown("---")
    st.sidebar.markdown("### 🔍 Global Filters")

    selections = {}
    for key, label, wkey in [
        ("Period",                     "Period",        "f_period"),
        ("Team",                       "Team",          "f_team"),
        ("Rec Name (as per Rec Cube)", "Rec Name",      "f_rec"),
        ("Entity",                     "Entity",        "f_entity"),
        ("Asset Class",                "Asset Class",   "f_ac"),
        ("Type of break",              "Type of Break", "f_tob"),
        ("True/Systemic Breaks",       "True/Systemic", "f_ts"),
    ]:
        if key not in filter_options: continue
        opts = filter_options[key]
        sel  = st.sidebar.multiselect(label, opts, default=opts, key=wkey)
        if sel and len(sel) < len(opts):
            selections[key] = sel

    abs_col = col_map.get("ABS GBP") or col_map.get("BREAK AMOUNT GBP")
    if abs_col and abs_col in df.columns:
        max_val = float(df[abs_col].abs().max() or 1_000_000)
        abs_threshold = st.sidebar.number_input(
            "Min ABS GBP Threshold (£)",
            min_value=0.0, max_value=float(min(max_val, 100_000_000)),
            value=0.0, step=1000.0, format="%.0f", key="f_abs_threshold",
        )
        if abs_threshold > 0:
            selections["_ABS_THRESHOLD"] = (abs_col, abs_threshold)

    exclude_fp = st.sidebar.checkbox(
        "Exclude False Positives", value=False, key="f_excl_fp")

    if not selections and not exclude_fp:
        return df

    where_parts = []
    for key, vals in selections.items():
        if key == "_ABS_THRESHOLD":
            col_name, thresh = vals
            where_parts.append(f'ABS("{col_name}") >= {thresh}')
        else:
            col = col_map[key]
            escaped = [str(v).replace("'", "''") for v in vals]
            in_list = ", ".join(f"'{v}'" for v in escaped)
            where_parts.append(f'"{col}" IN ({in_list})')

    if exclude_fp:
        where_parts.append('_False_Positive = false')

    return dq(f"SELECT * FROM tbl WHERE {' AND '.join(where_parts)}", df)


# ─────────────────────────── Tab 1: Data Quality ───────────────────────────

def tab_data_quality(df: pd.DataFrame, col_map: dict, violations_df: pd.DataFrame,
                     file_bytes: bytes, filename: str, dropped_cols: list):
    st.markdown("## Data Quality & Ingestion Scorecard")

    vcount = int(violations_df["Violation Count"].sum()) if len(violations_df) else 0
    if vcount > 0:
        st.markdown(
            f'<div class="violation-banner">⚠️ {format_number(vcount)} type violations '
            f'across {len(violations_df)} column(s). Review below.</div>',
            unsafe_allow_html=True)

    if dropped_cols:
        st.markdown(
            f'<div class="fp-banner">🗑️ <b>Auto-removed {len(dropped_cols)} blank trailing '
            f'column(s):</b> {", ".join(dropped_cols)}</div>',
            unsafe_allow_html=True)

    n_rows = len(df); n_cols = len(df.columns)
    cells  = n_rows * n_cols
    completeness = round(df.notna().sum().sum() / cells * 100, 1) if cells else 0

    c1,c2,c3,c4 = st.columns(4)
    with c1: kpi_card("Total Records",   format_number(n_rows))
    with c2: kpi_card("Columns",         str(n_cols))
    with c3: kpi_card("Completeness",    f"{completeness}%")
    with c4: kpi_card("Type Violations", format_number(vcount), warn=(vcount > 0), invert=True)

    st.markdown("---")
    cl, cr = st.columns(2)

    with cl:
        st.markdown("### Column Completeness")
        exprs = ", ".join(
            f'ROUND(100.0 * COUNT("{c}") / COUNT(*), 1) AS "{c}"'
            for c in df.columns
        )
        comp = dq(f"SELECT {exprs} FROM tbl", df).T.reset_index()
        comp.columns = ["Column","Completeness %"]
        comp = comp.sort_values("Completeness %", ascending=True)
        fig = px.bar(comp, x="Completeness %", y="Column",
                     orientation="h", color_discrete_sequence=[PRIMARY])
        fig = chart_layout(fig,"Per-Column Completeness (%)","Completeness %",
                           height=max(350, n_cols*18))
        fig.update_layout(yaxis=dict(tickfont=dict(size=9)))
        st.plotly_chart(fig, use_container_width=True)

    with cr:
        st.markdown("### ⚠️ Type Violation Details")
        if len(violations_df):
            render_aggrid(violations_df, height=220, key="tv_grid")
        else:
            st.success("✅ No type violations detected.")

        st.markdown("### Outlier Detection (IQR)")
        out_frames = []
        for key in ["BREAK AMOUNT CCY","BREAK AMOUNT GBP","ABS GBP","Age Days"]:
            if key in col_map and col_map[key] in df.columns:
                col = col_map[key]
                if df[col].dtype in [np.float64, np.int64, float, int]:
                    o = detect_outliers_iqr(df[col], col)
                    if len(o): out_frames.append(o)
        if out_frames:
            render_aggrid(pd.concat(out_frames, ignore_index=True), height=200, key="ol_grid")
        else:
            st.info("No outliers detected.")

    st.markdown("### Numeric Summary Statistics")
    num_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    if num_cols:
        render_aggrid(
            df[num_cols].describe().T.round(2).reset_index().rename(columns={"index":"Column"}),
            height=300, key="sum_grid")
    else:
        st.info("No numeric columns found.")

    st.markdown("---")
    buf = BytesIO(); df.to_parquet(buf, index=False, compression="zstd")
    dl1, dl2 = st.columns(2)
    with dl1:
        st.download_button("📥 Download Cleaned CSV",
            df.to_csv(index=False).encode("utf-8"),
            file_name="cleaned_data.csv", mime="text/csv")
    with dl2:
        st.download_button("⚡ Download Cleaned Parquet (fast future uploads)",
            buf.getvalue(), file_name="cleaned_data.parquet",
            mime="application/octet-stream")


# ─────────────────────────── Tab 2: Ageing Validation ───────────────────────────

def tab_ageing_validation(df: pd.DataFrame, col_map: dict):
    st.markdown("## Ageing Validation")

    age_col    = col_map.get("Age Days")
    bucket_col = col_map.get("Bucket")
    team_col   = col_map.get("Team")
    rec_col    = col_map.get("Rec Name (as per Rec Cube)")

    if not all(c in df.columns for c in
               ["_Computed_Age_Days","_Computed_Bucket","_Age_Match","_Bucket_Match"]):
        st.warning("Period and Date columns required for ageing validation.")
        return

    kpi = dq(f"""
        SELECT
            COUNT(*) FILTER (WHERE _Computed_Age_Days IS NOT NULL
                             AND "{age_col}" IS NOT NULL)        AS total_valid,
            COUNT(*) FILTER (WHERE _Age_Match=false
                             AND _Computed_Age_Days IS NOT NULL) AS age_mis,
            COUNT(*) FILTER (WHERE _Bucket_Match=false
                             AND _Computed_Age_Days IS NOT NULL) AS bucket_mis
        FROM tbl
    """, df).iloc[0]

    total_valid = int(kpi["total_valid"])
    age_mis     = int(kpi["age_mis"])
    bucket_mis  = int(kpi["bucket_mis"])
    age_pct     = round(age_mis    / total_valid * 100, 1) if total_valid else 0
    bucket_pct  = round(bucket_mis / total_valid * 100, 1) if total_valid else 0

    c1,c2,c3,c4 = st.columns(4)
    with c1: kpi_card("Records Validated",    format_number(total_valid))
    with c2: kpi_card("Age Discrepancies",    f"{format_number(age_mis)} ({age_pct}%)",
                      warn=(age_pct > 5), invert=True)
    with c3: kpi_card("Bucket Discrepancies", f"{format_number(bucket_mis)} ({bucket_pct}%)",
                      warn=(bucket_pct > 5), invert=True)
    with c4: kpi_card("Accuracy Rate",        f"{round(100-max(age_pct,bucket_pct),1)}%")

    st.markdown("---")
    st.markdown("### Discrepancy Records — Flag False Positives")
    st.markdown(
        '<div class="fp-banner">💡 <b>False Positive Flagging:</b> Mark records as false '
        'positives to exclude them from outstanding count. Use sidebar toggle to apply globally.</div>',
        unsafe_allow_html=True)

    sel_cols_sql = ", ".join(
        f'"{col_map[k]}"' for k in
        ["Period","Team","Rec Name (as per Rec Cube)","Entity","Date"]
        if k in col_map and col_map[k] in df.columns
    )
    disc_df = dq(f"""
        SELECT {sel_cols_sql},
               "{age_col}"        AS "Age Days (Source)",
               _Computed_Age_Days AS "Age Days (Computed)",
               "{bucket_col}"     AS "Bucket (Source)",
               _Computed_Bucket   AS "Bucket (Computed)",
               _Age_Match         AS "Age Match",
               _Bucket_Match      AS "Bucket Match",
               _False_Positive    AS "False Positive"
        FROM tbl
        WHERE (_Age_Match=false OR _Bucket_Match=false)
          AND _Computed_Age_Days IS NOT NULL
        ORDER BY _Computed_Age_Days DESC
        LIMIT 500
    """, df)

    if len(disc_df) > 0:
        fp_edited = st.data_editor(
            disc_df,
            column_config={
                "False Positive": st.column_config.CheckboxColumn(
                    "False Positive?", default=False),
                "Age Match":    st.column_config.CheckboxColumn("Age Match"),
                "Bucket Match": st.column_config.CheckboxColumn("Bucket Match"),
            },
            use_container_width=True, height=420,
            num_rows="fixed", key="fp_editor",
        )
        fp_count = int(fp_edited["False Positive"].sum())
        net_outstanding = len(disc_df) - fp_count
        fc1, fc2, fc3 = st.columns(3)
        with fc1: kpi_card("Total Discrepancies",   format_number(len(disc_df)))
        with fc2: kpi_card("Flagged False Positive", format_number(fp_count))
        with fc3: kpi_card("Net Outstanding",        format_number(net_outstanding),
                           warn=(net_outstanding > 0))
    else:
        st.success("✅ No discrepancies found!")
        disc_df = pd.DataFrame()

    st.markdown("---")
    cl, cr = st.columns(2)

    with cl:
        hist = dq(f"""
            SELECT "{age_col}" AS prepop, _Computed_Age_Days AS computed
            FROM tbl WHERE _Computed_Age_Days IS NOT NULL AND "{age_col}" IS NOT NULL
        """, df)
        fig = go.Figure()
        fig.add_trace(go.Histogram(x=hist["prepop"],   name="Pre-populated",
                                   opacity=0.6, marker_color=COLORS[0], nbinsx=50))
        fig.add_trace(go.Histogram(x=hist["computed"], name="Computed",
                                   opacity=0.6, marker_color=COLORS[4], nbinsx=50))
        fig.update_layout(barmode="overlay")
        fig = chart_layout(fig,"Age Days: Computed vs Pre-populated","Age Days","Count")
        st.plotly_chart(fig, use_container_width=True)

    with cr:
        bkt = dq("""
            SELECT _Computed_Bucket AS bucket, COUNT(*) AS computed FROM tbl
            WHERE _Computed_Age_Days IS NOT NULL GROUP BY _Computed_Bucket
        """, df)
        pre = dq(f"""
            SELECT "{bucket_col}" AS bucket, COUNT(*) AS prepop FROM tbl
            GROUP BY "{bucket_col}"
        """, df)
        merged = bkt.merge(pre, on="bucket", how="outer").fillna(0)
        merged["bucket"] = pd.Categorical(merged["bucket"],
                           categories=BUCKET_ORDER, ordered=True)
        merged = merged.sort_values("bucket")
        fig = go.Figure()
        fig.add_trace(go.Bar(x=merged["bucket"], y=merged["prepop"],
