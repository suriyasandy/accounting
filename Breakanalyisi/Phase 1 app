    with tab1: tab_data_quality(df_filtered, col_map, type_violations_df)
    with tab2: tab_ageing_validation(df_filtered, col_map)
    with tab3: tab_break_counts(df_filtered, col_map)
    with tab4: tab_amount_analysis(df_filtered, col_map)


if __name__ == "__main__":
    main()
