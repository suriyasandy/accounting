        risk_df[">90 %"]  = (risk_df["over90"]  / risk_df["total"] * 100).round(1)
        risk_df[">365 %"] = (risk_df["over365"] / risk_df["total"] * 100).round(1)
        fig = go.Figure()
        fig.add_trace(go.Scatter(x=risk_df["period"], y=risk_df[">90 %"], name="> 90 Days",
                                 mode="lines+markers", line=dict(color=COLORS[4], width=2),
                                 fill="tozeroy", fillcolor="rgba(168,75,47,0.15)"))
        fig.add_trace(go.Scatter(x=risk_df["period"], y=risk_df[">365 %"], name="> 365 Days",
