                    "Count Classification", "Latest Amount", "Median Amount",
                    "Upper Amount Threshold", "Amount Classification",
                    "Classification", "Deviation %", "Periods"]

display_alert = (alert_df[[c for c in display_cols if c in alert_df.columns]]
                 .sort_values("Deviation %" if "Deviation %" in display_cols else display_cols[-2],
                              ascending=False, na_position="last").reset_index(drop=True))

amt_js_formatter = JsCode("""
function(params) {
    var v = Math.abs(params.value);
    var sign = params.value < 0 ? '-' : '';
    if (v >= 1e9) return sign + '\u00a3' + (v/1e9).toFixed(1) + 'B';
    if (v >= 1e6) return sign + '\u00a3' + (v/1e6).toFixed(1) + 'M';
    if (v >= 1e3) return sign + '\u00a3' + (v/1e3).toFixed(1) + 'K';
    return sign + '\u00a3' + Math.round(v).toLocaleString();
}""") if HAS_AGGRID else None

if HAS_AGGRID and len(display_alert) > 0:
    gb = GridOptionsBuilder.from_dataframe(display_alert)
    gb.configure_pagination(paginationAutoPageSize=False, paginationPageSize=20)
    gb.configure_default_column(filterable=True, sortable=True, resizable=True)
