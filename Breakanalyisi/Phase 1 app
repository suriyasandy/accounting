def build_column_mapping(uploaded_cols):
    """Build a mapping from expected to actual column names."""
    mapping = {}
    for expected in EXPECTED_COLUMNS:
        match = fuzzy_col_match(uploaded_cols, expected)
        if match:
            mapping[expected] = match
    return mapping


