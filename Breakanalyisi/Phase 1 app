def tab_break_amounts(df, col_map):
    """Render Trend Analysis - Break Amounts tab."""
    st.markdown("## Trend Analysis: Break Amounts (GBP)")

    period_col = col_map.get("Period")
    team_col = col_map.get("Team")
    rec_col = col_map.get("Rec Name (as per Rec Cube)")
    ac_col = col_map.get("Asset Class")
    gbp_col = col_map.get("BREAK AMOUNT GBP")
    abs_col = col_map.get("ABS GBP")

    amt_col = abs_col if (abs_col and abs_col in df.columns) else gbp_col
    if not amt_col or amt_col not in df.columns:
        st.warning("Break Amount GBP / ABS GBP column not found.")
        return
    if not period_col or period_col not in df.columns:
        st.warning("Period column not found.")
        return

    periods_sorted = sorted(df[period_col].dropna().unique())

    # Period-level aggregation
    period_amt = df.groupby(period_col)[amt_col].sum().reset_index(name="Total Amount")
    period_amt = period_amt.sort_values(period_col)
    period_amt["Period Label"] = period_amt[period_col].apply(
        lambda x: period_to_datetime_scalar(x).strftime("%Y-%m") if pd.notna(period_to_datetime_scalar(x)) else str(x))

    total_amount = df[amt_col].sum()
    latest_period = periods_sorted[-1] if periods_sorted else None
    prev_period = periods_sorted[-2] if len(periods_sorted) >= 2 else None
    latest_amt = float(period_amt[period_amt[period_col] == latest_period]["Total Amount"].sum()) if latest_period else 0
    prev_amt = float(period_amt[period_amt[period_col] == prev_period]["Total Amount"].sum()) if prev_period else 0
    mom_pct = safe_mom_pct(latest_amt, prev_amt)
    avg_per_period = total_amount / len(periods_sorted) if periods_sorted else 0
    max_single = df[amt_col].max()

    c1, c2, c3, c4 = st.columns(4)
    with c1:
        kpi_card("Total Break Amount GBP", format_short(total_amount))
    with c2:
        delta_str = f"{'+'if mom_pct and mom_pct > 0 else ''}{mom_pct}% MoM" if mom_pct is not None else "N/A"
        kpi_card("MoM Change", format_short(latest_amt), delta_str, invert=True)
    with c3:
        kpi_card("Avg Amount/Period", format_short(avg_per_period))
    with c4:
        kpi_card("Max Single Break", format_short(max_single))

    st.markdown("---")

    # Chart 1: Total break amount by Period (bar + line)
    col_a, col_b = st.columns(2)
    with col_a:
        fig = go.Figure()
        fig.add_trace(go.Bar(x=period_amt["Period Label"], y=period_amt["Total Amount"],
                             name="Amount", marker_color=COLORS[0], opacity=0.8))
        fig.add_trace(go.Scatter(x=period_amt["Period Label"], y=period_amt["Total Amount"],
                                 name="Trend", line=dict(color=COLORS[4], width=2), mode="lines+markers"))
        fig = chart_layout(fig, "Break Amount (GBP) Trend by Period", "Period", "Amount (GBP)")
        st.plotly_chart(fig, use_container_width=True)

    # Chart 2: By Team
    with col_b:
        if team_col and team_col in df.columns:
            team_amt = df.groupby([team_col, "_Period_label"])[amt_col].sum().reset_index(name="Amount")
            fig = px.bar(team_amt, x="_Period_label", y="Amount", color=team_col,
                         color_discrete_sequence=COLORS, barmode="group")
            fig = chart_layout(fig, "Break Amount by Team Over Periods", "Period", "Amount (GBP)")
            st.plotly_chart(fig, use_container_width=True)

    col_c, col_d = st.columns(2)

    # Chart 3: By Rec Name top 10
    with col_c:
        if rec_col and rec_col in df.columns:
            rec_totals = df.groupby(rec_col)[amt_col].sum().abs()
            top_recs = rec_totals.nlargest(10).index.tolist()
