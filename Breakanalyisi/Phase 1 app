        show_cols = [col_map[k] for k in show_cols_keys if k in col_map and col_map[k] in top_breaks.columns]
        show_cols.append(amt_col)
        render_aggrid(top_breaks[show_cols].reset_index(drop=True), height=350, key="top_breaks_grid")

    # Download
    st.markdown("---")
    st.download_button(
        "📥 Download Filtered Data (CSV)",
        df.to_csv(index=False).encode("utf-8"),
        file_name="break_amounts_filtered.csv",
        mime="text/csv",
    )


# ─────────────────────────── Tab 5: Drill-Down ───────────────────────────

def tab_drill_down(df, col_map):
    """Render Detailed Drill-Down tab."""
    st.markdown("## Detailed Drill-Down Analysis")

    period_col = col_map.get("Period")
    team_col = col_map.get("Team")
    rec_col = col_map.get("Rec Name (as per Rec Cube)")
    entity_col = col_map.get("Entity")
    product_col = col_map.get("Products Reconciled")
    gbp_col = col_map.get("BREAK AMOUNT GBP")
    abs_col = col_map.get("ABS GBP")

    amt_col = abs_col if (abs_col and abs_col in df.columns) else gbp_col

    # Hierarchical selection
    col_sel1, col_sel2, col_sel3, col_sel4 = st.columns(4)

    with col_sel1:
        teams = ["All"] + sorted(df[team_col].dropna().unique().tolist()) if team_col and team_col in df.columns else ["All"]
        sel_team = st.selectbox("Select Team", teams, key="dd_team")

    filtered = df.copy()
    if sel_team != "All" and team_col:
        filtered = filtered[filtered[team_col] == sel_team]

    with col_sel2:
        recs = ["All"] + sorted(filtered[rec_col].dropna().unique().tolist()) if rec_col and rec_col in filtered.columns else ["All"]
        sel_rec = st.selectbox("Select Rec Name", recs, key="dd_rec")

    if sel_rec != "All" and rec_col:
        filtered = filtered[filtered[rec_col] == sel_rec]

    with col_sel3:
        entities = ["All"] + sorted(filtered[entity_col].dropna().unique().tolist()) if entity_col and entity_col in filtered.columns else ["All"]
        sel_entity = st.selectbox("Select Entity", entities, key="dd_entity")

    if sel_entity != "All" and entity_col:
        filtered = filtered[filtered[entity_col] == sel_entity]

    with col_sel4:
        products = ["All"] + sorted(filtered[product_col].dropna().unique().tolist()) if product_col and product_col in filtered.columns else ["All"]
        sel_product = st.selectbox("Select Product", products, key="dd_product")

    if sel_product != "All" and product_col:
        filtered = filtered[filtered[product_col] == sel_product]

    st.markdown("---")

    if len(filtered) == 0:
        st.info("No data matching the selected filters.")
        return

    # KPIs for drill-down level
    c1, c2, c3, c4 = st.columns(4)
    with c1:
        kpi_card("Filtered Records", format_number(len(filtered)))
    with c2:
        if amt_col and amt_col in filtered.columns:
            kpi_card("Total Amount GBP", format_number(filtered[amt_col].sum(), "£", 0))
        else:
            kpi_card("Total Amount GBP", "N/A")
    with c3:
        if period_col and period_col in filtered.columns:
            kpi_card("Periods", str(filtered[period_col].nunique()))
        else:
            kpi_card("Periods", "N/A")
    with c4:
        if rec_col and rec_col in filtered.columns:
            kpi_card("Unique Recs", str(filtered[rec_col].nunique()))
        else:
            kpi_card("Unique Recs", "N/A")

    st.markdown("---")

    # Trend charts
    if period_col and period_col in filtered.columns and "_Period_label" in filtered.columns:
        col_left, col_right = st.columns(2)

        with col_left:
            count_trend = filtered.groupby("_Period_label").size().reset_index(name="Break Count")
            fig = go.Figure()
            fig.add_trace(go.Bar(x=count_trend["_Period_label"], y=count_trend["Break Count"],
                                 marker_color=COLORS[0], opacity=0.8, name="Count"))
            fig.add_trace(go.Scatter(x=count_trend["_Period_label"], y=count_trend["Break Count"],
                                     line=dict(color=COLORS[4], width=2), mode="lines+markers", name="Trend"))
            fig = chart_layout(fig, "Break Count Trend (Filtered)", "Period", "Count")
            st.plotly_chart(fig, use_container_width=True)

        with col_right:
            if amt_col and amt_col in filtered.columns:
                amt_trend = filtered.groupby("_Period_label")[amt_col].sum().reset_index(name="Amount")
                fig = go.Figure()
                fig.add_trace(go.Bar(x=amt_trend["_Period_label"], y=amt_trend["Amount"],
                                     marker_color=COLORS[0], opacity=0.8, name="Amount"))
                fig.add_trace(go.Scatter(x=amt_trend["_Period_label"], y=amt_trend["Amount"],
                                         line=dict(color=COLORS[4], width=2), mode="lines+markers", name="Trend"))
                fig = chart_layout(fig, "Break Amount (GBP) Trend (Filtered)", "Period", "Amount (GBP)")
                st.plotly_chart(fig, use_container_width=True)

        # MoM comparison table
        st.markdown("### Period-over-Period Comparison")
        periods_sorted = sorted(filtered["_Period_label"].dropna().unique())
        mom_data = []
        for pl in periods_sorted:
            p_df = filtered[filtered["_Period_label"] == pl]
            count = len(p_df)
            amount = p_df[amt_col].sum() if amt_col and amt_col in p_df.columns else 0
            mom_data.append({"Period": pl, "Break Count": count, "Total Amount GBP": round(amount, 2)})

        mom_df = pd.DataFrame(mom_data)
        if len(mom_df) > 1:
            mom_df["Count MoM %"] = mom_df["Break Count"].pct_change().mul(100).round(1)
            mom_df["Amount MoM %"] = mom_df["Total Amount GBP"].pct_change().mul(100).round(1)
        else:
            mom_df["Count MoM %"] = np.nan
            mom_df["Amount MoM %"] = np.nan
        mom_df["Total Amount GBP"] = mom_df["Total Amount GBP"].apply(lambda x: f"£{x:,.0f}")
        render_aggrid(mom_df, height=250, key="mom_grid")

    # Full data table
    st.markdown("### Full Data (Filtered)")
    display_cols = [col_map[k] for k in [
        "Period", "Team", "Rec Name (as per Rec Cube)", "Entity", "Products Reconciled",
        "Type of break", "TRADE REF", "BREAK AMOUNT GBP", "ABS GBP", "Age Days", "Bucket",
        "True/Systemic Breaks", "Comments"
    ] if k in col_map and col_map[k] in filtered.columns]
    if display_cols:
        render_aggrid(filtered[display_cols].head(1000).reset_index(drop=True), height=400, key="dd_data_grid")

    # Download
    st.download_button(
        "📥 Download Drill-Down Data (CSV)",
        filtered.to_csv(index=False).encode("utf-8"),
        file_name="drill_down_data.csv",
        mime="text/csv",
    )


