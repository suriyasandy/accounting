def safe_mom_pct(current, previous):
    """Compute MoM percentage safely."""
    if previous is None or previous == 0:
        return None
    return round(((current - previous) / abs(previous)) * 100, 1)


def format_number(n, prefix="", decimal=0):
    """Format number with commas."""
    if pd.isna(n):
        return "N/A"
    if decimal > 0:
        return f"{prefix}{n:,.{decimal}f}"
    return f"{prefix}{int(n):,}"


def format_short(n, prefix="£"):
    """Format number in human-readable short form: £1.2M, £45.3K, etc."""
    if pd.isna(n):
        return "N/A"
    v = float(n)
    sign = "-" if v < 0 else ""
    v = abs(v)
    if v >= 1_000_000_000:
        return f"{sign}{prefix}{v / 1_000_000_000:.1f}B"
    if v >= 1_000_000:
        return f"{sign}{prefix}{v / 1_000_000:.1f}M"
    if v >= 1_000:
        return f"{sign}{prefix}{v / 1_000:.1f}K"
    return f"{sign}{prefix}{v:,.0f}"


# ───── VECTORISED: period_to_datetime ─────
def period_to_datetime_scalar(period_val):
    """Convert int period like 202501 to datetime (last day of month). Scalar version for fallback."""
    try:
        p = int(period_val)
        year = p // 100
        month = p % 100
        if month < 1 or month > 12:
            return pd.NaT
        if month == 12:
            return pd.Timestamp(year + 1, 1, 1) - pd.Timedelta(days=1)
        return pd.Timestamp(year, month + 1, 1) - pd.Timedelta(days=1)
    except (ValueError, TypeError):
        return pd.NaT


def period_to_datetime_vec(series):
    """Vectorised period→last-day-of-month conversion. 100x faster than .apply()."""
    s = pd.to_numeric(series, errors="coerce")
    year = (s // 100).astype("Int64")
    month = (s % 100).astype("Int64")
    # Mask invalid months
    valid = month.between(1, 12) & year.notna()
    # Next month's first day, then subtract 1 day
    next_month = month.where(valid) + 1
    next_year = year.where(valid)
    # Handle December → January rollover
    dec_mask = month == 12
    next_month = next_month.where(~dec_mask, 1)
    next_year = next_year.where(~dec_mask, year + 1)
    # Build date strings for valid rows only, then parse
    result = pd.Series(pd.NaT, index=series.index, dtype="datetime64[ns]")
    valid_idx = valid[valid].index
    if len(valid_idx) > 0:
        date_str = (next_year.loc[valid_idx].astype(str) + "-" +
                    next_month.loc[valid_idx].astype(str).str.zfill(2) + "-01")
        result.loc[valid_idx] = pd.to_datetime(date_str, errors="coerce") - pd.Timedelta(days=1)
    return result


# ───── VECTORISED: parse_amount ─────
def parse_amount_vec(series):
    """Vectorised amount parser. Handles currency symbols, codes, commas."""
    s = series.astype(str).str.strip()
    # Remove currency symbols
    s = s.str.replace(r'[£$€¥,]', '', regex=True)
    # Remove currency codes at start
    s = s.str.replace(r'^(GBP|USD|EUR|JPY|CHF|AUD|CAD)\s*', '', regex=True, case=False)
    s = s.str.strip()
    result = pd.to_numeric(s, errors="coerce")
    # Preserve original NaN
    result[series.isna()] = np.nan
    return result


# ───── VECTORISED: parse_age_days ─────
def parse_age_days_vec(series):
    """Vectorised age-days parser. Extracts leading integer."""
    s = series.astype(str).str.strip()
    # Extract leading number (optionally preceded by ~)
    extracted = s.str.extract(r'^[~]?(-?\d+)', expand=False)
    result = pd.to_numeric(extracted, errors="coerce")
    # Mark known NaN patterns
    na_mask = series.isna() | s.isin(['', 'N/A', 'n/a', '-', 'nan', 'None'])
    result[na_mask] = np.nan
    return result


# ───── VECTORISED: age_to_bucket ─────
def age_to_bucket_vec(age_series):
    """Vectorised bucket derivation using np.select (100x faster than .apply())."""
    a = age_series.values  # numpy array for speed
    conditions = [
        pd.isna(age_series),
        a <= 15,
        a <= 30,
        a <= 60,
        a <= 90,
        a <= 180,
        a <= 365,
    ]
    choices = ["Unknown", "0-15", "16-30", "31-60", "61-90", "91-180", "181-365"]
    return pd.Categorical(
        np.select(conditions, choices, default="365+"),
        categories=BUCKET_ORDER, ordered=True,
    )


BUCKET_ORDER = ["0-15", "16-30", "31-60", "61-90", "91-180", "181-365", "365+", "Unknown"]


def fuzzy_col_match(uploaded_cols, target):
    """Find best matching column name (case-insensitive, stripped)."""
    target_lower = target.lower().strip()
    for c in uploaded_cols:
        if c.lower().strip() == target_lower:
            return c
    # Partial match
    for c in uploaded_cols:
        if target_lower in c.lower().strip() or c.lower().strip() in target_lower:
            return c
    return None


