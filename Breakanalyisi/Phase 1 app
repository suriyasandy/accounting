# ─────────────────────────── Tab 4: Amount Analysis ───────────────────────────

def tab_amount_analysis(df: pd.DataFrame, col_map: dict):
    st.markdown("## Trend Analysis: Break Amounts")

    period_col = col_map.get("Period")
    abs_col    = col_map.get("ABS GBP")
    gbp_col    = col_map.get("BREAK AMOUNT GBP")
    team_col   = col_map.get("Team")
    ts_col     = col_map.get("True/Systemic Breaks")
    rec_col    = col_map.get("Rec Name (as per Rec Cube)")

    if not period_col or period_col not in df.columns:
        st.warning("Period column not found."); return

    amount_col = abs_col if abs_col and abs_col in df.columns else gbp_col
    if not amount_col or amount_col not in df.columns:
        st.warning("No ABS GBP or BREAK AMOUNT GBP column found."); return

    st.sidebar.markdown("---")
    max_abs   = float(df[amount_col].abs().max() or 1_000_000)
    threshold = st.sidebar.slider(
        "Min ABS GBP Threshold", min_value=0.0,
        max_value=float(min(max_abs,50_000_000)),
        value=0.0, step=10_000.0, format="£%,.0f", key="abs_threshold",
    )

    # Apply threshold via DuckDB
    amt_df = dq(f'SELECT * FROM tbl WHERE ABS("{amount_col}") >= {threshold}', df) \
             if threshold > 0 else df

    period_order = sorted(amt_df["_Period_label"].dropna().unique().tolist())
    latest = period_order[-1] if period_order else "0"
    prev   = period_order[-2] if len(period_order) >= 2 else "0"

    kpi = dq(f"""
        SELECT SUM(ABS("{amount_col}")) AS total_abs,
               AVG(ABS("{amount_col}")) AS avg_abs,
               MAX(ABS("{amount_col}")) AS max_abs,
               SUM(ABS("{amount_col}")) FILTER (WHERE _Period_label='{latest}') AS lat_sum,
               SUM(ABS("{amount_col}")) FILTER (WHERE _Period_label='{prev}')   AS prv_sum
        FROM tbl
    """, amt_df).iloc[0]

    mom = safe_mom_pct(float(kpi["lat_sum"] or 0), float(kpi["prv_sum"] or 0))
    c1,c2,c3,c4 = st.columns(4)
    with c1: kpi_card("Total ABS GBP",    format_short(kpi["total_abs"]))
    with c2: kpi_card("Latest Period",     format_short(kpi["lat_sum"]),
                      f"{'+'if mom and mom>0 else ''}{mom}% MoM" if mom else "N/A", invert=True)
    with c3: kpi_card("Avg Break Amount", format_short(kpi["avg_abs"]))
    with c4: kpi_card("Max Single Break", format_short(kpi["max_abs"]))

    st.markdown("---")
    ca, cb = st.columns(2)

    with ca:
        p_df = dq(f'SELECT _Period_label AS period, SUM(ABS("{amount_col}")) AS total FROM tbl GROUP BY _Period_label ORDER BY _Period_label', amt_df)
        p_df["label"] = p_df["total"].apply(format_short)
        fig = go.Figure()
        fig.add_trace(go.Bar(x=p_df["period"],y=p_df["total"],name="Total ABS GBP",
                             marker_color=COLORS[0],text=p_df["label"],textposition="outside"))
        fig = chart_layout(fig,"Total ABS GBP by Period","Period","GBP (£)")
        st.plotly_chart(fig, use_container_width=True)

    with cb:
        if team_col and team_col in amt_df.columns:
            t_df = dq(f'SELECT "{team_col}" AS team, _Period_label AS period, SUM(ABS("{amount_col}")) AS total FROM tbl GROUP BY "{team_col}", _Period_label ORDER BY _Period_label', amt_df)
            fig  = px.bar(t_df,x="period",y="total",color="team",
                          color_discrete_sequence=COLORS,barmode="group")
            fig  = chart_layout(fig,"ABS GBP by Team","Period","GBP (£)")
            st.plotly_chart(fig, use_container_width=True)

    cc, cd = st.columns(2)
    with cc:
        if ts_col and ts_col in amt_df.columns:
            ts_df = dq(f'SELECT "{ts_col}" AS ts, _Period_label AS period, SUM(ABS("{amount_col}")) AS total FROM tbl GROUP BY "{ts_col}", _Period_label ORDER BY _Period_label', amt_df)
            fig   = px.bar(ts_df,x="period",y="total",color="ts",
                           color_discrete_sequence=COLORS,barmode="stack")
            fig   = chart_layout(fig,"ABS GBP: True vs Systemic","Period","GBP (£)")
            st.plotly_chart(fig, use_container_width=True)

    with cd:
        if rec_col and rec_col in amt_df.columns:
            r_df = dq(f'SELECT "{rec_col}" AS rec, SUM(ABS("{amount_col}")) AS total FROM tbl GROUP BY "{rec_col}" ORDER BY total DESC LIMIT 10', amt_df)
            r_df = r_df.sort_values("total",ascending=True)
            r_df["label"] = r_df["total"].apply(format_short)
            fig = px.bar(r_df,x="total",y="rec",orientation="h",
                         color_discrete_sequence=[COLORS[0]])
            fig.update_traces(text=r_df["label"],textposition="outside")
            fig = chart_layout(fig,"Top 10 Rec Names by ABS GBP","GBP (£)","",
                               height=max(300,len(r_df)*30))
            st.plotly_chart(fig, use_container_width=True)

    st.markdown("---")
    dl_cols = [c for c in [period_col,team_col,rec_col,ts_col,amount_col]
               if c and c in amt_df.columns]
    st.download_button("📥 Download Amount Data (CSV)",
        amt_df[dl_cols].to_csv(index=False).encode("utf-8"),
        file_name="amount_analysis.csv", mime="text/csv")


