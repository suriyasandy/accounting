    periods = sorted(df["_Period_label"].drop_nulls().unique().to_list())
    latest, prev = (periods[-1] if periods else None), (periods[-2] if len(periods) >= 2 else None)

    kpi_sql = f"""
        SELECT COUNT(*) AS total,
            COUNT(*) FILTER (WHERE _Period_label = '{latest}') AS latest_count,
            COUNT(*) FILTER (WHERE _Period_label = '{prev}')   AS prev_count,
            COUNT(DISTINCT "{rec_col}") AS unique_recs
        FROM tbl
    """ if rec_col else f"""
        SELECT COUNT(*) AS total,
            COUNT(*) FILTER (WHERE _Period_label = '{latest}') AS latest_count,
            COUNT(*) FILTER (WHERE _Period_label = '{prev}')   AS prev_count,
            0 AS unique_recs
        FROM tbl
    """
    kpi = duck_query(kpi_sql, arrow).iloc[0]
    total    = int(kpi["total"])
    lat_cnt  = int(kpi["latest_count"])
    prv_cnt  = int(kpi["prev_count"])
    u_recs   = int(kpi["unique_recs"])
