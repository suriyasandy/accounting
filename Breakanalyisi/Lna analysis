def extract_strings(file_path, min_length=6):
    with open(file_path, "rb") as f:
        data = f.read()

    strings = []
    current = ""

    for byte in data:
        if 32 <= byte <= 126:  # printable ASCII
            current += chr(byte)
        else:
            if len(current) >= min_length:
                strings.append(current)
            current = ""

    return strings


lod_file = "extracted_lna/your_file.lod"
strings = extract_strings(lod_file)

# Save for inspection
with open("lod_strings.txt", "w") as f:
    for s in strings:
        f.write(s + "\n")

print("Extracted readable content!")
