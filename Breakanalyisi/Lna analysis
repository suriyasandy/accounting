import xml.dom.minidom

xml_file = "extracted_lna/project.xml"

with open(xml_file, "r", encoding="utf-8") as f:
    xml_content = f.read()

dom = xml.dom.minidom.parseString(xml_content)
pretty_xml = dom.toprettyxml()

with open("formatted.xml", "w", encoding="utf-8") as f:
    f.write(pretty_xml)

print("XML formatted and saved!")
