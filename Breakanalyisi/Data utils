# ──────────────────────────────────────────────────────────
# Column alias normalisation
# ──────────────────────────────────────────────────────────
ALIASES = {
    'Rec Name': 'Rec Name (as per Rec Cube)',
    'Rec Name(as per Rec Cube)': 'Rec Name (as per Rec Cube)',
    'BREAK AMOUNT GBP ': 'BREAK AMOUNT GBP',
    'ABS GBP ': 'ABS GBP',
    'True/Systematic Breaks': 'True/Systemic Breaks'
}


def normalize_columns(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    df.columns = [ALIASES.get(c.strip(), c.strip()) for c in df.columns]
    return df


# ──────────────────────────────────────────────────────────
# Numeric helpers
# ──────────────────────────────────────────────────────────
def safe_to_numeric(series: pd.Series) -> pd.Series:
    """Strip currency symbols, commas, stray text; coerce to float."""
    cleaned = (
        series.astype(str)
        .str.replace(r"[,£$€₹]", "", regex=True)
        .str.replace(r"[^0-9.\-]", "", regex=True)
        .replace({"": np.nan, "nan": np.nan, "None": np.nan})
    )
    return pd.to_numeric(cleaned, errors="coerce")


def safe_binary_normalize(series: pd.Series) -> pd.Series:
    mapping = {
        "true": "TRUE", "systemic": "SYSTEMIC", "systematic": "SYSTEMIC",
        "yes": "TRUE", "no": "SYSTEMIC", "1": "TRUE", "0": "SYSTEMIC",
        "t": "TRUE", "f": "SYSTEMIC", "break": "TRUE",
    }
    s = (
        series.astype(str)
        .str.strip()
        .str.lower()
        .map(mapping)
        .fillna(series.astype(str).str.strip().str.upper())
    )
    return s.replace({"NAN": np.nan, "": np.nan})


