def fuzzy_col_match(cols, target):
    tl = target.lower().strip()
    for c in cols:
        if c.lower().strip() == tl: return c
    for c in cols:
        if tl in c.lower() or c.lower() in tl: return c
    return None

def build_col_map(cols):
    return {exp: m for exp in EXPECTED_COLUMNS if (m := fuzzy_col_match(cols, exp))}


# ─────────────────────────── DuckDB ───────────────────────────

@st.cache_resource
def get_duck() -> duckdb.DuckDBPyConnection:
    return duckdb.connect()

def duck_query(sql: str, arrow_table=None, table_name: str = "tbl") -> pd.DataFrame:
    con = get_duck()
    if arrow_table is not None:
        con.register(table_name, arrow_table)
    return con.execute(sql).df()


# ─────────────────────────── Date Format Sniffer ───────────────────────────

def _try_parse(s: str, fmt: str) -> bool:
    try:
        datetime.strptime(s, fmt)
        return True
    except ValueError:
        return False

def detect_date_format(series: pl.Series) -> str:
    sample = series.drop_nulls().cast(pl.Utf8).head(10).to_list()
    for fmt in ["%Y-%m-%d","%d/%m/%Y","%d-%m-%Y","%m/%d/%Y",
                "%Y%m%d","%d %b %Y","%d-%b-%Y","%Y/%m/%d","%d/%m/%y"]:
        try:
            if all(_try_parse(s.strip(), fmt) for s in sample if s):
                return fmt
        except Exception:
            continue
    return "%Y-%m-%d"


# ─────────────────────────── Auto Parquet Conversion ───────────────────────────

def convert_to_parquet(file_bytes: bytes, filename: str) -> bytes:
    """
    Convert CSV or Excel bytes → Parquet bytes using Polars.
    Result stored in st.session_state keyed by file hash.
    Returns Parquet bytes ready for pl.read_parquet().
    """
    buf = BytesIO(file_bytes)
    name_lower = filename.lower()

    with st.spinner("⚡ Converting to Parquet for faster processing..."):
        if name_lower.endswith(".csv"):
            df = pl.read_csv(buf, infer_schema_length=0, ignore_errors=True)
        elif name_lower.endswith(".parquet"):
            return file_bytes          # already Parquet, no conversion needed
        else:
            try:
                df = pl.read_excel(buf, engine="calamine")
            except Exception:
                buf.seek(0)
                df = pl.read_excel(buf, engine="openpyxl")

    parquet_buf = BytesIO()
    df.write_parquet(parquet_buf, compression="zstd")
    return parquet_buf.getvalue()


def get_parquet_bytes(file_bytes: bytes, filename: str) -> tuple[bytes, bool]:
    """
    Returns (parquet_bytes, was_converted).
    Caches converted Parquet in st.session_state by file hash.
    On re-run with same file, returns cached Parquet instantly.
    """
    fhash = file_hash(file_bytes)
    cache_key = f"parquet_{fhash}"

    # Already converted and cached this session
    if cache_key in st.session_state:
        return st.session_state[cache_key], False

    # First time — convert and cache
    parquet_bytes = convert_to_parquet(file_bytes, filename)
    st.session_state[cache_key] = parquet_bytes

    # Clean up old cached parquet files (keep only latest)
    for key in list(st.session_state.keys()):
        if key.startswith("parquet_") and key != cache_key:
            del st.session_state[key]

    return parquet_bytes, not filename.lower().endswith(".parquet")


# ─────────────────────────── File Loading (always Parquet) ───────────────────────────

@st.cache_resource
def load_parquet(_parquet_bytes: bytes) -> pl.DataFrame:
    """
    Load from Parquet bytes. Always fast (~0.2s for 600K rows).
    Leading _ on param skips st.cache_resource hashing (uses file hash key instead).
    """
    return pl.read_parquet(BytesIO(_parquet_bytes))


# ─────────────────────────── Clean & Process ───────────────────────────

@st.cache_resource
def clean_data(_parquet_bytes: bytes):
    """
    Full Polars LazyFrame cleaning pipeline on Parquet-loaded data.
    Single .collect() at the end — all expressions fused.
    """
    raw     = load_parquet(_parquet_bytes)
    col_map = build_col_map(raw.columns)
    lf      = raw.lazy()

    # ── Pass 1: All amount columns in one with_columns ──
    amount_exprs = []
    for key in ["BREAK AMOUNT CCY", "BREAK AMOUNT GBP", "ABS GBP"]:
        if key not in col_map: continue
        col = col_map[key]
        amount_exprs.append(
            pl.col(col).cast(pl.Utf8)
              .str.strip_chars()
              .str.replace_all(r"[£$€¥,]", "")
              .str.replace_all(r"(?i)^(GBP|USD|EUR|JPY|CHF|AUD|CAD)\s*", "")
              .str.strip_chars()
              .cast(pl.Float64, strict=False)
              .alias(col)
        )
    if amount_exprs:
        lf = lf.with_columns(amount_exprs)

    # ── Pass 2: Age Days ──
    if "Age Days" in col_map:
        col = col_map["Age Days"]
        lf = lf.with_columns(
            pl.col(col).cast(pl.Utf8).str.strip_chars()
              .str.extract(r"^[~]?(-?\d+)", 1)
              .cast(pl.Float64, strict=False)
              .alias(col)
        )

    # ── Pass 3: Date — explicit format ──
    if "Date" in col_map:
        col      = col_map["Date"]
        date_fmt = detect_date_format(raw[col])
        lf = lf.with_columns(
            pl.col(col).cast(pl.Utf8).str.strip_chars()
              .str.to_date(format=date_fmt, strict=False)
              .alias(col)
        )

    # ── Pass 4: Period → last day of month ──
    if "Period" in col_map:
        col = col_map["Period"]
        lf = lf.with_columns(
            pl.col(col).cast(pl.Int64, strict=False).alias(col)
        ).with_columns([
            (pl.col(col) // 100).cast(pl.Int32).alias("_yr"),
            (pl.col(col) % 100).cast(pl.Int32).alias("_mo"),
        ]).with_columns(
            pl.when(pl.col("_mo") == 12)
              .then(pl.date(pl.col("_yr") + 1, 1, 1))
              .otherwise(pl.date(pl.col("_yr"), pl.col("_mo") + 1, 1))
              .dt.offset_by("-1d")
              .alias("_Period_date")
        ).with_columns(
            pl.col("_Period_date").dt.strftime("%Y-%m").alias("_Period_label")
        ).drop(["_yr", "_mo"])

    # ── Pass 5: Computed age days ──
    if "Date" in col_map and "Period" in col_map:
        date_col = col_map["Date"]
        lf = lf.with_columns(
            (pl.col("_Period_date").dt.epoch("d") - pl.col(date_col).dt.epoch("d"))
            .alias("_Computed_Age_Days")
        )

    # ── Pass 6: Bucket + match flags — all in one pass ──
    bucket_exprs = [
        pl.when(pl.col("_Computed_Age_Days").is_null()).then(pl.lit("Unknown"))
        .when(pl.col("_Computed_Age_Days") <= 15).then(pl.lit("0-15"))
        .when(pl.col("_Computed_Age_Days") <= 30).then(pl.lit("16-30"))
        .when(pl.col("_Computed_Age_Days") <= 60).then(pl.lit("31-60"))
        .when(pl.col("_Computed_Age_Days") <= 90).then(pl.lit("61-90"))
        .when(pl.col("_Computed_Age_Days") <= 180).then(pl.lit("91-180"))
        .when(pl.col("_Computed_Age_Days") <= 365).then(pl.lit("181-365"))
        .otherwise(pl.lit("365+"))
        .alias("_Computed_Bucket")
    ]
    if "Age Days" in col_map:
        bucket_exprs.append(
            ((pl.col(col_map["Age Days"]) - pl.col("_Computed_Age_Days")).abs() <= 1)
            .alias("_Age_Match")
        )
    if "Bucket" in col_map:
        bucket_exprs.append(
            (pl.col(col_map["Bucket"]).cast(pl.Utf8).str.strip_chars() ==
             pl.col("_Computed_Bucket"))
            .alias("_Bucket_Match")
        )
    if "_Computed_Age_Days" in [e.meta.output_name() if hasattr(e.meta, "output_name") 
                                 else "" for e in bucket_exprs]:
        lf = lf.with_columns(bucket_exprs)
    else:
        try:
            lf = lf.with_columns(bucket_exprs)
        except Exception:
            pass

    # ── SINGLE COLLECT ──
    df = lf.collect()

    # ── Violation counts post-collect ──
    type_violations = []
    for key in ["BREAK AMOUNT CCY", "BREAK AMOUNT GBP", "ABS GBP", "Age Days"]:
        if key not in col_map: continue
        col    = col_map[key]
        gained = df[col].null_count() - raw[col].null_count()
        if gained > 0:
            sample = raw[col].cast(pl.Utf8).drop_nulls().head(3).to_list()
            type_violations.append({
                "Column": col, "Expected Type": "Float64",
                "Violation Count": gained,
                "Sample Values": ", ".join(str(s) for s in sample),
            })

    # ── Filter options ──
    filter_options = {}
    for key in ["Period","Team","Rec Name (as per Rec Cube)","Entity",
                "Asset Class","Type of break","True/Systemic Breaks"]:
        if key in col_map and col_map[key] in df.columns:
            filter_options[key] = df[col_map[key]].drop_nulls().unique().sort().to_list()

    type_violations_df = pd.DataFrame(type_violations) if type_violations else \
        pd.DataFrame(columns=["Column","Expected Type","Violation Count","Sample Values"])

    return df, col_map, filter_options, type_violations_df


# ─────────────────────────── Global Filters ───────────────────────────

def apply_filters(df: pl.DataFrame, col_map: dict, filter_options: dict) -> pl.DataFrame:
    st.sidebar.markdown("---")
    st.sidebar.markdown("### 🔍 Global Filters")
    mask = pl.lit(True)
    for key, label, wkey in [
        ("Period",                     "Period",        "f_period"),
        ("Team",                       "Team",          "f_team"),
        ("Rec Name (as per Rec Cube)", "Rec Name",      "f_rec"),
        ("Entity",                     "Entity",        "f_entity"),
        ("Asset Class",                "Asset Class",   "f_ac"),
        ("Type of break",              "Type of Break", "f_tob"),
        ("True/Systemic Breaks",       "True/Systemic", "f_ts"),
    ]:
        if key not in filter_options: continue
        opts     = filter_options[key]
        selected = st.sidebar.multiselect(label, opts, default=opts, key=wkey)
        if selected and col_map.get(key) in df.columns:
            mask = mask & pl.col(col_map[key]).is_in(selected)
    return df.filter(mask)


# ─────────────────────────── IQR Outliers ───────────────────────────

def detect_outliers(df: pl.DataFrame, col: str) -> pd.DataFrame:
    s = df[col].drop_nulls()
    if len(s) < 10: return pd.DataFrame()
    q1, q3 = s.quantile(0.25), s.quantile(0.75)
    iqr = q3 - q1
    lo, hi = q1 - 1.5*iqr, q3 + 1.5*iqr
    out = s.filter((s < lo) | (s > hi))
    if len(out) == 0: return pd.DataFrame()
    return pd.DataFrame({
        "Column":[col],"Outlier Count":[len(out)],
        "Outlier %":[round(len(out)/len(s)*100,2)],
        "IQR Lower":[round(lo,2)],"IQR Upper":[round(hi,2)],
        "Min Outlier":[round(out.min(),2)],"Max Outlier":[round(out.max(),2)],
    })


