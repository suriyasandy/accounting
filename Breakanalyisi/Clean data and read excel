    </div>""", unsafe_allow_html=True)


def safe_mom_pct(current, previous):
    if not previous: return None
    return round(((current - previous) / abs(previous)) * 100, 1)


def format_number(n, decimal=0):
    if n is None or (isinstance(n, float) and np.isnan(n)): return "N/A"
    return f"{int(n):,}" if decimal == 0 else f"{n:,.{decimal}f}"


def format_short(n, prefix="£"):
    if n is None or (isinstance(n, float) and np.isnan(n)): return "N/A"
    v, sign = abs(float(n)), "-" if float(n) < 0 else ""
    if v >= 1_000_000_000: return f"{sign}{prefix}{v/1e9:.1f}B"
    if v >= 1_000_000:     return f"{sign}{prefix}{v/1e6:.1f}M"
    if v >= 1_000:         return f"{sign}{prefix}{v/1e3:.1f}K"
    return f"{sign}{prefix}{v:,.0f}"


